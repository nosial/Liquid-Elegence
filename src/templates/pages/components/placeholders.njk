{% set root = "../../" %}
{% extends "layouts/dashboard.njk" %}

{% block title %}Placeholders — Liquid Elegance{% endblock %}

{% block breadcrumb %}
<li class="breadcrumb-item"><a href="javascript:void(0)">Components</a></li>
<li class="breadcrumb-item active">Placeholders</li>
{% endblock %}


{% block content %}

{# ── Placeholder Glow ───────────────────────────────────────────────── #}
<div class="row g-4 mb-4">
    <div class="col-lg-6">
        <div class="glass-card">
            <div class="glass-card-body">
                <h5 class="mb-1">Placeholder — Glow Effect</h5>
                <p class="text-muted mb-3 le-fs-body">Skeleton placeholders with a pulsing glow animation for content loading states.</p>
                <div class="d-flex align-items-start gap-3 mb-3">
                    <div class="placeholder-glow">
                        <span class="placeholder rounded-circle d-block le-box-48"></span>
                    </div>
                    <div class="flex-grow-1">
                        <p class="placeholder-glow mb-2">
                            <span class="placeholder col-6 rounded"></span>
                        </p>
                        <p class="placeholder-glow mb-2">
                            <span class="placeholder col-8 rounded"></span>
                        </p>
                        <p class="placeholder-glow mb-0">
                            <span class="placeholder col-4 rounded"></span>
                        </p>
                    </div>
                </div>
                <div class="glass-card le-bg-glass-subtle">
                    <div class="glass-card-body py-2 px-3">
                        <h6 class="d-flex align-items-center gap-2 mb-2 le-fs-base"><i data-feather="code" class="le-icon-14"></i> Usage</h6>
                        <pre class="mb-0 le-fs-base le-ws-pre-wrap"><code>&lt;p class="placeholder-glow"&gt;
    &lt;span class="placeholder col-6 rounded"&gt;&lt;/span&gt;
&lt;/p&gt;

&lt;!-- Circle avatar skeleton --&gt;
&lt;div class="placeholder-glow"&gt;
    &lt;span class="placeholder rounded-circle"
          style="width:48px;height:48px;display:block;"&gt;
    &lt;/span&gt;
&lt;/div&gt;</code></pre>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# ── Placeholder Wave ───────────────────────────────────────────── #}
    <div class="col-lg-6">
        <div class="glass-card">
            <div class="glass-card-body">
                <h5 class="mb-1">Placeholder — Wave Effect</h5>
                <p class="text-muted mb-3 le-fs-body">Skeleton placeholders with a sweeping wave animation across the skeleton.</p>
                <div class="placeholder-wave mb-3">
                    <span class="placeholder col-12 rounded mb-2 le-h-120"></span>
                    <span class="placeholder col-8 rounded mb-2"></span>
                    <span class="placeholder col-10 rounded mb-2"></span>
                    <span class="placeholder col-6 rounded"></span>
                </div>
                <div class="d-flex gap-2 placeholder-wave">
                    <span class="placeholder col-3 rounded btn btn-primary disabled le-h-32"></span>
                    <span class="placeholder col-2 rounded btn btn-secondary disabled le-h-32"></span>
                </div>
                <div class="glass-card mt-3 le-bg-glass-subtle">
                    <div class="glass-card-body py-2 px-3">
                        <h6 class="d-flex align-items-center gap-2 mb-2 le-fs-base"><i data-feather="code" class="le-icon-14"></i> Usage</h6>
                        <pre class="mb-0 le-fs-base le-ws-pre-wrap"><code>&lt;div class="placeholder-wave"&gt;
    &lt;span class="placeholder col-12 rounded"&gt;&lt;/span&gt;
    &lt;span class="placeholder col-8 rounded"&gt;&lt;/span&gt;
&lt;/div&gt;

&lt;!-- Skeleton button --&gt;
&lt;a class="btn btn-primary disabled placeholder col-4"&gt;&lt;/a&gt;</code></pre>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

{# ── Placeholder Sizes & Colours ───────────────────────────────────── #}
<div class="row g-4 mb-4">
    <div class="col-lg-6">
        <div class="glass-card">
            <div class="glass-card-body">
                <h5 class="mb-1">Skeleton Text Sizes</h5>
                <p class="text-muted mb-3 le-fs-body">Placeholder blocks can simulate different text sizes using sizing classes.</p>
                <div class="placeholder-glow">
                    <p class="placeholder-glow mb-3">
                        <span class="placeholder col-10 rounded placeholder-lg"></span>
                    </p>
                    <p class="placeholder-glow mb-3">
                        <span class="placeholder col-8 rounded"></span>
                    </p>
                    <p class="placeholder-glow mb-3">
                        <span class="placeholder col-6 rounded placeholder-sm"></span>
                    </p>
                    <p class="placeholder-glow mb-0">
                        <span class="placeholder col-4 rounded placeholder-xs"></span>
                    </p>
                </div>
                <div class="glass-card mt-3 le-bg-glass-subtle">
                    <div class="glass-card-body py-2 px-3">
                        <h6 class="d-flex align-items-center gap-2 mb-2 le-fs-base"><i data-feather="code" class="le-icon-14"></i> Usage</h6>
                        <pre class="mb-0 le-fs-base le-ws-pre-wrap"><code>&lt;!-- Sizing: placeholder-lg / (default) / placeholder-sm / placeholder-xs --&gt;
&lt;span class="placeholder col-10 rounded placeholder-lg"&gt;&lt;/span&gt;
&lt;span class="placeholder col-8 rounded"&gt;&lt;/span&gt;
&lt;span class="placeholder col-6 rounded placeholder-sm"&gt;&lt;/span&gt;
&lt;span class="placeholder col-4 rounded placeholder-xs"&gt;&lt;/span&gt;</code></pre>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# ── Placeholder Colour Variants ───────────────────────────────── #}
    <div class="col-lg-6">
        <div class="glass-card">
            <div class="glass-card-body">
                <h5 class="mb-1">Colour Variants</h5>
                <p class="text-muted mb-3 le-fs-body">Placeholders support <code>bg-*</code> utility classes for colour customisation.</p>
                <div class="placeholder-glow mb-3">
                    <span class="placeholder col-8 rounded bg-primary mb-2"></span>
                    <span class="placeholder col-7 rounded bg-success mb-2"></span>
                    <span class="placeholder col-9 rounded bg-danger mb-2"></span>
                    <span class="placeholder col-6 rounded bg-warning mb-2"></span>
                    <span class="placeholder col-5 rounded bg-info"></span>
                </div>
                <div class="glass-card le-bg-glass-subtle">
                    <div class="glass-card-body py-2 px-3">
                        <h6 class="d-flex align-items-center gap-2 mb-2 le-fs-base"><i data-feather="code" class="le-icon-14"></i> Usage</h6>
                        <pre class="mb-0 le-fs-base le-ws-pre-wrap"><code>&lt;span class="placeholder col-8 rounded bg-primary"&gt;&lt;/span&gt;
&lt;span class="placeholder col-6 rounded bg-success"&gt;&lt;/span&gt;
&lt;span class="placeholder col-5 rounded bg-warning"&gt;&lt;/span&gt;</code></pre>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

{# ── Practical Patterns ────────────────────────────────────────────── #}
<div class="row g-4 mb-4">
    <div class="col-12">
        <div class="glass-card">
            <div class="glass-card-body">
                <h5 class="mb-1">Practical Loading Patterns</h5>
                <p class="text-muted mb-3 le-fs-body">Common real-world skeleton loading layouts.</p>

                <div class="row g-4">
                    {# Card skeleton #}
                    <div class="col-md-4">
                        <div class="card border-0 le-bg-glass p-3" aria-hidden="true">
                            <div class="placeholder-glow">
                                <span class="placeholder col-12 rounded le-h-120 mb-3"></span>
                                <span class="placeholder col-8 rounded mb-2"></span>
                                <span class="placeholder col-6 rounded mb-3"></span>
                                <span class="placeholder col-4 rounded"></span>
                            </div>
                        </div>
                    </div>

                    {# Profile skeleton #}
                    <div class="col-md-4">
                        <div class="card border-0 le-bg-glass p-3" aria-hidden="true">
                            <div class="d-flex align-items-center gap-3 mb-3">
                                <span class="placeholder rounded-circle le-box-48"></span>
                                <div class="flex-grow-1 placeholder-glow">
                                    <span class="placeholder col-8 rounded mb-1"></span>
                                    <span class="placeholder col-5 rounded"></span>
                                </div>
                            </div>
                            <div class="placeholder-glow">
                                <span class="placeholder col-12 rounded mb-2 le-h-16"></span>
                                <span class="placeholder col-12 rounded mb-2 le-h-16"></span>
                                <span class="placeholder col-8 rounded le-h-16"></span>
                            </div>
                        </div>
                    </div>

                    {# Table skeleton #}
                    <div class="col-md-4">
                        <div class="card border-0 le-bg-glass p-3" aria-hidden="true">
                            <div class="placeholder-glow">
                                <span class="placeholder col-4 rounded mb-3 le-h-20"></span>
                                <span class="placeholder col-12 rounded mb-2 le-h-14"></span>
                                <span class="placeholder col-12 rounded mb-2 le-h-14"></span>
                                <span class="placeholder col-12 rounded mb-2 le-h-14"></span>
                                <span class="placeholder col-8 rounded le-h-14"></span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

{% endblock %}
