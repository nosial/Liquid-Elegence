{% set root = "../../" %}
{% extends "layouts/dashboard.njk" %}

{% block title %}Glass Effects — Liquid Elegance{% endblock %}

{% block breadcrumb %}
<li class="breadcrumb-item"><a href="javascript:void(0)">Components</a></li>
<li class="breadcrumb-item active">Glass Effects</li>
{% endblock %}


{% block content %}

<div class="row g-4 mb-4">
    <div class="col-12">
        <div class="glass-card le-bg-glass-subtle">
            <div class="glass-card-body py-2 px-3">
                <h6 class="d-flex align-items-center gap-2 mb-2 le-fs-base"><i data-feather="code" class="le-icon-14"></i> Quick Reference</h6>
                <pre class="mb-0 le-fs-base le-ws-pre-wrap"><code>&lt;!-- Glass card --&gt;
&lt;div class="glass-card"&gt;...&lt;/div&gt;

&lt;!-- Glass effects --&gt;
&lt;div class="glass-reflection"&gt;...&lt;/div&gt;
&lt;div class="glass-prismatic-edge"&gt;...&lt;/div&gt;
&lt;div class="glass-halo"&gt;...&lt;/div&gt;

&lt;!-- CSS variable customization --&gt;
&lt;style&gt;
:root {
    --le-glass-bg: rgba(255, 255, 255, 0.08);
    --le-glass-bg-subtle: rgba(255, 255, 255, 0.04);
    --le-glass-blur: 12px;
    --le-glass-border: rgba(255, 255, 255, 0.12);
}
&lt;/style&gt;</code></pre>
            </div>
        </div>
    </div>
</div>

{# ──────────────────────────────────────────────
   1. Glass Surface Variants
   ────────────────────────────────────────────── #}
<div class="row g-4 mb-4">
    <div class="col-12">
        <div class="glass-card">
            <div class="glass-card-body">
                <h5 class="mb-1"><i data-feather="layers"></i> Glass Surface Variants</h5>
                <p class="text-muted text-sm mb-3">Three core surface opacities. Shown over a gradient so the transparency and blur differences are visible.</p>

                <div class="demo-backdrop">
                    <div class="demo-shapes">
                        <span class="s1"></span>
                        <span class="s2"></span>
                        <span class="s3"></span>
                        <span class="s4"></span>
                    </div>
                    <div class="row g-3 demo-stacked">
                        <div class="col-md-4">
                            <div class="glass rounded p-4">
                                <h6 class="demo-text mb-2">.glass</h6>
                                <p class="demo-text-sm mb-2">Standard surface — balanced translucency with 20px backdrop blur.</p>
                                <button class="btn btn-sm btn-light">Action</button>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="glass-strong rounded p-4">
                                <h6 class="demo-text mb-2">.glass-strong</h6>
                                <p class="demo-text-sm mb-2">Stronger opacity with heavier 40px blur for prominent surfaces.</p>
                                <button class="btn btn-sm btn-light">Action</button>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="glass-subtle rounded p-4">
                                <h6 class="demo-text mb-2">.glass-subtle</h6>
                                <p class="demo-text-sm mb-2">Barely-there surface with minimal 10px blur for background layers.</p>
                                <button class="btn btn-sm btn-light">Action</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

{# ──────────────────────────────────────────────
   2. Light Reflection & Color Bending
   ────────────────────────────────────────────── #}
<div class="row g-4 mb-4">
    <div class="col-lg-6">
        <div class="glass-card">
            <div class="glass-card-body">
                <h5 class="mb-1"><i data-feather="sun"></i> Light Reflection</h5>
                <p class="text-muted text-sm mb-3">Adds a radial gradient highlight simulating light bouncing off glass.</p>

                <div class="demo-backdrop-warm">
                    <div class="demo-shapes">
                        <span class="s1"></span>
                        <span class="s3"></span>
                    </div>
                    <div class="glass light-reflection rounded p-4 demo-stacked">
                        <h6 class="demo-text mb-2">Reflected Surface</h6>
                        <p class="demo-text-sm mb-0">Notice the soft highlight in the upper-left corner. Hover to see it shift and intensify.</p>
                    </div>
                    <div class="demo-label mt-2">.light-reflection</div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-6">
        <div class="glass-card">
            <div class="glass-card-body">
                <h5 class="mb-1"><i data-feather="aperture"></i> Color Bending</h5>
                <p class="text-muted text-sm mb-3">A subtle multi-color gradient overlay that simulates light refraction through glass.</p>

                <div class="demo-backdrop-cool">
                    <div class="demo-shapes">
                        <span class="s2"></span>
                        <span class="s4"></span>
                    </div>
                    <div class="glass color-bend rounded p-4 demo-stacked">
                        <h6 class="demo-text mb-2">Color Bent Surface</h6>
                        <p class="demo-text-sm mb-0">The color gradient bends from one end to the other, creating depth. Hover to intensify.</p>
                    </div>
                    <div class="demo-label mt-2">.color-bend</div>
                </div>
            </div>
        </div>
    </div>
</div>

