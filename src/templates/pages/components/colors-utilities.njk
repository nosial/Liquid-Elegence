{% set root = "../../" %}
{% extends "layouts/dashboard.njk" %}

{% block title %}Colors &amp; Utilities — Liquid Elegance{% endblock %}

{% block breadcrumb %}
<li class="breadcrumb-item"><a href="javascript:void(0)">Components</a></li>
<li class="breadcrumb-item active">Colors &amp; Utilities</li>
{% endblock %}


{% block content %}

{# ── Text Colours ────────────────────────────────────────────────────── #}
<div class="row g-4 mb-4">
    <div class="col-lg-6">
        <div class="glass-card">
            <div class="glass-card-body">
                <h5 class="mb-1">Text Colours</h5>
                <p class="text-muted mb-3 le-fs-body">Theme-aware text colour classes.</p>
                <div class="d-flex flex-column gap-2">
                    <span class="text-primary fw-semibold">text-primary — Primary brand colour</span>
                    <span class="text-secondary fw-semibold">text-secondary — Secondary colour</span>
                    <span class="text-success fw-semibold">text-success — Success / positive</span>
                    <span class="text-danger fw-semibold">text-danger — Danger / error</span>
                    <span class="text-warning fw-semibold">text-warning — Warning / caution</span>
                    <span class="text-info fw-semibold">text-info — Information</span>
                    <span class="text-muted">text-muted — Muted / de-emphasised</span>
                    <span class="text-body">text-body — Default body text</span>
                    <span class="text-white bg-dark px-2 rounded">text-white — White (on dark background)</span>
                </div>
                <div class="glass-card mt-3 le-bg-glass-subtle">
                    <div class="glass-card-body py-2 px-3">
                        <h6 class="d-flex align-items-center gap-2 mb-2 le-fs-base"><i data-feather="code" class="le-icon-14"></i> Usage</h6>
                        <pre class="mb-0 le-fs-base le-ws-pre-wrap"><code>&lt;span class="text-primary"&gt;Primary text&lt;/span&gt;
&lt;span class="text-success"&gt;Success text&lt;/span&gt;
&lt;span class="text-muted"&gt;Muted text&lt;/span&gt;</code></pre>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# ── Background Colours ──────────────────────────────────────────── #}
    <div class="col-lg-6">
        <div class="glass-card">
            <div class="glass-card-body">
                <h5 class="mb-1">Background Colours</h5>
                <p class="text-muted mb-3 le-fs-body">Background colour classes for badges, cards, and containers.</p>
                <div class="d-flex flex-wrap gap-2 mb-3">
                    <span class="badge bg-primary">bg-primary</span>
                    <span class="badge bg-secondary">bg-secondary</span>
                    <span class="badge bg-success">bg-success</span>
                    <span class="badge bg-danger">bg-danger</span>
                    <span class="badge bg-warning text-dark">bg-warning</span>
                    <span class="badge bg-info">bg-info</span>
                    <span class="badge bg-dark">bg-dark</span>
                    <span class="badge bg-light text-dark">bg-light</span>
                </div>
                <h6 class="mb-2">Subtle Backgrounds</h6>
                <div class="d-flex flex-wrap gap-2">
                    <span class="badge text-primary-emphasis bg-primary-subtle">primary-subtle</span>
                    <span class="badge text-success-emphasis bg-success-subtle">success-subtle</span>
                    <span class="badge text-danger-emphasis bg-danger-subtle">danger-subtle</span>
                    <span class="badge text-warning-emphasis bg-warning-subtle">warning-subtle</span>
                    <span class="badge text-info-emphasis bg-info-subtle">info-subtle</span>
                </div>
                <div class="glass-card mt-3 le-bg-glass-subtle">
                    <div class="glass-card-body py-2 px-3">
                        <h6 class="d-flex align-items-center gap-2 mb-2 le-fs-base"><i data-feather="code" class="le-icon-14"></i> Usage</h6>
                        <pre class="mb-0 le-fs-base le-ws-pre-wrap"><code>&lt;div class="bg-primary text-white"&gt;…&lt;/div&gt;
&lt;div class="bg-success-subtle text-success-emphasis"&gt;…&lt;/div&gt;</code></pre>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

{# ── Glass Theme Colours ────────────────────────────────────────────── #}
<div class="row g-4 mb-4">
    <div class="col-12">
        <div class="glass-card">
            <div class="glass-card-body">
                <h5 class="mb-1">Glass Theme Colour Variables</h5>
                <p class="text-muted mb-3 le-fs-body">CSS custom properties used throughout the Liquid Elegance theme.</p>
                <div class="row g-3">
                    <div class="col-md-4 col-lg-3">
                        <div class="p-3 rounded text-center le-bg-primary-white">--le-primary</div>
                    </div>
                    <div class="col-md-4 col-lg-3">
                        <div class="p-3 rounded text-center le-bg-secondary-white">--le-secondary</div>
                    </div>
                    <div class="col-md-4 col-lg-3">
                        <div class="p-3 rounded text-center le-bg-success-white">--le-success</div>
                    </div>
                    <div class="col-md-4 col-lg-3">
                        <div class="p-3 rounded text-center le-bg-danger-white">--le-danger</div>
                    </div>
                    <div class="col-md-4 col-lg-3">
                        <div class="p-3 rounded text-center le-bg-warning-black">--le-warning</div>
                    </div>
                    <div class="col-md-4 col-lg-3">
                        <div class="p-3 rounded text-center le-bg-info-white">--le-info</div>
                    </div>
                    <div class="col-md-4 col-lg-3">
                        <div class="p-3 rounded text-center le-bg-glass le-border-glass">--le-glass-bg</div>
                    </div>
                    <div class="col-md-4 col-lg-3">
                        <div class="p-3 rounded text-center le-bg-glass-strong le-border-glass">--le-glass-bg-strong</div>
                    </div>
                </div>
                <div class="glass-card mt-3 le-bg-glass-subtle">
                    <div class="glass-card-body py-2 px-3">
                        <h6 class="d-flex align-items-center gap-2 mb-2 le-fs-base"><i data-feather="code" class="le-icon-14"></i> Usage</h6>
                        <pre class="mb-0 le-fs-base le-ws-pre-wrap"><code>/* Use in custom CSS */
.custom-element {
    background: var(--le-primary);
    color: #fff;
    border: 1px solid var(--le-glass-border);
}

/* Glass backgrounds */
.my-card {
    background: var(--le-glass-bg);
    backdrop-filter: blur(12px);
}</code></pre>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

{# ── Shadows ─────────────────────────────────────────────────────────── #}
<div class="row g-4 mb-4">
    <div class="col-lg-6">
        <div class="glass-card">
            <div class="glass-card-body">
                <h5 class="mb-1">Shadows</h5>
                <p class="text-muted mb-3 le-fs-body">Bootstrap shadow utilities for depth.</p>
                <div class="row g-3">
                    <div class="col-6">
                        <div class="p-3 rounded text-center shadow-none le-bg-glass">shadow-none</div>
                    </div>
                    <div class="col-6">
                        <div class="p-3 rounded text-center shadow-sm le-bg-glass">shadow-sm</div>
                    </div>
                    <div class="col-6">
                        <div class="p-3 rounded text-center shadow le-bg-glass">shadow</div>
                    </div>
                    <div class="col-6">
                        <div class="p-3 rounded text-center shadow-lg le-bg-glass">shadow-lg</div>
                    </div>
                </div>
                <div class="glass-card mt-3 le-bg-glass-subtle">
                    <div class="glass-card-body py-2 px-3">
                        <h6 class="d-flex align-items-center gap-2 mb-2 le-fs-base"><i data-feather="code" class="le-icon-14"></i> Usage</h6>
                        <pre class="mb-0 le-fs-base le-ws-pre-wrap"><code>&lt;div class="shadow-sm"&gt;Small shadow&lt;/div&gt;
&lt;div class="shadow"&gt;Regular shadow&lt;/div&gt;
&lt;div class="shadow-lg"&gt;Large shadow&lt;/div&gt;</code></pre>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# ── Borders & Radius ────────────────────────────────────────────── #}
    <div class="col-lg-6">
        <div class="glass-card">
            <div class="glass-card-body">
                <h5 class="mb-1">Borders &amp; Radius</h5>
                <p class="text-muted mb-3 le-fs-body">Border and border-radius utilities.</p>
                <div class="row g-3 mb-3">
                    <div class="col-6">
                        <div class="p-3 text-center border le-bg-glass">border</div>
                    </div>
                    <div class="col-6">
                        <div class="p-3 text-center border-top le-bg-glass">border-top</div>
                    </div>
                    <div class="col-6">
                        <div class="p-3 text-center border border-primary le-bg-glass">border-primary</div>
                    </div>
                    <div class="col-6">
                        <div class="p-3 text-center border border-danger border-2 le-bg-glass">border-danger-2</div>
                    </div>
                </div>
                <h6 class="mb-2">Border Radius</h6>
                <div class="d-flex flex-wrap gap-3">
                    <div class="p-3 text-center rounded-0 border le-bg-glass le-min-w-80">rounded-0</div>
                    <div class="p-3 text-center rounded border le-bg-glass le-min-w-80">rounded</div>
                    <div class="p-3 text-center rounded-3 border le-bg-glass le-min-w-80">rounded-3</div>
                    <div class="p-3 text-center rounded-pill border le-bg-glass le-min-w-80">rounded-pill</div>
                    <div class="text-center rounded-circle border d-flex align-items-center justify-content-center le-bg-glass le-box-64">circle</div>
                </div>
                <div class="glass-card mt-3 le-bg-glass-subtle">
                    <div class="glass-card-body py-2 px-3">
                        <h6 class="d-flex align-items-center gap-2 mb-2 le-fs-base"><i data-feather="code" class="le-icon-14"></i> Usage</h6>
                        <pre class="mb-0 le-fs-base le-ws-pre-wrap"><code>&lt;div class="border border-primary"&gt;…&lt;/div&gt;
&lt;div class="rounded-pill"&gt;…&lt;/div&gt;
&lt;div class="rounded-circle"&gt;…&lt;/div&gt;</code></pre>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

{# ── Spacing ─────────────────────────────────────────────────────────── #}
<div class="row g-4 mb-4">
    <div class="col-lg-6">
        <div class="glass-card">
            <div class="glass-card-body">
                <h5 class="mb-1">Spacing (Margin &amp; Padding)</h5>
                <p class="text-muted mb-3 le-fs-body">Bootstrap spacing scale from 0 to 5 (0, 0.25rem, 0.5rem, 1rem, 1.5rem, 3rem).</p>
                <div class="d-flex flex-column gap-2">
                    {% for i in range(0, 6) %}
                    <div class="d-flex align-items-center gap-2">
                        <code class="text-nowrap le-min-w-40">p-{{ i }}</code>
                        <div class="le-badge-primary-outline">
                            <div class="p-{{ i }} le-bg-primary-20 le-fs-base le-ws-nowrap">Content</div>
                        </div>
                    </div>
                    {% endfor %}
                </div>
                <div class="glass-card mt-3 le-bg-glass-subtle">
                    <div class="glass-card-body py-2 px-3">
                        <h6 class="d-flex align-items-center gap-2 mb-2 le-fs-base"><i data-feather="code" class="le-icon-14"></i> Usage</h6>
                        <pre class="mb-0 le-fs-base le-ws-pre-wrap"><code>&lt;!-- Padding: p, pt, pb, ps, pe, px, py --&gt;
&lt;div class="p-3"&gt;…&lt;/div&gt;
&lt;div class="px-4 py-2"&gt;…&lt;/div&gt;

&lt;!-- Margin: m, mt, mb, ms, me, mx, my --&gt;
&lt;div class="mt-3 mb-4"&gt;…&lt;/div&gt;
&lt;div class="mx-auto" style="width:200px;"&gt;Centred&lt;/div&gt;</code></pre>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# ── Display & Visibility ────────────────────────────────────────── #}
    <div class="col-lg-6">
        <div class="glass-card">
            <div class="glass-card-body">
                <h5 class="mb-1">Display &amp; Visibility</h5>
                <p class="text-muted mb-3 le-fs-body">Control visibility and display behaviour at different breakpoints.</p>
                <div class="table-responsive">
                    <table class="table table-sm mb-0 le-fs-body">
                        <thead>
                            <tr>
                                <th>Class</th>
                                <th>Effect</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr><td><code>d-none</code></td><td>Hidden</td></tr>
                            <tr><td><code>d-block</code></td><td>Block display</td></tr>
                            <tr><td><code>d-inline</code></td><td>Inline display</td></tr>
                            <tr><td><code>d-inline-block</code></td><td>Inline-block display</td></tr>
                            <tr><td><code>d-flex</code></td><td>Flexbox container</td></tr>
                            <tr><td><code>d-grid</code></td><td>Grid container</td></tr>
                            <tr><td><code>d-none d-md-block</code></td><td>Hidden below md breakpoint</td></tr>
                            <tr><td><code>d-md-none</code></td><td>Hidden at md and above</td></tr>
                            <tr><td><code>invisible</code></td><td>Invisible (keeps space)</td></tr>
                            <tr><td><code>visually-hidden</code></td><td>Screen-reader only</td></tr>
                        </tbody>
                    </table>
                </div>
                <div class="glass-card mt-3 le-bg-glass-subtle">
                    <div class="glass-card-body py-2 px-3">
                        <h6 class="d-flex align-items-center gap-2 mb-2 le-fs-base"><i data-feather="code" class="le-icon-14"></i> Usage</h6>
                        <pre class="mb-0 le-fs-base le-ws-pre-wrap"><code>&lt;!-- Show only on medium and up --&gt;
&lt;div class="d-none d-md-block"&gt;Desktop only&lt;/div&gt;

&lt;!-- Show only on mobile --&gt;
&lt;div class="d-block d-md-none"&gt;Mobile only&lt;/div&gt;

&lt;!-- Flexbox layout --&gt;
&lt;div class="d-flex justify-content-between align-items-center"&gt;
    &lt;span&gt;Left&lt;/span&gt;
    &lt;span&gt;Right&lt;/span&gt;
&lt;/div&gt;</code></pre>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

{# ── Opacity & Overflow ─────────────────────────────────────────────── #}
<div class="row g-4 mb-4">
    <div class="col-lg-6">
        <div class="glass-card">
            <div class="glass-card-body">
                <h5 class="mb-1">Opacity</h5>
                <p class="text-muted mb-3 le-fs-body">Bootstrap opacity utility classes.</p>
                <div class="d-flex flex-wrap gap-3">
                    <div class="p-3 rounded text-center opacity-100 le-bg-primary-white le-min-w-80">100%</div>
                    <div class="p-3 rounded text-center opacity-75 le-bg-primary-white le-min-w-80">75%</div>
                    <div class="p-3 rounded text-center opacity-50 le-bg-primary-white le-min-w-80">50%</div>
                    <div class="p-3 rounded text-center opacity-25 le-bg-primary-white le-min-w-80">25%</div>
                </div>
                <div class="glass-card mt-3 le-bg-glass-subtle">
                    <div class="glass-card-body py-2 px-3">
                        <h6 class="d-flex align-items-center gap-2 mb-2 le-fs-base"><i data-feather="code" class="le-icon-14"></i> Usage</h6>
                        <pre class="mb-0 le-fs-base le-ws-pre-wrap"><code>&lt;div class="opacity-75"&gt;75% opacity&lt;/div&gt;
&lt;div class="opacity-50"&gt;50% opacity&lt;/div&gt;</code></pre>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="glass-card">
            <div class="glass-card-body">
                <h5 class="mb-1">Overflow</h5>
                <p class="text-muted mb-3 le-fs-body">Control how content overflows its container.</p>
                <div class="row g-3">
                    <div class="col-6">
                        <code class="d-block mb-1">overflow-auto</code>
                        <div class="overflow-auto p-2 rounded border le-thumb-80">
                            <p class="mb-0 le-fs-base">This content is long enough to scroll. The overflow-auto class adds scrollbars only when needed. Resize to see the effect in action.</p>
                        </div>
                    </div>
                    <div class="col-6">
                        <code class="d-block mb-1">overflow-hidden</code>
                        <div class="overflow-hidden p-2 rounded border le-thumb-80">
                            <p class="mb-0 le-fs-base">This content is long enough to be clipped. The overflow-hidden class hides any content that extends beyond the container boundary.</p>
                        </div>
                    </div>
                </div>
                <div class="glass-card mt-3 le-bg-glass-subtle">
                    <div class="glass-card-body py-2 px-3">
                        <h6 class="d-flex align-items-center gap-2 mb-2 le-fs-base"><i data-feather="code" class="le-icon-14"></i> Usage</h6>
                        <pre class="mb-0 le-fs-base le-ws-pre-wrap"><code>&lt;div class="overflow-auto" style="max-height:200px;"&gt;
    Scrollable content…
&lt;/div&gt;
&lt;div class="overflow-hidden"&gt;Clipped content&lt;/div&gt;</code></pre>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

{% endblock %}
