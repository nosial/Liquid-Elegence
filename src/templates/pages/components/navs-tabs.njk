    </div>
</div>

{# ── Tabs with Practical Content ──────────────────────────────────────── #}
<div class="row g-4 mb-4">
    <div class="col-12">
        <div class="glass-card">
            <div class="glass-card-body">
                <h5 class="mb-1">User Profile</h5>
                <p class="text-muted mb-3 le-fs-body">A real-world example combining glass underline tabs with practical content panels.</p>

                <ul class="nav nav-underline-glass" id="profileTabs" role="tablist">
                    <li class="nav-item" role="presentation">
                        <a class="nav-link active" id="profileActivity-tab" href="#profileActivity" data-bs-toggle="tab" role="tab" aria-controls="profileActivity" aria-selected="true"><i data-feather="activity" class="le-icon-16"></i> Activity</a>
                    </li>
                    <li class="nav-item" role="presentation">
                        <a class="nav-link" id="profileProjects-tab" href="#profileProjects" data-bs-toggle="tab" role="tab" aria-controls="profileProjects" aria-selected="false"><i data-feather="folder" class="le-icon-16"></i> Projects</a>
                    </li>
                    <li class="nav-item" role="presentation">
                        <a class="nav-link" id="profileSettings-tab" href="#profileSettings" data-bs-toggle="tab" role="tab" aria-controls="profileSettings" aria-selected="false"><i data-feather="settings" class="le-icon-16"></i> Settings</a>
                    </li>
                </ul>

                <div class="tab-content tab-content-glass mt-3" id="profileTabsContent">
                    {# Activity Tab #}
                    <div class="tab-pane fade show active" id="profileActivity" role="tabpanel" aria-labelledby="profileActivity-tab">
                        <div class="activity-feed">
                            <div class="activity-item d-flex gap-3 mb-3 pb-3 border-bottom">
                                <div class="flex-shrink-0">
                                    <span class="badge bg-primary rounded-circle p-2"><i data-feather="check-circle" class="le-icon-14"></i></span>
                                </div>
                                <div class="flex-grow-1">
                                    <p class="mb-1"><strong>Completed task</strong> — Dashboard redesign sprint</p>
                                    <small class="text-muted">2 minutes ago</small>
                                </div>
                            </div>
                            <div class="activity-item d-flex gap-3 mb-3 pb-3 border-bottom">
                                <div class="flex-shrink-0">
                                    <span class="badge bg-success rounded-circle p-2"><i data-feather="git-commit" class="le-icon-14"></i></span>
                                </div>
                                <div class="flex-grow-1">
                                    <p class="mb-1"><strong>Pushed commit</strong> — Adjusted nav bar alignment on mobile</p>
                                    <small class="text-muted">1 hour ago</small>
                                </div>
                            </div>
                            <div class="activity-item d-flex gap-3 mb-3 pb-3 border-bottom">
                                <div class="flex-shrink-0">
                                    <span class="badge bg-warning rounded-circle p-2"><i data-feather="message-square" class="le-icon-14"></i></span>
                                </div>
                                <div class="flex-grow-1">
                                    <p class="mb-1"><strong>New comment</strong> — on "API Integration Plan"</p>
                                    <small class="text-muted">3 hours ago</small>
                                </div>
                            </div>
                            <div class="activity-item d-flex gap-3">
                                <div class="flex-shrink-0">
                                    <span class="badge bg-info rounded-circle p-2"><i data-feather="user-plus" class="le-icon-14"></i></span>
                                </div>
                                <div class="flex-grow-1">
                                    <p class="mb-1"><strong>New team member</strong> — Sarah joined the project</p>
                                    <small class="text-muted">Yesterday</small>
                                </div>
                            </div>
                        </div>
                    </div>

                    {# Projects Tab #}
                    <div class="tab-pane fade" id="profileProjects" role="tabpanel" aria-labelledby="profileProjects-tab">
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead>
                                    <tr>
                                        <th>Project</th>
                                        <th>Status</th>
                                        <th>Due Date</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td>Liquid Elegance Dashboard</td>
                                        <td><span class="badge bg-success">Completed</span></td>
                                        <td>Jan 15, 2025</td>
                                    </tr>
                                    <tr>
                                        <td>API Gateway v2</td>
                                        <td><span class="badge bg-primary">In Progress</span></td>
                                        <td>Mar 01, 2025</td>
                                    </tr>
                                    <tr>
                                        <td>Mobile App Redesign</td>
                                        <td><span class="badge bg-warning text-dark">Planning</span></td>
                                        <td>Apr 20, 2025</td>
                                    </tr>
                                    <tr>
                                        <td>Analytics Module</td>
                                        <td><span class="badge bg-danger">Delayed</span></td>
                                        <td>Feb 10, 2025</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    {# Settings Tab #}
                    <div class="tab-pane fade" id="profileSettings" role="tabpanel" aria-labelledby="profileSettings-tab">
                        <form>
                            <div class="mb-3">
                                <label for="settingsName" class="form-label">Display Name</label>
                                <input type="text" class="form-control glass-input" id="settingsName" placeholder="Enter your name" value="John Doe">
                            </div>
                            <div class="mb-3">
                                <label for="settingsEmail" class="form-label">Email Address</label>
                                <input type="email" class="form-control glass-input" id="settingsEmail" placeholder="Enter your email" value="john@example.com">
                            </div>
                            <div class="mb-3">
                                <label for="settingsBio" class="form-label">Bio</label>
                                <textarea class="form-control glass-input" id="settingsBio" rows="3" placeholder="Write a short bio...">Full-stack developer passionate about clean UI design.</textarea>
                            </div>
                            <button type="button" class="btn btn-glass btn-glass-primary">Save Changes</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

{% endblock %}
