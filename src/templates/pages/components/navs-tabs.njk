{% set root = "../../" %}
{% extends "layouts/dashboard.njk" %}

{% block title %}Navs &amp; Tabs — Liquid Elegance{% endblock %}

{% block breadcrumb %}
<li class="breadcrumb-item"><a href="javascript:void(0)">Components</a></li>
<li class="breadcrumb-item active">Navs &amp; Tabs</li>
{% endblock %}


{% block content %}

{# ── Glass Nav Pills ─────────────────────────────────────────────────── #}
<div class="row g-4 mb-4">
    <div class="col-12">
        <div class="glass-card">
            <div class="glass-card-body">
                <h5 class="mb-1">Glass Nav Pills</h5>
                <p class="text-muted mb-3 le-fs-body">Custom glassmorphic pill navigation with smooth animated transitions.</p>

                <ul class="nav nav-pills-glass" id="glassPills" role="tablist">
                    <li class="nav-item" role="presentation">
                        <a class="nav-link active" id="pillsTab1-tab" href="#pillsTab1" data-bs-toggle="pill" role="tab" aria-controls="pillsTab1" aria-selected="true">Home</a>
                    </li>
                    <li class="nav-item" role="presentation">
                        <a class="nav-link" id="pillsTab2-tab" href="#pillsTab2" data-bs-toggle="pill" role="tab" aria-controls="pillsTab2" aria-selected="false">Profile</a>
                    </li>
                    <li class="nav-item" role="presentation">
                        <a class="nav-link" id="pillsTab3-tab" href="#pillsTab3" data-bs-toggle="pill" role="tab" aria-controls="pillsTab3" aria-selected="false">Messages</a>
                    </li>
                    <li class="nav-item" role="presentation">
                        <a class="nav-link disabled" tabindex="-1" aria-disabled="true">Disabled</a>
                    </li>
                </ul>

                <div class="tab-content tab-content-glass mt-3" id="glassPillsContent">
                    <div class="tab-pane fade show active" id="pillsTab1" role="tabpanel" aria-labelledby="pillsTab1-tab">
                        <p class="mb-0">Welcome to the Home tab. This is a glass-styled pill navigation that blends seamlessly with the glassmorphic design system. Content transitions smoothly between panes.</p>
                    </div>
                    <div class="tab-pane fade" id="pillsTab2" role="tabpanel" aria-labelledby="pillsTab2-tab">
                        <p class="mb-0">Your profile information lives here. Glass nav pills provide a modern, frosted-glass appearance that adapts to both light and dark themes automatically.</p>
                    </div>
                    <div class="tab-pane fade" id="pillsTab3" role="tabpanel" aria-labelledby="pillsTab3-tab">
                        <p class="mb-0">You have 3 new messages waiting. The pill navigation highlights the active tab with a subtle glass accent, providing clear visual feedback to the user.</p>
                    </div>
                </div>
                <div class="glass-card mt-3 le-bg-glass-subtle">
                    <div class="glass-card-body py-2 px-3">
                        <h6 class="d-flex align-items-center gap-2 mb-2 le-fs-base"><i data-feather="code" class="le-icon-14"></i> Usage</h6>
                        <pre class="mb-0 le-fs-base le-ws-pre-wrap"><code>&lt;ul class="nav nav-pills-glass" id="myPills" role="tablist"&gt;
  &lt;li class="nav-item" role="presentation"&gt;
    &lt;a class="nav-link active" href="#tab1" data-bs-toggle="pill" role="tab"&gt;Tab 1&lt;/a&gt;
  &lt;/li&gt;
  &lt;li class="nav-item" role="presentation"&gt;
    &lt;a class="nav-link" href="#tab2" data-bs-toggle="pill" role="tab"&gt;Tab 2&lt;/a&gt;
  &lt;/li&gt;
&lt;/ul&gt;

&lt;div class="tab-content tab-content-glass mt-3"&gt;
  &lt;div class="tab-pane fade show active" id="tab1" role="tabpanel"&gt;Tab 1 content&lt;/div&gt;
  &lt;div class="tab-pane fade" id="tab2" role="tabpanel"&gt;Tab 2 content&lt;/div&gt;
&lt;/div&gt;</code></pre>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

{# ── Glass Underline Tabs ────────────────────────────────────────────── #}
<div class="row g-4 mb-4">
    <div class="col-12">
        <div class="glass-card">
            <div class="glass-card-body">
