                <div class="tab-content tab-content-glass mt-3" id="glassUnderlineContent">
                    <div class="tab-pane fade show active" id="underlineTab1" role="tabpanel" aria-labelledby="underlineTab1-tab">
                        <div class="row g-3">
                            <div class="col-md-4">
                                <div class="glass-card">
                                    <div class="glass-card-body text-center py-3">
                                        <p class="text-muted mb-1 le-fs-base">Total Users</p>
                                        <h4 class="mb-0">12,840</h4>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="glass-card">
                                    <div class="glass-card-body text-center py-3">
                                        <p class="text-muted mb-1 le-fs-base">Revenue</p>
                                        <h4 class="mb-0">$48,290</h4>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="glass-card">
                                    <div class="glass-card-body text-center py-3">
                                        <p class="text-muted mb-1 le-fs-base">Growth</p>
                                        <h4 class="mb-0">+24.5%</h4>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="tab-pane fade" id="underlineTab2" role="tabpanel" aria-labelledby="underlineTab2-tab">
                        <p class="mb-0">Analytics data for the current period. Track page views, session duration, bounce rate, and user engagement metrics across all your dashboard pages.</p>
                    </div>
                    <div class="tab-pane fade" id="underlineTab3" role="tabpanel" aria-labelledby="underlineTab3-tab">
                        <p class="mb-0">Generated reports are available for download. Export weekly, monthly, or custom date-range reports in PDF, CSV, or Excel format.</p>
                    </div>
                    <div class="tab-pane fade" id="underlineTab4" role="tabpanel" aria-labelledby="underlineTab4-tab">
                        <p class="mb-0">Configure your dashboard preferences, notification settings, and data retention policies from this panel.</p>
                    </div>
                </div>
                <div class="glass-card mt-3 le-bg-glass-subtle">
                    <div class="glass-card-body py-2 px-3">
                        <h6 class="d-flex align-items-center gap-2 mb-2 le-fs-base"><i data-feather="code" class="le-icon-14"></i> Usage</h6>
                        <pre class="mb-0 le-fs-base le-ws-pre-wrap"><code>&lt;ul class="nav nav-underline-glass" id="myTabs" role="tablist"&gt;
  &lt;li class="nav-item" role="presentation"&gt;
    &lt;a class="nav-link active" href="#uTab1" data-bs-toggle="tab" role="tab"&gt;Tab 1&lt;/a&gt;
  &lt;/li&gt;
  &lt;li class="nav-item" role="presentation"&gt;
    &lt;a class="nav-link" href="#uTab2" data-bs-toggle="tab" role="tab"&gt;Tab 2&lt;/a&gt;
  &lt;/li&gt;
&lt;/ul&gt;

&lt;div class="tab-content tab-content-glass mt-3"&gt;
  &lt;div class="tab-pane fade show active" id="uTab1" role="tabpanel"&gt;...&lt;/div&gt;
  &lt;div class="tab-pane fade" id="uTab2" role="tabpanel"&gt;...&lt;/div&gt;
&lt;/div&gt;</code></pre>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

{# ── Standard Bootstrap Tabs & Pills ─────────────────────────────────── #}
