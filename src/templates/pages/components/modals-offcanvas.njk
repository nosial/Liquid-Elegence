{% set root = "../../" %}
{% extends "layouts/dashboard.njk" %}

{% block title %}Modals &amp; Offcanvas — Liquid Elegance{% endblock %}

{% block breadcrumb %}
<li class="breadcrumb-item"><a href="javascript:void(0)">Components</a></li>
<li class="breadcrumb-item active">Modals &amp; Offcanvas</li>
{% endblock %}


{% block content %}
<div class="row g-4 mb-4">

    {# ── 1. Standard Bootstrap Modals ── #}
    <div class="col-12">
        <div class="glass-card">
            <div class="glass-card-body">
                <h5 class="mb-1">Standard Bootstrap Modals</h5>
                <p class="text-muted mb-3 le-fs-body">Default Bootstrap 5 modals with glass styling. Click each button to preview.</p>
                <div class="d-flex flex-wrap gap-2">
                    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#defaultModal"><i data-feather="square" class="me-1 le-icon-16"></i>Default Modal</button>
                    <button class="btn btn-secondary" data-bs-toggle="modal" data-bs-target="#scrollableModal"><i data-feather="align-left" class="me-1 le-icon-16"></i>Scrollable Modal</button>
                    <button class="btn btn-info" data-bs-toggle="modal" data-bs-target="#centeredModal"><i data-feather="crosshair" class="me-1 le-icon-16"></i>Centered Modal</button>
                    <button class="btn btn-warning" data-bs-toggle="modal" data-bs-target="#fullscreenModal"><i data-feather="maximize" class="me-1 le-icon-16"></i>Fullscreen Modal</button>
                </div>
                <div class="glass-card mt-3 le-bg-glass-subtle">
                    <div class="glass-card-body py-2 px-3">
                        <h6 class="d-flex align-items-center gap-2 mb-2 le-fs-base"><i data-feather="code" class="le-icon-14"></i> Usage</h6>
                        <pre class="mb-0 le-fs-base le-ws-pre-wrap"><code>&lt;!-- Trigger button --&gt;
&lt;button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#myModal"&gt;
  Open Modal
&lt;/button&gt;

&lt;!-- Modal structure --&gt;
&lt;div class="modal fade" id="myModal" tabindex="-1" aria-hidden="true"&gt;
  &lt;div class="modal-dialog"&gt;
    &lt;div class="modal-content"&gt;
      &lt;div class="modal-header"&gt;
        &lt;h5 class="modal-title"&gt;Modal Title&lt;/h5&gt;
        &lt;button type="button" class="btn-close" data-bs-dismiss="modal"&gt;&lt;/button&gt;
      &lt;/div&gt;
      &lt;div class="modal-body"&gt;Content here...&lt;/div&gt;
      &lt;div class="modal-footer"&gt;
        &lt;button class="btn btn-secondary" data-bs-dismiss="modal"&gt;Close&lt;/button&gt;
      &lt;/div&gt;
    &lt;/div&gt;
  &lt;/div&gt;
&lt;/div&gt;

&lt;!-- Glass variant: add .modal-glass to .modal --&gt;
&lt;div class="modal fade modal-glass" id="myGlassModal" tabindex="-1" aria-hidden="true"&gt;
  ...
&lt;/div&gt;</code></pre>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# ── 2. Glass Modals ── #}
    <div class="col-12">
        <div class="glass-card">
            <div class="glass-card-body">
                <h5 class="mb-1">Glass Modals</h5>
                <p class="text-muted mb-3 le-fs-body">Modals with the <code>.modal-glass</code> class for a frosted-glass appearance.</p>
                <div class="d-flex flex-wrap gap-2">
                    <button class="btn btn-glass btn-glass-primary" data-bs-toggle="modal" data-bs-target="#glassModal1"><i data-feather="layers" class="me-1 le-icon-16"></i>Glass Modal</button>
                    <button class="btn btn-glass btn-glass-danger" data-bs-toggle="modal" data-bs-target="#glassConfirmModal"><i data-feather="alert-triangle" class="me-1 le-icon-16"></i>Glass Confirm Dialog</button>
                    <button class="btn btn-glass btn-glass-success" data-bs-toggle="modal" data-bs-target="#glassFormModal"><i data-feather="edit-3" class="me-1 le-icon-16"></i>Glass Form Modal</button>
                </div>
            </div>
        </div>
    </div>

    {# ── 3. Modal Sizes ── #}
    <div class="col-12">
        <div class="glass-card">
            <div class="glass-card-body">
                <h5 class="mb-1">Modal Sizes</h5>
                <p class="text-muted mb-3 le-fs-body">Glass modals in all available Bootstrap sizes, from small to extra large.</p>
                <div class="d-flex flex-wrap gap-2">
                    <button class="btn btn-glass btn-glass-secondary" data-bs-toggle="modal" data-bs-target="#sizeSmModal"><i data-feather="minimize-2" class="me-1 le-icon-16"></i>Small Modal</button>
                    <button class="btn btn-glass btn-glass-secondary" data-bs-toggle="modal" data-bs-target="#sizeDefaultModal"><i data-feather="square" class="me-1 le-icon-16"></i>Default Modal</button>
                    <button class="btn btn-glass btn-glass-secondary" data-bs-toggle="modal" data-bs-target="#sizeLgModal"><i data-feather="maximize-2" class="me-1 le-icon-16"></i>Large Modal</button>
                    <button class="btn btn-glass btn-glass-secondary" data-bs-toggle="modal" data-bs-target="#sizeXlModal"><i data-feather="monitor" class="me-1 le-icon-16"></i>Extra Large Modal</button>
                </div>
            </div>
        </div>
    </div>

    {# ── 4. Offcanvas Panels ── #}
    <div class="col-12">
        <div class="glass-card">
            <div class="glass-card-body">
                <h5 class="mb-1">Offcanvas Panels</h5>
                <p class="text-muted mb-3 le-fs-body">Slide-in panels from all four directions. Each contains distinct sample content.</p>
                <div class="d-flex flex-wrap gap-2">
                    <button class="btn btn-glass btn-glass-primary" data-bs-toggle="offcanvas" data-bs-target="#offcanvasStart"><i data-feather="arrow-right" class="me-1 le-icon-16"></i>Offcanvas Start</button>
                    <button class="btn btn-glass btn-glass-primary" data-bs-toggle="offcanvas" data-bs-target="#offcanvasEnd"><i data-feather="arrow-left" class="me-1 le-icon-16"></i>Offcanvas End</button>
                    <button class="btn btn-glass btn-glass-primary" data-bs-toggle="offcanvas" data-bs-target="#offcanvasTop"><i data-feather="arrow-down" class="me-1 le-icon-16"></i>Offcanvas Top</button>
                    <button class="btn btn-glass btn-glass-primary" data-bs-toggle="offcanvas" data-bs-target="#offcanvasBottom"><i data-feather="arrow-up" class="me-1 le-icon-16"></i>Offcanvas Bottom</button>
                </div>
                <div class="glass-card mt-3 le-bg-glass-subtle">
                    <div class="glass-card-body py-2 px-3">
                        <h6 class="d-flex align-items-center gap-2 mb-2 le-fs-base"><i data-feather="code" class="le-icon-14"></i> Usage</h6>
                        <pre class="mb-0 le-fs-base le-ws-pre-wrap"><code>&lt;!-- Trigger button --&gt;
&lt;button class="btn btn-glass btn-glass-primary"
  data-bs-toggle="offcanvas" data-bs-target="#myOffcanvas"&gt;
  Open Panel
&lt;/button&gt;

&lt;!-- Offcanvas panel --&gt;
&lt;div class="offcanvas offcanvas-start" id="myOffcanvas" tabindex="-1"&gt;
  &lt;div class="offcanvas-header"&gt;
    &lt;h5 class="offcanvas-title"&gt;Panel Title&lt;/h5&gt;
    &lt;button type="button" class="btn-close" data-bs-dismiss="offcanvas"&gt;&lt;/button&gt;
  &lt;/div&gt;
  &lt;div class="offcanvas-body"&gt;Content here...&lt;/div&gt;
&lt;/div&gt;</code></pre>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# ── 5. Offcanvas Backdrop Options ── #}
    <div class="col-lg-6">
        <div class="glass-card">
            <div class="glass-card-body">
                <h5 class="mb-1">Offcanvas Backdrop Options</h5>
                <p class="text-muted mb-3 le-fs-body">Different backdrop and scroll behaviour configurations for offcanvas panels.</p>
                <div class="d-flex flex-wrap gap-2">
                    <button class="btn btn-glass btn-glass-secondary" data-bs-toggle="offcanvas" data-bs-target="#offcanvasBackdrop"><i data-feather="sidebar" class="me-1 le-icon-16"></i>With Backdrop</button>
                    <button class="btn btn-glass btn-glass-secondary" data-bs-toggle="offcanvas" data-bs-target="#offcanvasNoBackdrop"><i data-feather="eye-off" class="me-1 le-icon-16"></i>Without Backdrop</button>
                    <button class="btn btn-glass btn-glass-secondary" data-bs-toggle="offcanvas" data-bs-target="#offcanvasStaticBackdrop"><i data-feather="lock" class="me-1 le-icon-16"></i>Static Backdrop</button>
                    <button class="btn btn-glass btn-glass-secondary" data-bs-toggle="offcanvas" data-bs-target="#offcanvasScrollable"><i data-feather="mouse-pointer" class="me-1 le-icon-16"></i>Scrollable Body</button>
                </div>
            </div>
        </div>
    </div>

    {# ── 6. Practical Modal Examples ── #}
    <div class="col-12">
        <div class="glass-card">
            <div class="glass-card-body">
                <h5 class="mb-1">Practical Modal Examples</h5>
                <p class="text-muted mb-3 le-fs-body">Real-world modal patterns commonly used in admin dashboards.</p>
                <div class="d-flex flex-wrap gap-2">
                    <button class="btn btn-danger" data-bs-toggle="modal" data-bs-target="#deleteConfirmModal"><i data-feather="trash-2" class="me-1 le-icon-16"></i>Delete Confirmation</button>
                    <button class="btn btn-glass btn-glass-primary" data-bs-toggle="modal" data-bs-target="#imagePreviewModal"><i data-feather="image" class="me-1 le-icon-16"></i>Image Preview</button>
                    <button class="btn btn-glass btn-glass-secondary" data-bs-toggle="modal" data-bs-target="#termsModal"><i data-feather="file-text" class="me-1 le-icon-16"></i>Terms &amp; Conditions</button>
                </div>
            </div>
        </div>
    </div>

</div>

{# ═══════════════════════════════════════════════════════════════════════════
   MODAL DEFINITIONS
   ═══════════════════════════════════════════════════════════════════════════ #}

{# ── 1a. Default Modal ── #}
<div class="modal fade" id="defaultModal" tabindex="-1" aria-labelledby="defaultModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="defaultModalLabel">Default Modal</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>This is a standard Bootstrap 5 modal with default settings. It appears at the top of the viewport and can be dismissed by clicking the backdrop or the close button.</p>
                <p class="mb-0 text-muted le-fs-body">Use modals to display contextual information, confirmations, or lightweight forms without leaving the current page.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn btn-primary">Understood</button>
            </div>
        </div>
    </div>
</div>

{# ── 1b. Scrollable Modal (with form) ── #}
<div class="modal fade" id="scrollableModal" tabindex="-1" aria-labelledby="scrollableModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="scrollableModalLabel">Scrollable Modal — Feedback Form</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="text-muted mb-3 le-fs-body">This modal scrolls independently when the content overflows. It also demonstrates a form inside a modal.</p>
                <form>
                    <div class="mb-3">
                        <label class="form-label">Full Name</label>
                        <input type="text" class="form-control" placeholder="Jane Doe">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Email Address</label>
                        <input type="email" class="form-control" placeholder="jane@example.com">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Department</label>
                        <select class="form-select">
                            <option selected>Select department…</option>
                            <option>Engineering</option>
                            <option>Design</option>
                            <option>Marketing</option>
                            <option>Sales</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Feedback</label>
                        <textarea class="form-control" rows="4" placeholder="Share your thoughts…"></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Priority</label>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="priority" id="priorityLow">
                            <label class="form-check-label" for="priorityLow">Low</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="priority" id="priorityMedium" checked>
                            <label class="form-check-label" for="priorityMedium">Medium</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="priority" id="priorityHigh">
                            <label class="form-check-label" for="priorityHigh">High</label>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Additional Notes</label>
                        <textarea class="form-control" rows="6" placeholder="Any additional context or steps to reproduce the issue…"></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary">Submit Feedback</button>
            </div>
        </div>
    </div>
</div>

{# ── 1c. Centered Modal ── #}
<div class="modal fade" id="centeredModal" tabindex="-1" aria-labelledby="centeredModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="centeredModalLabel">Vertically Centered</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="text-center py-3">
                    <i data-feather="check-circle" class="mb-3 le-icon-48 le-text-success"></i>
                    <h5>Action Completed</h5>
                    <p class="text-muted mb-0">This modal is vertically centered in the viewport using <code>.modal-dialog-centered</code>. It is ideal for confirmations and status messages.</p>
                </div>
            </div>
            <div class="modal-footer justify-content-center">
                <button type="button" class="btn btn-primary" data-bs-dismiss="modal">Got it</button>
            </div>
        </div>
    </div>
</div>

{# ── 1d. Fullscreen Modal ── #}
<div class="modal fade" id="fullscreenModal" tabindex="-1" aria-labelledby="fullscreenModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-fullscreen">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="fullscreenModalLabel"><i data-feather="maximize" class="me-2 le-icon-18"></i>Fullscreen Modal</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="container py-4">
                    <div class="row g-4">
                        <div class="col-md-4">
                            <div class="glass-card">
                                <div class="glass-card-body text-center py-4">
                                    <i data-feather="users" class="mb-2 le-icon-32 le-text-primary"></i>
                                    <h6>Users</h6>
                                    <h3 class="mb-0">2,847</h3>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="glass-card">
                                <div class="glass-card-body text-center py-4">
                                    <i data-feather="shopping-cart" class="mb-2 le-icon-32 le-text-success"></i>
                                    <h6>Orders</h6>
                                    <h3 class="mb-0">1,203</h3>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="glass-card">
                                <div class="glass-card-body text-center py-4">
                                    <i data-feather="dollar-sign" class="mb-2 le-icon-32 le-text-warning"></i>
                                    <h6>Revenue</h6>
                                    <h3 class="mb-0">$54,200</h3>
                                </div>
                            </div>
                        </div>
                    </div>
                    <p class="text-muted mt-4">Fullscreen modals take over the entire viewport and are useful for immersive experiences such as dashboards, wizards, or rich media previews. Use <code>.modal-fullscreen</code> on the dialog element.</p>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close Fullscreen</button>
            </div>
        </div>
    </div>
</div>

{# ── 2a. Glass Modal ── #}
<div class="modal fade modal-glass" id="glassModal1" tabindex="-1" aria-labelledby="glassModal1Label" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="glassModal1Label"><i data-feather="layers" class="me-2 le-icon-18"></i>Glass Modal</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>This modal uses the <code>.modal-glass</code> class to apply frosted-glass styling to the dialog. The content area inherits translucent backgrounds, soft borders, and backdrop blur effects.</p>
                <div class="glass-card">
                    <div class="glass-card-body">
                        <div class="d-flex align-items-center gap-3">
                            <i data-feather="info" class="le-icon-20 le-text-primary"></i>
                            <span class="text-muted le-fs-body">Glass cards can be nested inside glass modals for layered depth effects.</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-glass btn-glass-secondary" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn btn-glass btn-glass-primary">Save Changes</button>
            </div>
        </div>
    </div>
</div>

{# ── 2b. Glass Confirm Dialog ── #}
<div class="modal fade modal-glass" id="glassConfirmModal" tabindex="-1" aria-labelledby="glassConfirmModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content">
            <div class="modal-body text-center py-4">
                <div class="mb-3">
                    <i data-feather="alert-triangle" class="le-icon-48 le-text-warning"></i>
                </div>
                <h5 class="mb-2">Are you sure?</h5>
                <p class="text-muted mb-0 le-fs-body">This action cannot be undone. All associated data will be permanently removed from our servers.</p>
            </div>
            <div class="modal-footer justify-content-center">
                <button type="button" class="btn btn-glass btn-glass-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-glass btn-glass-danger">Confirm</button>
            </div>
        </div>
    </div>
</div>

{# ── 2c. Glass Form Modal ── #}
<div class="modal fade modal-glass" id="glassFormModal" tabindex="-1" aria-labelledby="glassFormModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="glassFormModalLabel"><i data-feather="user-plus" class="me-2 le-icon-18"></i>Create Account</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form>
                    <div class="mb-3">
                        <label class="form-label">Username</label>
                        <input type="text" class="glass-input" placeholder="Choose a username">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input type="email" class="glass-input" placeholder="you@example.com">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Password</label>
                        <input type="password" class="glass-input" placeholder="Min. 8 characters">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Role</label>
                        <select class="glass-select">
                            <option selected>Select role…</option>
                            <option>Administrator</option>
                            <option>Editor</option>
                            <option>Viewer</option>
                        </select>
                    </div>
                    <div class="form-check mb-0">
                        <input class="form-check-input" type="checkbox" id="agreeTerms">
                        <label class="form-check-label le-fs-body" for="agreeTerms">I agree to the terms and conditions</label>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-glass btn-glass-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-glass btn-glass-success">Create Account</button>
            </div>
        </div>
    </div>
</div>

{# ── 3a. Small Modal ── #}
<div class="modal fade modal-glass" id="sizeSmModal" tabindex="-1" aria-labelledby="sizeSmModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="sizeSmModalLabel">Small Modal</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="mb-0">This is a small glass modal using <code>.modal-sm</code>. Maximum width is 300px.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-glass btn-glass-primary btn-sm" data-bs-dismiss="modal">OK</button>
            </div>
        </div>
    </div>
</div>

{# ── 3b. Default Size Modal ── #}
<div class="modal fade modal-glass" id="sizeDefaultModal" tabindex="-1" aria-labelledby="sizeDefaultModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="sizeDefaultModalLabel">Default Modal</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="mb-0">This glass modal uses the default Bootstrap size. Maximum width is 500px. Suitable for most dialogs and forms.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-glass btn-glass-secondary" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn btn-glass btn-glass-primary">Save</button>
            </div>
        </div>
    </div>
</div>

{# ── 3c. Large Modal ── #}
<div class="modal fade modal-glass" id="sizeLgModal" tabindex="-1" aria-labelledby="sizeLgModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="sizeLgModalLabel">Large Modal</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>This glass modal uses <code>.modal-lg</code> for a maximum width of 800px. Ideal for data tables, detailed forms, or content that requires more horizontal space.</p>
                <div class="row g-3">
                    <div class="col-sm-6">
                        <div class="glass-card">
                            <div class="glass-card-body text-center">
                                <i data-feather="bar-chart-2" class="mb-2 le-icon-24 le-text-primary"></i>
                                <h6 class="mb-0">Analytics</h6>
                            </div>
                        </div>
                    </div>
                    <div class="col-sm-6">
                        <div class="glass-card">
                            <div class="glass-card-body text-center">
                                <i data-feather="pie-chart" class="le-icon-24 le-text-secondary mb-2"></i>
