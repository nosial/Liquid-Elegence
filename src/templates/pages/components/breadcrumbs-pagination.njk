{% set root = "../../" %}
{% extends "layouts/dashboard.njk" %}

{% block title %}Breadcrumbs &amp; Pagination — Liquid Elegance{% endblock %}

{% block breadcrumb %}
<li class="breadcrumb-item"><a href="javascript:void(0)">Components</a></li>
<li class="breadcrumb-item active">Breadcrumbs &amp; Pagination</li>
{% endblock %}


{% block content %}

{# ── Basic Breadcrumbs ───────────────────────────────────────────────── #}
<div class="row g-4 mb-4">
    <div class="col-12">
        <div class="glass-card">
            <div class="glass-card-body">
                <h5 class="mb-1">Breadcrumbs</h5>
                <p class="text-muted mb-3 le-fs-body">Indicate the current page's location within a navigational hierarchy.</p>
                <nav class="mb-3"><ol class="breadcrumb"><li class="breadcrumb-item active">Home</li></ol></nav>
                <nav class="mb-3"><ol class="breadcrumb"><li class="breadcrumb-item"><a href="javascript:void(0)">Home</a></li><li class="breadcrumb-item active">Dashboard</li></ol></nav>
                <nav class="mb-3"><ol class="breadcrumb"><li class="breadcrumb-item"><a href="javascript:void(0)">Home</a></li><li class="breadcrumb-item"><a href="javascript:void(0)">Pages</a></li><li class="breadcrumb-item active">Current Page</li></ol></nav>
                <nav class="mb-0"><ol class="breadcrumb"><li class="breadcrumb-item"><a href="javascript:void(0)">App</a></li><li class="breadcrumb-item"><a href="javascript:void(0)">Settings</a></li><li class="breadcrumb-item"><a href="javascript:void(0)">Account</a></li><li class="breadcrumb-item active">Security</li></ol></nav>
                <div class="glass-card mt-3 le-bg-glass-subtle">
                    <div class="glass-card-body py-2 px-3">
                        <h6 class="d-flex align-items-center gap-2 mb-2 le-fs-base"><i data-feather="code" class="le-icon-14"></i> Usage</h6>
                        <pre class="mb-0 le-fs-base le-ws-pre-wrap"><code>&lt;nav aria-label="breadcrumb"&gt;
    &lt;ol class="breadcrumb"&gt;
        &lt;li class="breadcrumb-item"&gt;
            &lt;a href="javascript:void(0)"&gt;Home&lt;/a&gt;
        &lt;/li&gt;
        &lt;li class="breadcrumb-item"&gt;
            &lt;a href="javascript:void(0)"&gt;Pages&lt;/a&gt;
        &lt;/li&gt;
        &lt;li class="breadcrumb-item active"
            aria-current="page"&gt;Current&lt;/li&gt;
    &lt;/ol&gt;
&lt;/nav&gt;</code></pre>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

{# ── Breadcrumb with Icons ───────────────────────────────────────────── #}
<div class="row g-4 mb-4">
    <div class="col-lg-6">
        <div class="glass-card">
            <div class="glass-card-body">
                <h5 class="mb-1">Breadcrumbs with Icons</h5>
                <p class="text-muted mb-3 le-fs-body">Add icons for richer visual context.</p>
                <nav class="mb-3">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="javascript:void(0)"><i data-feather="home" class="le-icon-14 le-icon-mr-4"></i>Home</a></li>
                        <li class="breadcrumb-item"><a href="javascript:void(0)"><i data-feather="settings" class="le-icon-14 le-icon-mr-4"></i>Settings</a></li>
                        <li class="breadcrumb-item active"><i data-feather="user" class="le-icon-14 le-icon-mr-4"></i>Profile</li>
                    </ol>
                </nav>
                <nav class="mb-0">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="javascript:void(0)"><i data-feather="shopping-bag" class="le-icon-14 le-icon-mr-4"></i>Shop</a></li>
                        <li class="breadcrumb-item"><a href="javascript:void(0)">Electronics</a></li>
                        <li class="breadcrumb-item"><a href="javascript:void(0)">Phones</a></li>
                        <li class="breadcrumb-item active">iPhone 15</li>
                    </ol>
                </nav>
            </div>
        </div>
    </div>

    {# ── Custom Separators ───────────────────────────────────────────── #}
    <div class="col-lg-6">
        <div class="glass-card">
            <div class="glass-card-body">
                <h5 class="mb-1">Custom Separators</h5>
                <p class="text-muted mb-3 le-fs-body">Breadcrumb separators can be changed via CSS variables.</p>
                <nav class="mb-3" style="--bs-breadcrumb-divider: '>';">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="javascript:void(0)">Home</a></li>
                        <li class="breadcrumb-item"><a href="javascript:void(0)">Library</a></li>
                        <li class="breadcrumb-item active">Data</li>
                    </ol>
                </nav>
                <nav class="mb-3" style="--bs-breadcrumb-divider: '→';">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="javascript:void(0)">Home</a></li>
                        <li class="breadcrumb-item"><a href="javascript:void(0)">Products</a></li>
                        <li class="breadcrumb-item active">Details</li>
                    </ol>
                </nav>
                <nav class="mb-0" style="--bs-breadcrumb-divider: '•';">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="javascript:void(0)">Home</a></li>
                        <li class="breadcrumb-item"><a href="javascript:void(0)">Account</a></li>
                        <li class="breadcrumb-item active">Security</li>
                    </ol>
                </nav>
                <div class="glass-card mt-3 le-bg-glass-subtle">
                    <div class="glass-card-body py-2 px-3">
                        <h6 class="d-flex align-items-center gap-2 mb-2 le-fs-base"><i data-feather="code" class="le-icon-14"></i> Usage</h6>
                        <pre class="mb-0 le-fs-base le-ws-pre-wrap"><code>&lt;!-- Custom separator via CSS variable --&gt;
&lt;nav style="--bs-breadcrumb-divider: '→';"&gt;
    &lt;ol class="breadcrumb"&gt;
        &lt;li class="breadcrumb-item"&gt;&lt;a href="javascript:void(0)"&gt;Home&lt;/a&gt;&lt;/li&gt;
        &lt;li class="breadcrumb-item active"&gt;Current&lt;/li&gt;
    &lt;/ol&gt;
&lt;/nav&gt;</code></pre>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

{# ── Basic Pagination ───────────────────────────────────────────────── #}
<div class="row g-4 mb-4">
    <div class="col-12">
        <div class="glass-card">
            <div class="glass-card-body">
                <h5 class="mb-1">Pagination</h5>
                <p class="text-muted mb-3 le-fs-body">Standard pagination with active, disabled, and navigation states.</p>
                <nav>
                    <ul class="pagination mb-3">
                        <li class="page-item disabled"><a class="page-link" href="javascript:void(0)">&laquo; Previous</a></li>
                        <li class="page-item active"><a class="page-link" href="javascript:void(0)">1</a></li>
                        <li class="page-item"><a class="page-link" href="javascript:void(0)">2</a></li>
                        <li class="page-item"><a class="page-link" href="javascript:void(0)">3</a></li>
                        <li class="page-item"><a class="page-link" href="javascript:void(0)">4</a></li>
                        <li class="page-item"><a class="page-link" href="javascript:void(0)">5</a></li>
                        <li class="page-item"><a class="page-link" href="javascript:void(0)">Next &raquo;</a></li>
                    </ul>
                </nav>
                <nav>
                    <ul class="pagination mb-0">
                        <li class="page-item"><a class="page-link" href="javascript:void(0)">&laquo;</a></li>
                        <li class="page-item"><a class="page-link" href="javascript:void(0)">1</a></li>
                        <li class="page-item"><a class="page-link" href="javascript:void(0)">2</a></li>
                        <li class="page-item active"><a class="page-link" href="javascript:void(0)">3</a></li>
                        <li class="page-item"><a class="page-link" href="javascript:void(0)">4</a></li>
                        <li class="page-item"><a class="page-link" href="javascript:void(0)">5</a></li>
                        <li class="page-item"><a class="page-link" href="javascript:void(0)">&raquo;</a></li>
                    </ul>
                </nav>
                <div class="glass-card mt-3 le-bg-glass-subtle">
                    <div class="glass-card-body py-2 px-3">
                        <h6 class="d-flex align-items-center gap-2 mb-2 le-fs-base"><i data-feather="code" class="le-icon-14"></i> Usage</h6>
                        <pre class="mb-0 le-fs-base le-ws-pre-wrap"><code>&lt;nav aria-label="Page navigation"&gt;
    &lt;ul class="pagination"&gt;
        &lt;li class="page-item disabled"&gt;
            &lt;a class="page-link" href="javascript:void(0)"&gt;&amp;laquo;&lt;/a&gt;
        &lt;/li&gt;
        &lt;li class="page-item active"&gt;
            &lt;a class="page-link" href="javascript:void(0)"&gt;1&lt;/a&gt;
        &lt;/li&gt;
        &lt;li class="page-item"&gt;
            &lt;a class="page-link" href="javascript:void(0)"&gt;2&lt;/a&gt;
        &lt;/li&gt;
        &lt;li class="page-item"&gt;
            &lt;a class="page-link" href="javascript:void(0)"&gt;&amp;raquo;&lt;/a&gt;
        &lt;/li&gt;
    &lt;/ul&gt;
&lt;/nav&gt;</code></pre>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

{# ── Pagination Sizes ───────────────────────────────────────────────── #}
<div class="row g-4 mb-4">
    <div class="col-lg-6">
        <div class="glass-card">
            <div class="glass-card-body">
                <h5 class="mb-1">Pagination Sizes</h5>
                <p class="text-muted mb-3 le-fs-body">Large, default, and small pagination sizes.</p>
                <h6 class="mb-2 le-fs-body">Large</h6>
                <nav>
                    <ul class="pagination pagination-lg mb-3">
                        <li class="page-item"><a class="page-link" href="javascript:void(0)">&laquo;</a></li>
                        <li class="page-item active"><a class="page-link" href="javascript:void(0)">1</a></li>
                        <li class="page-item"><a class="page-link" href="javascript:void(0)">2</a></li>
                        <li class="page-item"><a class="page-link" href="javascript:void(0)">3</a></li>
                        <li class="page-item"><a class="page-link" href="javascript:void(0)">&raquo;</a></li>
                    </ul>
                </nav>
                <h6 class="mb-2 le-fs-body">Small</h6>
                <nav>
                    <ul class="pagination pagination-sm mb-0">
                        <li class="page-item"><a class="page-link" href="javascript:void(0)">&laquo;</a></li>
                        <li class="page-item"><a class="page-link" href="javascript:void(0)">1</a></li>
                        <li class="page-item active"><a class="page-link" href="javascript:void(0)">2</a></li>
                        <li class="page-item"><a class="page-link" href="javascript:void(0)">3</a></li>
                        <li class="page-item"><a class="page-link" href="javascript:void(0)">4</a></li>
                        <li class="page-item"><a class="page-link" href="javascript:void(0)">5</a></li>
                        <li class="page-item"><a class="page-link" href="javascript:void(0)">&raquo;</a></li>
                    </ul>
                </nav>
                <div class="glass-card mt-3 le-bg-glass-subtle">
                    <div class="glass-card-body py-2 px-3">
                        <h6 class="d-flex align-items-center gap-2 mb-2 le-fs-base"><i data-feather="code" class="le-icon-14"></i> Usage</h6>
                        <pre class="mb-0 le-fs-base le-ws-pre-wrap"><code>&lt;ul class="pagination pagination-lg"&gt;…&lt;/ul&gt;
&lt;ul class="pagination pagination-sm"&gt;…&lt;/ul&gt;</code></pre>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# ── Pagination Alignment ────────────────────────────────────────── #}
    <div class="col-lg-6">
        <div class="glass-card">
            <div class="glass-card-body">
                <h5 class="mb-1">Pagination Alignment</h5>
                <p class="text-muted mb-3 le-fs-body">Control pagination alignment with flexbox utilities.</p>
                <h6 class="mb-2 le-fs-body">Start (default)</h6>
                <nav>
                    <ul class="pagination mb-3">
                        <li class="page-item"><a class="page-link" href="javascript:void(0)">&laquo;</a></li>
                        <li class="page-item active"><a class="page-link" href="javascript:void(0)">1</a></li>
                        <li class="page-item"><a class="page-link" href="javascript:void(0)">2</a></li>
                        <li class="page-item"><a class="page-link" href="javascript:void(0)">&raquo;</a></li>
                    </ul>
                </nav>
                <h6 class="mb-2 le-fs-body">Centre</h6>
                <nav>
                    <ul class="pagination justify-content-center mb-3">
                        <li class="page-item"><a class="page-link" href="javascript:void(0)">&laquo;</a></li>
                        <li class="page-item active"><a class="page-link" href="javascript:void(0)">1</a></li>
                        <li class="page-item"><a class="page-link" href="javascript:void(0)">2</a></li>
                        <li class="page-item"><a class="page-link" href="javascript:void(0)">&raquo;</a></li>
                    </ul>
                </nav>
                <h6 class="mb-2 le-fs-body">End</h6>
