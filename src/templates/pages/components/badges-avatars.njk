                    <div class="avatar avatar-lg"><div class="avatar-placeholder">JD</div></div>
                    <div class="avatar avatar-lg"><div class="avatar-placeholder">AK</div></div>
                    <div class="avatar avatar-lg"><div class="avatar-placeholder">MR</div></div>
                    <div class="avatar avatar-lg"><div class="avatar-placeholder">+2</div></div>
                </div>
            </div>
        </div>
    </div>
</div>


