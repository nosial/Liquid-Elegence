                    <div class="avatar avatar-sm"><div class="avatar-placeholder">D</div></div>
                    <div class="avatar avatar-sm"><div class="avatar-placeholder">+5</div></div>
                </div>

                <h6 class="mb-2">Default</h6>
                <div class="avatar-group mb-4">
                    <div class="avatar"><div class="avatar-placeholder">JD</div></div>
                    <div class="avatar"><div class="avatar-placeholder">AK</div></div>
                    <div class="avatar"><div class="avatar-placeholder">MR</div></div>
                    <div class="avatar"><div class="avatar-placeholder">TW</div></div>
                    <div class="avatar"><div class="avatar-placeholder">+3</div></div>
                </div>

                <h6 class="mb-2">Large</h6>
