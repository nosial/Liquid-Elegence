</div>


{# ── Avatar Groups ────────────────────────────────────────────────────── #}
<div class="row g-4 mb-4">
    <div class="col-12">
        <div class="glass-card">
            <div class="glass-card-body">
                <h5 class="mb-1">Avatar Groups</h5>
                <p class="text-muted mb-3 le-fs-body">Overlapping avatar stacks using <code>.avatar-group</code> in multiple sizes.</p>

                <h6 class="mb-2">Small</h6>
                <div class="avatar-group mb-4">
                    <div class="avatar avatar-sm"><div class="avatar-placeholder">A</div></div>
                    <div class="avatar avatar-sm"><div class="avatar-placeholder">B</div></div>
