{% set root = "../../" %}
{% extends "layouts/dashboard.njk" %}

{% block title %}UI Elements — Liquid Elegance{% endblock %}

{% block breadcrumb %}
<li class="breadcrumb-item"><a href="javascript:void(0)">Components</a></li>
<li class="breadcrumb-item active">UI Elements</li>
{% endblock %}


{% block content %}

{# ── Buttons ─────────────────────────────────────────────────────────── #}
<div class="row g-4 mb-4">
    <div class="col-12">
        <div class="glass-card">
            <div class="glass-card-body">
                <h5 class="mb-1">Glass Buttons</h5>
                <p class="text-muted mb-3 le-fs-body">Primary glass button styles with backdrop-filter and hover effects.</p>
                <div class="d-flex flex-wrap gap-3 mb-4">
                    <button class="btn btn-glass btn-glass-primary">Primary</button>
                    <button class="btn btn-glass btn-glass-secondary">Secondary</button>
                    <button class="btn btn-glass btn-glass-success">Success</button>
                    <button class="btn btn-glass btn-glass-danger">Danger</button>
                    <button class="btn btn-glass btn-glass-warning">Warning</button>
                    <button class="btn btn-glass btn-glass-info">Info</button>
                </div>

                <h6 class="mb-2">Sizes</h6>
                <div class="d-flex flex-wrap gap-3 align-items-center mb-4">
                    <button class="btn btn-glass btn-glass-primary btn-sm">Small</button>
                    <button class="btn btn-glass btn-glass-primary">Default</button>
                    <button class="btn btn-glass btn-glass-primary btn-lg">Large</button>
                </div>

                <h6 class="mb-2">Outline Buttons</h6>
                <div class="d-flex flex-wrap gap-3 mb-4">
                    <button class="btn btn-outline-primary">Primary</button>
                    <button class="btn btn-outline-secondary">Secondary</button>
                    <button class="btn btn-outline-success">Success</button>
                    <button class="btn btn-outline-danger">Danger</button>
                    <button class="btn btn-outline-warning">Warning</button>
                    <button class="btn btn-outline-info">Info</button>
                </div>

                <h6 class="mb-2">Bootstrap Solid Buttons</h6>
                <div class="d-flex flex-wrap gap-3 mb-4">
                    <button class="btn btn-primary">Primary</button>
                    <button class="btn btn-secondary">Secondary</button>
                    <button class="btn btn-success">Success</button>
                    <button class="btn btn-danger">Danger</button>
                    <button class="btn btn-warning">Warning</button>
                    <button class="btn btn-info">Info</button>
                    <button class="btn btn-light">Light</button>
                    <button class="btn btn-dark">Dark</button>
                </div>

                <h6 class="mb-2">Button States</h6>
                <div class="d-flex flex-wrap gap-3">
                    <button class="btn btn-glass btn-glass-primary">Normal</button>
                    <button class="btn btn-glass btn-glass-primary active">Active</button>
                    <button class="btn btn-glass btn-glass-primary" disabled>Disabled</button>
                    <button class="btn btn-glass btn-glass-primary">
                        <span class="spinner-border spinner-border-sm me-2" role="status"></span>Loading...
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

{# ── Badges ──────────────────────────────────────────────────────────── #}
<div class="row g-4 mb-4">
    <div class="col-lg-6">
        <div class="glass-card">
            <div class="glass-card-body">
                <h5 class="mb-3">Badges</h5>
                <h6 class="mb-2">Glass Badges</h6>
                <div class="d-flex flex-wrap gap-2 mb-3">
                    <span class="glass-badge">Default</span>
                    <span class="glass-badge glass-badge-primary">Primary</span>
                    <span class="glass-badge glass-badge-success">Success</span>
                    <span class="glass-badge glass-badge-danger">Danger</span>
                    <span class="glass-badge glass-badge-warning">Warning</span>
                    <span class="glass-badge glass-badge-info">Info</span>
                </div>

                <h6 class="mb-2">Status Badges</h6>
                <div class="d-flex flex-wrap gap-2 mb-3">
                    <span class="badge badge-status bg-success">Active</span>
                    <span class="badge badge-status bg-warning">Pending</span>
                    <span class="badge badge-status bg-danger">Declined</span>
                    <span class="badge badge-status bg-info">Processing</span>
                    <span class="badge badge-status bg-secondary">Draft</span>
                    <span class="badge badge-status bg-primary">New</span>
                </div>

                <h6 class="mb-2">Bootstrap Badges</h6>
                <div class="d-flex flex-wrap gap-2 mb-3">
                    <span class="badge bg-primary">Primary</span>
                    <span class="badge bg-secondary">Secondary</span>
                    <span class="badge bg-success">Success</span>
                    <span class="badge bg-danger">Danger</span>
                    <span class="badge bg-warning text-dark">Warning</span>
                    <span class="badge bg-info">Info</span>
                </div>

                <h6 class="mb-2">Rounded Pill Badges</h6>
                <div class="d-flex flex-wrap gap-2">
                    <span class="badge rounded-pill bg-primary">1</span>
                    <span class="badge rounded-pill bg-success">24</span>
                    <span class="badge rounded-pill bg-danger">99+</span>
                    <span class="badge rounded-pill bg-warning text-dark">New</span>
                </div>
            </div>
        </div>
    </div>

    {# ── Avatars ─────────────────────────────────────────────────────── #}
    <div class="col-lg-6">
        <div class="glass-card">
            <div class="glass-card-body">
                <h5 class="mb-3">Avatars</h5>
                <h6 class="mb-2">Sizes</h6>
                <div class="d-flex flex-wrap gap-3 align-items-center mb-4">
                    <div class="avatar avatar-xs"><div class="avatar-placeholder">XS</div></div>
                    <div class="avatar avatar-sm"><div class="avatar-placeholder">SM</div></div>
                    <div class="avatar"><div class="avatar-placeholder">MD</div></div>
                    <div class="avatar avatar-lg"><div class="avatar-placeholder">LG</div></div>
                    <div class="avatar avatar-xl"><div class="avatar-placeholder">XL</div></div>
                </div>

                <h6 class="mb-2">With Status Indicators</h6>
                <div class="d-flex flex-wrap gap-3 align-items-center mb-4">
                    <div class="avatar position-relative">
                        <div class="avatar-placeholder">JD</div>
                        <span class="status-dot online"></span>
                    </div>
                    <div class="avatar position-relative">
                        <div class="avatar-placeholder">AK</div>
                        <span class="status-dot away"></span>
                    </div>
                    <div class="avatar position-relative">
                        <div class="avatar-placeholder">BM</div>
                        <span class="status-dot busy"></span>
                    </div>
                    <div class="avatar position-relative">
                        <div class="avatar-placeholder">CL</div>
                        <span class="status-dot offline"></span>
                    </div>
                </div>

                <h6 class="mb-2">Avatar Group (stacked)</h6>
                <div class="d-flex ms-2">
                    <div class="avatar avatar-sm le-avatar-stacked"><div class="avatar-placeholder">A</div></div>
                    <div class="avatar avatar-sm le-avatar-stacked"><div class="avatar-placeholder">B</div></div>
                    <div class="avatar avatar-sm le-avatar-stacked"><div class="avatar-placeholder">C</div></div>
                    <div class="avatar avatar-sm le-avatar-stacked"><div class="avatar-placeholder">D</div></div>
                    <div class="avatar avatar-sm le-avatar-stacked"><div class="avatar-placeholder">+3</div></div>
                </div>
            </div>
        </div>
    </div>
</div>

{# ── Alerts ──────────────────────────────────────────────────────────── #}
<div class="row g-4 mb-4">
    <div class="col-12">
        <div class="glass-card">
            <div class="glass-card-body">
                <h5 class="mb-3">Alerts</h5>
                <div class="alert alert-primary d-flex align-items-center" role="alert">
                    <i data-feather="info" class="me-2 flex-shrink-0 le-icon-18"></i>
                    <div>A simple primary alert with an icon — check it out!</div>
                </div>
                <div class="alert alert-success d-flex align-items-center" role="alert">
                    <i data-feather="check-circle" class="me-2 flex-shrink-0 le-icon-18"></i>
                    <div>Well done! Operation completed successfully.</div>
                </div>
                <div class="alert alert-warning d-flex align-items-center" role="alert">
                    <i data-feather="alert-triangle" class="me-2 flex-shrink-0 le-icon-18"></i>
                    <div>Warning: Please review the changes before proceeding.</div>
                </div>
                <div class="alert alert-danger d-flex align-items-center" role="alert">
                    <i data-feather="alert-circle" class="me-2 flex-shrink-0 le-icon-18"></i>
                    <div>Error! Something went wrong. Please try again later.</div>
                </div>
                <div class="alert alert-info d-flex align-items-center" role="alert">
                    <i data-feather="info" class="me-2 flex-shrink-0 le-icon-18"></i>
                    <div>This is an informational alert for your reference.</div>
                </div>
                <div class="alert alert-primary alert-dismissible fade show" role="alert">
                    <strong>Dismissible!</strong> Click the X to dismiss this alert.
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            </div>
        </div>
    </div>
</div>

{# ── Progress ────────────────────────────────────────────────────────── #}
<div class="row g-4 mb-4">
    <div class="col-lg-6">
        <div class="glass-card">
            <div class="glass-card-body">
                <h5 class="mb-3">Progress Bars</h5>
                <div class="mb-3">
                    <small class="text-muted d-block mb-1">Default (25%)</small>
                    <div class="progress le-h-8">
                        <div class="progress-bar" role="progressbar" style="width: 25%"></div>
                    </div>
                </div>
                <div class="mb-3">
                    <small class="text-muted d-block mb-1">Success (50%)</small>
                    <div class="progress le-h-8">
                        <div class="progress-bar bg-success" role="progressbar" style="width: 50%"></div>
                    </div>
                </div>
                <div class="mb-3">
                    <small class="text-muted d-block mb-1">Warning (75%)</small>
                    <div class="progress le-h-8">
                        <div class="progress-bar bg-warning" role="progressbar" style="width: 75%"></div>
                    </div>
                </div>
                <div class="mb-3">
                    <small class="text-muted d-block mb-1">Danger (90%)</small>
                    <div class="progress le-h-8">
                        <div class="progress-bar bg-danger" role="progressbar" style="width: 90%"></div>
                    </div>
                </div>
                <div class="mb-3">
                    <small class="text-muted d-block mb-1">Striped & Animated</small>
                    <div class="progress le-h-10">
                        <div class="progress-bar progress-bar-striped progress-bar-animated" role="progressbar" style="width: 65%"></div>
                    </div>
                </div>
                <div class="mb-0">
                    <small class="text-muted d-block mb-1">Multi-segment (Stacked)</small>
                    <div class="progress le-h-10">
                        <div class="progress-bar bg-primary" role="progressbar" style="width: 30%"></div>
                        <div class="progress-bar bg-success" role="progressbar" style="width: 20%"></div>
                        <div class="progress-bar bg-warning" role="progressbar" style="width: 15%"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-12">
        <div class="glass-card mt-3 le-bg-glass-subtle">
            <div class="glass-card-body py-2 px-3">
                <h6 class="d-flex align-items-center gap-2 mb-2 le-fs-base"><i data-feather="code" class="le-icon-14"></i> Usage</h6>
                <pre class="mb-0 le-fs-base le-ws-pre-wrap"><code>&lt;div class="progress"&gt;
    &lt;div class="progress-bar" style="width:75%"&gt;75%&lt;/div&gt;
&lt;/div&gt;

&lt;!-- Striped animated --&gt;
&lt;div class="progress"&gt;
    &lt;div class="progress-bar progress-bar-striped
         progress-bar-animated bg-success"
         style="width:50%"&gt;&lt;/div&gt;
&lt;/div&gt;</code></pre>
            </div>
        </div>
    </div>

    {# ── Spinners ────────────────────────────────────────────────────── #}
    <div class="col-lg-6">
        <div class="glass-card">
            <div class="glass-card-body">
                <h5 class="mb-3">Spinners</h5>
                <h6 class="mb-2">Border Spinners</h6>
                <div class="d-flex flex-wrap gap-3 align-items-center mb-4">
                    <div class="spinner-border text-primary" role="status"><span class="visually-hidden">Loading...</span></div>
                    <div class="spinner-border text-success" role="status"><span class="visually-hidden">Loading...</span></div>
                    <div class="spinner-border text-danger" role="status"><span class="visually-hidden">Loading...</span></div>
                    <div class="spinner-border text-warning" role="status"><span class="visually-hidden">Loading...</span></div>
                    <div class="spinner-border text-info" role="status"><span class="visually-hidden">Loading...</span></div>
                </div>

                <h6 class="mb-2">Growing Spinners</h6>
                <div class="d-flex flex-wrap gap-3 align-items-center mb-4">
                    <div class="spinner-grow text-primary" role="status"><span class="visually-hidden">Loading...</span></div>
                    <div class="spinner-grow text-success" role="status"><span class="visually-hidden">Loading...</span></div>
                    <div class="spinner-grow text-danger" role="status"><span class="visually-hidden">Loading...</span></div>
                    <div class="spinner-grow text-warning" role="status"><span class="visually-hidden">Loading...</span></div>
                </div>

                <h6 class="mb-2">Sizes</h6>
                <div class="d-flex flex-wrap gap-3 align-items-center">
                    <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
                    <div class="spinner-border text-primary" role="status"></div>
                    <div class="spinner-border text-primary le-box-3r" role="status"></div>
                </div>
            </div>
        </div>
    </div>
</div>

{# ── Tooltips & Popovers ────────────────────────────────────────────── #}
<div class="row g-4 mb-4">
    <div class="col-lg-6">
        <div class="glass-card">
            <div class="glass-card-body">
                <h5 class="mb-3">Tooltips</h5>
                <div class="d-flex flex-wrap gap-3">
                    <button class="btn btn-glass btn-glass-primary" data-bs-toggle="tooltip" data-bs-placement="top" title="Tooltip on top">Top</button>
                    <button class="btn btn-glass btn-glass-secondary" data-bs-toggle="tooltip" data-bs-placement="right" title="Tooltip on right">Right</button>
                    <button class="btn btn-glass btn-glass-success" data-bs-toggle="tooltip" data-bs-placement="bottom" title="Tooltip on bottom">Bottom</button>
                    <button class="btn btn-glass btn-glass-warning" data-bs-toggle="tooltip" data-bs-placement="left" title="Tooltip on left">Left</button>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="glass-card">
            <div class="glass-card-body">
                <h5 class="mb-3">Popovers</h5>
                <div class="d-flex flex-wrap gap-3">
                    <button class="btn btn-glass btn-glass-primary" data-bs-toggle="popover" data-bs-placement="top" title="Popover Title" data-bs-content="This is the popover content for the top placement.">Top</button>
                    <button class="btn btn-glass btn-glass-danger" data-bs-toggle="popover" data-bs-placement="bottom" title="Bottom Popover" data-bs-content="Content goes here with glass styling.">Bottom</button>
                    <button class="btn btn-glass btn-glass-info" data-bs-toggle="popover" data-bs-placement="right" title="Side Popover" data-bs-content="Popovers support rich text and positioning.">Right</button>
                </div>
            </div>
        </div>
    </div>
</div>

{# ── Breadcrumbs & Pagination ────────────────────────────────────────── #}
<div class="row g-4 mb-4">
    <div class="col-lg-6">
        <div class="glass-card">
            <div class="glass-card-body">
                <h5 class="mb-3">Breadcrumbs</h5>
                <nav><ol class="breadcrumb"><li class="breadcrumb-item"><a href="javascript:void(0)">Home</a></li><li class="breadcrumb-item active">Dashboard</li></ol></nav>
                <nav><ol class="breadcrumb"><li class="breadcrumb-item"><a href="javascript:void(0)">Home</a></li><li class="breadcrumb-item"><a href="javascript:void(0)">Pages</a></li><li class="breadcrumb-item active">Current</li></ol></nav>
                <nav><ol class="breadcrumb mb-0"><li class="breadcrumb-item"><a href="javascript:void(0)">App</a></li><li class="breadcrumb-item"><a href="javascript:void(0)">Settings</a></li><li class="breadcrumb-item"><a href="javascript:void(0)">Account</a></li><li class="breadcrumb-item active">Security</li></ol></nav>
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="glass-card">
            <div class="glass-card-body">
                <h5 class="mb-3">Pagination</h5>
                <nav>
                    <ul class="pagination mb-3">
                        <li class="page-item disabled"><a class="page-link" href="javascript:void(0)">&laquo;</a></li>
                        <li class="page-item active"><a class="page-link" href="javascript:void(0)">1</a></li>
                        <li class="page-item"><a class="page-link" href="javascript:void(0)">2</a></li>
                        <li class="page-item"><a class="page-link" href="javascript:void(0)">3</a></li>
                        <li class="page-item"><a class="page-link" href="javascript:void(0)">&raquo;</a></li>
                    </ul>
                </nav>
                <nav>
                    <ul class="pagination pagination-sm mb-0">
                        <li class="page-item"><a class="page-link" href="javascript:void(0)">&laquo;</a></li>
                        <li class="page-item"><a class="page-link" href="javascript:void(0)">1</a></li>
                        <li class="page-item active"><a class="page-link" href="javascript:void(0)">2</a></li>
                        <li class="page-item"><a class="page-link" href="javascript:void(0)">3</a></li>
                        <li class="page-item"><a class="page-link" href="javascript:void(0)">4</a></li>
                        <li class="page-item"><a class="page-link" href="javascript:void(0)">5</a></li>
                        <li class="page-item"><a class="page-link" href="javascript:void(0)">&raquo;</a></li>
                    </ul>
                </nav>
            </div>
        </div>
    </div>
</div>

{% endblock %}
