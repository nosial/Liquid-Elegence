{% set root = "../../" %}
{% extends "layouts/dashboard.njk" %}

{% block title %}Progress Bars — Liquid Elegance{% endblock %}

{% block breadcrumb %}
<li class="breadcrumb-item"><a href="javascript:void(0)">Components</a></li>
<li class="breadcrumb-item active">Progress Bars</li>
{% endblock %}


{% block content %}

{# ── Basic Progress Bars ─────────────────────────────────────────────── #}
<div class="row g-4 mb-4">
    <div class="col-lg-6">
        <div class="glass-card">
            <div class="glass-card-body">
                <h5 class="mb-1">Basic Progress Bars</h5>
                <p class="text-muted mb-3 le-fs-body">Standard progress bars in different colour variants.</p>
                <div class="mb-3">
                    <div class="d-flex justify-content-between mb-1"><small class="text-muted">Primary</small><small class="text-muted">25%</small></div>
                    <div class="progress le-h-8">
                        <div class="progress-bar" role="progressbar" style="width:25%" aria-valuenow="25" aria-valuemin="0" aria-valuemax="100"></div>
                    </div>
                </div>
                <div class="mb-3">
                    <div class="d-flex justify-content-between mb-1"><small class="text-muted">Success</small><small class="text-muted">50%</small></div>
                    <div class="progress le-h-8">
                        <div class="progress-bar bg-success" role="progressbar" style="width:50%"></div>
                    </div>
                </div>
                <div class="mb-3">
                    <div class="d-flex justify-content-between mb-1"><small class="text-muted">Warning</small><small class="text-muted">75%</small></div>
                    <div class="progress le-h-8">
                        <div class="progress-bar bg-warning" role="progressbar" style="width:75%"></div>
                    </div>
                </div>
                <div class="mb-0">
                    <div class="d-flex justify-content-between mb-1"><small class="text-muted">Danger</small><small class="text-muted">90%</small></div>
                    <div class="progress le-h-8">
                        <div class="progress-bar bg-danger" role="progressbar" style="width:90%"></div>
                    </div>
                </div>
                <div class="glass-card mt-3 le-bg-glass-subtle">
                    <div class="glass-card-body py-2 px-3">
                        <h6 class="d-flex align-items-center gap-2 mb-2 le-fs-base"><i data-feather="code" class="le-icon-14"></i> Usage</h6>
                        <pre class="mb-0 le-fs-base le-ws-pre-wrap"><code>&lt;div class="progress" style="height:8px;"&gt;
    &lt;div class="progress-bar" role="progressbar"
         style="width:25%"
         aria-valuenow="25" aria-valuemin="0"
         aria-valuemax="100"&gt;&lt;/div&gt;
&lt;/div&gt;

&lt;!-- Color variants --&gt;
&lt;div class="progress-bar bg-success" …&gt;&lt;/div&gt;
&lt;div class="progress-bar bg-warning" …&gt;&lt;/div&gt;
&lt;div class="progress-bar bg-danger" …&gt;&lt;/div&gt;</code></pre>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# ── Progress Variants ───────────────────────────────────────────── #}
    <div class="col-lg-6">
        <div class="glass-card">
            <div class="glass-card-body">
                <h5 class="mb-1">Progress Variants</h5>
                <p class="text-muted mb-3 le-fs-body">Labelled, striped, animated, and stacked progress bars.</p>
                <div class="mb-3">
                    <small class="text-muted d-block mb-1">With Label</small>
                    <div class="progress le-h-20">
                        <div class="progress-bar" role="progressbar" style="width:60%">60%</div>
                    </div>
                </div>
                <div class="mb-3">
                    <small class="text-muted d-block mb-1">Striped</small>
                    <div class="progress le-h-10">
                        <div class="progress-bar progress-bar-striped bg-info" role="progressbar" style="width:45%"></div>
                    </div>
                </div>
                <div class="mb-3">
                    <small class="text-muted d-block mb-1">Striped &amp; Animated</small>
                    <div class="progress le-h-10">
                        <div class="progress-bar progress-bar-striped progress-bar-animated" role="progressbar" style="width:65%"></div>
                    </div>
                </div>
                <div class="mb-0">
                    <small class="text-muted d-block mb-1">Stacked / Multi-segment</small>
                    <div class="progress le-h-10">
                        <div class="progress-bar bg-primary" role="progressbar" style="width:30%"></div>
                        <div class="progress-bar bg-success" role="progressbar" style="width:20%"></div>
                        <div class="progress-bar bg-warning" role="progressbar" style="width:15%"></div>
                    </div>
                </div>
                <div class="glass-card mt-3 le-bg-glass-subtle">
                    <div class="glass-card-body py-2 px-3">
                        <h6 class="d-flex align-items-center gap-2 mb-2 le-fs-base"><i data-feather="code" class="le-icon-14"></i> Usage</h6>
                        <pre class="mb-0 le-fs-base le-ws-pre-wrap"><code>&lt;!-- Striped & animated --&gt;
&lt;div class="progress"&gt;
    &lt;div class="progress-bar progress-bar-striped
         progress-bar-animated" style="width:65%"&gt;&lt;/div&gt;
&lt;/div&gt;

&lt;!-- Stacked --&gt;
&lt;div class="progress"&gt;
    &lt;div class="progress-bar bg-primary" style="width:30%"&gt;&lt;/div&gt;
    &lt;div class="progress-bar bg-success" style="width:20%"&gt;&lt;/div&gt;
&lt;/div&gt;</code></pre>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

{# ── Progress Heights ───────────────────────────────────────────────── #}
<div class="row g-4 mb-4">
    <div class="col-12">
        <div class="glass-card">
            <div class="glass-card-body">
                <h5 class="mb-1">Progress Heights</h5>
                <p class="text-muted mb-3 le-fs-body">Customise height to match your design context.</p>
                <div class="mb-3">
                    <small class="text-muted d-block mb-1">Thin (4px)</small>
                    <div class="progress le-h-4">
                        <div class="progress-bar" role="progressbar" style="width:40%"></div>
                    </div>
                </div>
                <div class="mb-3">
                    <small class="text-muted d-block mb-1">Default (8px)</small>
                    <div class="progress le-h-8">
                        <div class="progress-bar bg-success" role="progressbar" style="width:55%"></div>
                    </div>
                </div>
                <div class="mb-3">
                    <small class="text-muted d-block mb-1">Medium (16px)</small>
                    <div class="progress le-h-16">
                        <div class="progress-bar bg-info" role="progressbar" style="width:70%">70%</div>
                    </div>
                </div>
                <div class="mb-0">
                    <small class="text-muted d-block mb-1">Thick (24px)</small>
                    <div class="progress le-h-24">
                        <div class="progress-bar bg-warning" role="progressbar" style="width:85%">85% Complete</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

{# ── Progress Bar Context & Patterns ───────────────────────────────── #}
<div class="row g-4 mb-4">
    <div class="col-lg-6">
        <div class="glass-card">
            <div class="glass-card-body">
                <h5 class="mb-1">Contextual Progress Bars</h5>
                <p class="text-muted mb-3 le-fs-body">Progress bars can use <code>bg-*</code> utility classes for semantic colouring.</p>
                <div class="mb-3">
                    <div class="d-flex justify-content-between mb-1"><small>Info</small><small>35%</small></div>
                    <div class="progress le-h-8">
                        <div class="progress-bar bg-info" role="progressbar" style="width:35%"></div>
                    </div>
                </div>
                <div class="mb-3">
                    <div class="d-flex justify-content-between mb-1"><small>Secondary</small><small>60%</small></div>
                    <div class="progress le-h-8">
                        <div class="progress-bar bg-secondary" role="progressbar" style="width:60%"></div>
                    </div>
                </div>
                <div class="mb-0">
                    <div class="d-flex justify-content-between mb-1"><small>Dark</small><small>80%</small></div>
                    <div class="progress le-h-8">
                        <div class="progress-bar bg-dark" role="progressbar" style="width:80%"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# ── Progress with Bars & Gradient ────────────────────────────── #}
    <div class="col-lg-6">
        <div class="glass-card">
            <div class="glass-card-body">
                <h5 class="mb-1">Progress with Background</h5>
                <p class="text-muted mb-3 le-fs-body">Customise the track background and bar gradient for richer visuals.</p>
                <div class="mb-3">
                    <small class="text-muted d-block mb-1">Light track</small>
                    <div class="progress le-h-10 le-bg-glass">
                        <div class="progress-bar" role="progressbar" style="width:55%"></div>
                    </div>
                </div>
                <div class="mb-3">
                    <small class="text-muted d-block mb-1">Striped gradient bar</small>
                    <div class="progress le-h-10">
                        <div class="progress-bar progress-bar-striped bg-success" role="progressbar" style="width:70%"></div>
                    </div>
                </div>
                <div class="mb-0">
                    <small class="text-muted d-block mb-1">Animated progress</small>
                    <div class="progress le-h-10">
                        <div class="progress-bar progress-bar-striped progress-bar-animated bg-primary" role="progressbar" style="width:45%"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

{% endblock %}
