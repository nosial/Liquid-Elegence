{% set root = "../../" %}
{% extends "layouts/dashboard.njk" %}

{% block title %}Cards &amp; Tables — Liquid Elegance{% endblock %}

{% block breadcrumb %}
<li class="breadcrumb-item"><a href="javascript:void(0)">Components</a></li>
<li class="breadcrumb-item active">Cards &amp; Tables</li>
{% endblock %}


{% block content %}

{# ── Glass Cards ─────────────────────────────────────────────────────── #}
<div class="row g-4 mb-4">
    <div class="col-md-6 col-xl-3">
        <div class="glass-card">
            <div class="glass-card-body">
                <h6 class="mb-2">Basic Glass Card</h6>
                <p class="text-muted mb-0 le-fs-body">A standard glass card with backdrop-filter blur and subtle border.</p>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="glass-card metric-card">
            <div class="glass-card-body">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="metric-label text-muted mb-1">Revenue</p>
                        <h3 class="metric-value mb-1">$12,480</h3>
                        <span class="metric-change text-success"><i data-feather="trending-up"></i> +8.2%</span>
                    </div>
                    <div class="metric-icon bg-primary-subtle">
                        <i data-feather="dollar-sign"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="glass-card metric-card">
            <div class="glass-card-body">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="metric-label text-muted mb-1">Users</p>
                        <h3 class="metric-value mb-1">2,845</h3>
                        <span class="metric-change text-danger"><i data-feather="trending-down"></i> -2.4%</span>
                    </div>
                    <div class="metric-icon bg-success-subtle">
                        <i data-feather="users"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-xl-3">
        <div class="glass-card metric-card">
            <div class="glass-card-body">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="metric-label text-muted mb-1">Orders</p>
                        <h3 class="metric-value mb-1">384</h3>
                        <span class="metric-change text-success"><i data-feather="trending-up"></i> +12.1%</span>
                    </div>
                    <div class="metric-icon bg-warning-subtle">
                        <i data-feather="shopping-cart"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-12">
        <div class="glass-card mt-3 le-bg-glass-subtle">
            <div class="glass-card-body py-2 px-3">
                <h6 class="d-flex align-items-center gap-2 mb-2 le-fs-base"><i data-feather="code" class="le-icon-14"></i> Usage</h6>
                <pre class="mb-0 le-fs-base le-ws-pre-wrap"><code>&lt;!-- Basic Glass Card --&gt;
&lt;div class="glass-card"&gt;
    &lt;div class="glass-card-body"&gt;
        &lt;h6&gt;Card Title&lt;/h6&gt;
        &lt;p class="text-muted mb-0"&gt;Card content goes here.&lt;/p&gt;
    &lt;/div&gt;
&lt;/div&gt;

&lt;!-- Metric Card --&gt;
&lt;div class="glass-card metric-card"&gt;
    &lt;div class="glass-card-body"&gt;
        &lt;div class="d-flex justify-content-between align-items-start"&gt;
            &lt;div&gt;
                &lt;p class="metric-label text-muted mb-1"&gt;Label&lt;/p&gt;
                &lt;h3 class="metric-value mb-1"&gt;$12,480&lt;/h3&gt;
                &lt;span class="metric-change text-success"&gt;
                    &lt;i data-feather="trending-up"&gt;&lt;/i&gt; +8.2%
                &lt;/span&gt;
            &lt;/div&gt;
            &lt;div class="metric-icon bg-primary-subtle"&gt;
                &lt;i data-feather="dollar-sign"&gt;&lt;/i&gt;
            &lt;/div&gt;
        &lt;/div&gt;
    &lt;/div&gt;
&lt;/div&gt;</code></pre>
            </div>
        </div>
    </div>
</div>

{# ── Card with Header / Footer ──────────────────────────────────────── #}
<div class="row g-4 mb-4">
    <div class="col-lg-6">
        <div class="glass-card">
            <div class="glass-card-header d-flex justify-content-between align-items-center">
                <h6 class="mb-0">Card with Header</h6>
                <span class="glass-badge glass-badge-primary">New</span>
            </div>
            <div class="glass-card-body">
                <p class="text-muted mb-0">This card has a header section with a title and badge. The glass morphism design carries through to all card sections.</p>
            </div>
            <div class="glass-card-footer text-muted le-fs-body">
                <i data-feather="clock" class="me-1 le-icon-14"></i> Updated 2 hours ago
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="glass-card">
            <div class="glass-card-header">
                <ul class="nav nav-pills glass-nav-pills" role="tablist">
                    <li class="nav-item"><button class="nav-link active" data-bs-toggle="pill" data-bs-target="#tabA">Overview</button></li>
                    <li class="nav-item"><button class="nav-link" data-bs-toggle="pill" data-bs-target="#tabB">Details</button></li>
                    <li class="nav-item"><button class="nav-link" data-bs-toggle="pill" data-bs-target="#tabC">History</button></li>
                </ul>
            </div>
            <div class="glass-card-body">
                <div class="tab-content">
                    <div class="tab-pane fade show active" id="tabA">
                        <p class="text-muted mb-0">Overview tab content. This demonstrates a card with tabbed navigation in the header.</p>
                    </div>
                    <div class="tab-pane fade" id="tabB">
                        <p class="text-muted mb-0">Detailed information goes here with granular data about the subject.</p>
                    </div>
                    <div class="tab-pane fade" id="tabC">
                        <p class="text-muted mb-0">Historical records and change log entries are displayed in this panel.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-12">
        <div class="glass-card mt-3 le-bg-glass-subtle">
            <div class="glass-card-body py-2 px-3">
                <h6 class="d-flex align-items-center gap-2 mb-2 le-fs-base"><i data-feather="code" class="le-icon-14"></i> Usage</h6>
                <pre class="mb-0 le-fs-base le-ws-pre-wrap"><code>&lt;!-- Card with Header, Body &amp; Footer --&gt;
&lt;div class="glass-card"&gt;
    &lt;div class="glass-card-header d-flex justify-content-between align-items-center"&gt;
        &lt;h6 class="mb-0"&gt;Title&lt;/h6&gt;
        &lt;span class="glass-badge glass-badge-primary"&gt;Badge&lt;/span&gt;
    &lt;/div&gt;
    &lt;div class="glass-card-body"&gt;
        &lt;p&gt;Body content.&lt;/p&gt;
    &lt;/div&gt;
    &lt;div class="glass-card-footer text-muted"&gt;
        Footer content
    &lt;/div&gt;
&lt;/div&gt;

&lt;!-- Card with Tabbed Header --&gt;
&lt;div class="glass-card"&gt;
    &lt;div class="glass-card-header"&gt;
        &lt;ul class="nav nav-pills glass-nav-pills" role="tablist"&gt;
            &lt;li class="nav-item"&gt;
                &lt;button class="nav-link active" data-bs-toggle="pill"
                    data-bs-target="#tab1"&gt;Tab 1&lt;/button&gt;
            &lt;/li&gt;
        &lt;/ul&gt;
    &lt;/div&gt;
    &lt;div class="glass-card-body"&gt;
        &lt;div class="tab-content"&gt;
            &lt;div class="tab-pane fade show active" id="tab1"&gt;...&lt;/div&gt;
        &lt;/div&gt;
    &lt;/div&gt;
&lt;/div&gt;</code></pre>
            </div>
        </div>
    </div>
</div>

{# ── Tables ──────────────────────────────────────────────────────────── #}
<div class="row g-4 mb-4">
    <div class="col-12">
        <div class="glass-card">
            <div class="glass-card-header d-flex justify-content-between align-items-center">
                <h6 class="mb-0">Data Table</h6>
                <div class="d-flex gap-2">
                    <button class="btn btn-sm btn-glass btn-glass-primary"><i data-feather="plus" class="me-1 le-icon-14"></i>Add</button>
                    <button class="btn btn-sm btn-glass btn-glass-secondary"><i data-feather="download" class="me-1 le-icon-14"></i>Export</button>
                </div>
            </div>
            <div class="glass-card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead>
                            <tr>
                                <th><input class="form-check-input" type="checkbox"></th>
                                <th>Name</th>
                                <th>Email</th>
                                <th>Role</th>
                                <th>Status</th>
                                <th>Joined</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td><input class="form-check-input" type="checkbox"></td>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="avatar avatar-sm"><div class="avatar-placeholder">JD</div></div>
                                        <div><span class="fw-semibold">John Doe</span></div>
                                    </div>
                                </td>
                                <td>john@example.com</td>
                                <td><span class="badge badge-status bg-primary">Admin</span></td>
                                <td><span class="badge badge-status bg-success">Active</span></td>
                                <td>Jan 15, 2024</td>
                                <td class="text-end action-btns">
                                    <button class="btn btn-sm" title="Edit"><i data-feather="edit-2"></i></button>
                                    <button class="btn btn-sm" title="Delete"><i data-feather="trash-2"></i></button>
                                </td>
                            </tr>
                            <tr>
                                <td><input class="form-check-input" type="checkbox"></td>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="avatar avatar-sm"><div class="avatar-placeholder">AK</div></div>
                                        <div><span class="fw-semibold">Alice Kim</span></div>
                                    </div>
                                </td>
                                <td>alice@example.com</td>
                                <td><span class="badge badge-status bg-info">Editor</span></td>
                                <td><span class="badge badge-status bg-success">Active</span></td>
                                <td>Feb 03, 2024</td>
                                <td class="text-end action-btns">
                                    <button class="btn btn-sm" title="Edit"><i data-feather="edit-2"></i></button>
                                    <button class="btn btn-sm" title="Delete"><i data-feather="trash-2"></i></button>
                                </td>
                            </tr>
                            <tr>
                                <td><input class="form-check-input" type="checkbox"></td>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="avatar avatar-sm"><div class="avatar-placeholder">BM</div></div>
                                        <div><span class="fw-semibold">Bob Martin</span></div>
                                    </div>
                                </td>
                                <td>bob@example.com</td>
                                <td><span class="badge badge-status bg-secondary">Viewer</span></td>
                                <td><span class="badge badge-status bg-warning">Pending</span></td>
                                <td>Mar 22, 2024</td>
                                <td class="text-end action-btns">
                                    <button class="btn btn-sm" title="Edit"><i data-feather="edit-2"></i></button>
                                    <button class="btn btn-sm" title="Delete"><i data-feather="trash-2"></i></button>
                                </td>
                            </tr>
                            <tr>
                                <td><input class="form-check-input" type="checkbox"></td>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="avatar avatar-sm"><div class="avatar-placeholder">CL</div></div>
                                        <div><span class="fw-semibold">Clara Lee</span></div>
                                    </div>
                                </td>
                                <td>clara@example.com</td>
                                <td><span class="badge badge-status bg-primary">Admin</span></td>
                                <td><span class="badge badge-status bg-danger">Suspended</span></td>
                                <td>Apr 10, 2024</td>
                                <td class="text-end action-btns">
                                    <button class="btn btn-sm" title="Edit"><i data-feather="edit-2"></i></button>
                                    <button class="btn btn-sm" title="Delete"><i data-feather="trash-2"></i></button>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
    <div class="col-12">
        <div class="glass-card mt-3 le-bg-glass-subtle">
            <div class="glass-card-body py-2 px-3">
                <h6 class="d-flex align-items-center gap-2 mb-2 le-fs-base"><i data-feather="code" class="le-icon-14"></i> Usage</h6>
                <pre class="mb-0 le-fs-base le-ws-pre-wrap"><code>&lt;!-- Basic Glass Table --&gt;
&lt;div class="glass-card"&gt;
    &lt;div class="glass-card-body p-0"&gt;
        &lt;div class="table-responsive"&gt;
            &lt;table class="table table-hover align-middle mb-0"&gt;
                &lt;thead&gt;
                    &lt;tr&gt;
                        &lt;th&gt;Name&lt;/th&gt;
                        &lt;th&gt;Email&lt;/th&gt;
                        &lt;th&gt;Status&lt;/th&gt;
                    &lt;/tr&gt;
                &lt;/thead&gt;
                &lt;tbody&gt;
                    &lt;tr&gt;
                        &lt;td&gt;John Doe&lt;/td&gt;
                        &lt;td&gt;john@example.com&lt;/td&gt;
                        &lt;td&gt;&lt;span class="badge bg-success"&gt;Active&lt;/span&gt;&lt;/td&gt;
                    &lt;/tr&gt;
                &lt;/tbody&gt;
            &lt;/table&gt;
        &lt;/div&gt;
    &lt;/div&gt;
&lt;/div&gt;

&lt;!-- Striped &amp; hover variant --&gt;
&lt;table class="table table-striped table-hover align-middle"&gt;...&lt;/table&gt;</code></pre>
            </div>
        </div>
    </div>
</div>

{# ── Accordion ───────────────────────────────────────────────────────── #}
<div class="row g-4 mb-4">
    <div class="col-lg-6">
        <div class="glass-card">
            <div class="glass-card-body">
                <h5 class="mb-3">Accordion</h5>
                <div class="accordion" id="demoAccordion">
                    <div class="accordion-item">
                        <h2 class="accordion-header">
                            <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#collapseOne">What is Liquid Elegance?</button>
                        </h2>
                        <div id="collapseOne" class="accordion-collapse collapse show" data-bs-parent="#demoAccordion">
                            <div class="accordion-body">A Bootstrap 5 admin template featuring a liquid glass morphism design system with comprehensive dark mode and density support.</div>
                        </div>
                    </div>
                    <div class="accordion-item">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseTwo">How do I customize themes?</button>
                        </h2>
                        <div id="collapseTwo" class="accordion-collapse collapse" data-bs-parent="#demoAccordion">
                            <div class="accordion-body">Use the customizer panel (gear icon at bottom-right) to switch between 6 color themes, light/dark mode, and 3 density levels.</div>
                        </div>
                    </div>
                    <div class="accordion-item">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseThree">Is RTL supported?</button>
                        </h2>
                        <div id="collapseThree" class="accordion-collapse collapse" data-bs-parent="#demoAccordion">
                            <div class="accordion-body">Yes, the template includes full RTL support with a dedicated stylesheet that automatically mirrors the layout when RTL direction is enabled.</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# ── List Group ──────────────────────────────────────────────────── #}
    <div class="col-lg-6">
        <div class="glass-card">
            <div class="glass-card-body">
                <h5 class="mb-3">List Group</h5>
                <ul class="list-group mb-4">
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        Emails
                        <span class="badge bg-primary rounded-pill">14</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        Messages
                        <span class="badge bg-success rounded-pill">5</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        Tasks
                        <span class="badge bg-warning rounded-pill">23</span>
                    </li>
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        Notifications
                        <span class="badge bg-danger rounded-pill">99+</span>
                    </li>
                </ul>

                <h6 class="mb-2">Activity Feed</h6>
                <div class="activity-feed">
                    <div class="activity-item d-flex gap-3 mb-3">
                        <div class="le-status-dot le-bg-primary"></div>
                        <div>
                            <p class="mb-0 le-fs-body"><strong>John Doe</strong> created a new project</p>
                            <small class="text-muted">2 hours ago</small>
                        </div>
                    </div>
                    <div class="activity-item d-flex gap-3 mb-3">
                        <div class="le-status-dot le-bg-success"></div>
                        <div>
                            <p class="mb-0 le-fs-body"><strong>Alice Kim</strong> completed task "Design Review"</p>
                            <small class="text-muted">4 hours ago</small>
                        </div>
                    </div>
                    <div class="activity-item d-flex gap-3">
                        <div class="le-status-dot le-bg-warning"></div>
                        <div>
                            <p class="mb-0 le-fs-body"><strong>System</strong> scheduled maintenance window</p>
                            <small class="text-muted">6 hours ago</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

{# ── Modals ──────────────────────────────────────────────────────────── #}
<div class="row g-4 mb-4">
    <div class="col-12">
        <div class="glass-card">
            <div class="glass-card-body">
                <h5 class="mb-3">Modals</h5>
                <div class="d-flex flex-wrap gap-3">
                    <button class="btn btn-glass btn-glass-primary" data-bs-toggle="modal" data-bs-target="#demoModal">Standard Modal</button>
                    <button class="btn btn-glass btn-glass-secondary" data-bs-toggle="modal" data-bs-target="#demoModalSm">Small Modal</button>
                    <button class="btn btn-glass btn-glass-success" data-bs-toggle="modal" data-bs-target="#demoModalLg">Large Modal</button>
                    <button class="btn btn-glass btn-glass-info" data-bs-toggle="modal" data-bs-target="#demoModalCenter">Centered Modal</button>
                </div>
            </div>
        </div>
    </div>
</div>

{# Modal HTML #}
<div class="modal fade" id="demoModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Standard Modal</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>This is a standard modal with the liquid glass design system applied. Notice the backdrop blur and glass effects on the modal content area.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-glass btn-glass-secondary" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn btn-glass btn-glass-primary">Save changes</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="demoModalSm" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Small Modal</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>A compact modal for quick confirmations or small forms.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-sm btn-glass btn-glass-danger" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-sm btn-glass btn-glass-primary">Confirm</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="demoModalLg" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Large Modal</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>A large modal suitable for complex forms, data display, or multi-step wizards. The glass design scales beautifully at any size.</p>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">First Name</label>
                        <input type="text" class="form-control glass-input" placeholder="John">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Last Name</label>
                        <input type="text" class="form-control glass-input" placeholder="Doe">
                    </div>
                    <div class="col-12">
                        <label class="form-label">Email</label>
                        <input type="email" class="form-control glass-input" placeholder="john@example.com">
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-glass btn-glass-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-glass btn-glass-primary">Submit</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="demoModalCenter" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Centered Modal</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-center">
                <div class="icon-circle icon-circle-xl icon-circle-success mx-auto mb-3">
                    <i data-feather="check" class="le-box-32"></i>
                </div>
                <h5>Success!</h5>
                <p class="text-muted">Your operation has been completed successfully.</p>
            </div>
            <div class="modal-footer justify-content-center">
                <button type="button" class="btn btn-glass btn-glass-primary" data-bs-dismiss="modal">Got it!</button>
            </div>
        </div>
    </div>
</div>

{# ── Tabs & Nav Pills ───────────────────────────────────────────────── #}
<div class="row g-4 mb-4">
    <div class="col-lg-6">
        <div class="glass-card">
            <div class="glass-card-body">
                <h5 class="mb-3">Nav Tabs</h5>
                <ul class="nav nav-tabs mb-3" role="tablist">
                    <li class="nav-item"><button class="nav-link active" data-bs-toggle="tab" data-bs-target="#navTab1">Home</button></li>
                    <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#navTab2">Profile</button></li>
                    <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#navTab3">Settings</button></li>
                    <li class="nav-item"><button class="nav-link" disabled>Disabled</button></li>
                </ul>
                <div class="tab-content">
                    <div class="tab-pane fade show active" id="navTab1"><p class="text-muted mb-0">Home tab content with the liquid glass design system.</p></div>
                    <div class="tab-pane fade" id="navTab2"><p class="text-muted mb-0">Profile information and user preferences.</p></div>
