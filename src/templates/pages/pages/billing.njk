{% set root = "../../" %}
{% extends "layouts/dashboard.njk" %}


{% block content %}
<div class="billing-page">
<div class="page-header"><h1 class="page-title">Billing</h1></div>

<!-- Current Plan & Payment Method -->
<div class="row g-4 mb-4">
    <!-- Current Plan -->
    <div class="col-lg-7">
        <div class="glass-card h-100">
            <div class="plan-header">
                <div>
                    <h4>Professional Plan</h4>
                    <span class="text-muted">Billed monthly</span>
                </div>
                <div class="plan-price">$29<span class="le-fs-half fw-normal le-opacity-70">/month</span></div>
            </div>
            <div class="card-header-title">Usage This Period</div>
            <div class="usage-stat">
                <div class="d-flex justify-content-between">
                    <span class="usage-label">API Calls</span>
                    <span class="usage-value">8,420 / 10,000</span>
                </div>
                <div class="progress">
                    <div class="progress-bar bg-primary" role="progressbar" style="width: 84.2%" aria-valuenow="84.2" aria-valuemin="0" aria-valuemax="100"></div>
                </div>
            </div>
            <div class="usage-stat">
                <div class="d-flex justify-content-between">
                    <span class="usage-label">Storage</span>
                    <span class="usage-value">3.2 GB / 5 GB</span>
                </div>
                <div class="progress">
                    <div class="progress-bar bg-info" role="progressbar" style="width: 64%" aria-valuenow="64" aria-valuemin="0" aria-valuemax="100"></div>
                </div>
            </div>
            <div class="usage-stat">
                <div class="d-flex justify-content-between">
                    <span class="usage-label">Team Members</span>
                    <span class="usage-value">8 / 10</span>
                </div>
                <div class="progress">
                    <div class="progress-bar bg-success" role="progressbar" style="width: 80%" aria-valuenow="80" aria-valuemin="0" aria-valuemax="100"></div>
                </div>
            </div>
            <div class="d-flex gap-2 mt-4">
                <button class="btn btn-primary">Upgrade Plan</button>
                <button class="btn btn-outline-danger">Cancel Subscription</button>
            </div>
        </div>
    </div>

    <!-- Payment Method -->
    <div class="col-lg-5">
        <div class="glass-card h-100">
            <div class="card-header-title">Payment Methods</div>
            <div class="payment-card">
                <div class="card-icon"><i data-feather="credit-card"></i></div>
                <div class="card-details">
                    <div class="card-name">Visa ending in 4242</div>
                    <div class="card-info">Expires 12/28</div>
                </div>
                <span class="badge bg-primary default-badge">Default</span>
            </div>
            <div class="payment-card">
                <div class="card-icon"><i data-feather="link"></i></div>
                <div class="card-details">
                    <div class="card-name">PayPal</div>
                    <div class="card-info">john.doe@email.com</div>
                </div>
                <span class="badge bg-secondary default-badge">Backup</span>
            </div>
            <div class="d-flex gap-2 mt-4">
                <button class="btn btn-primary">Update Card</button>
                <button class="btn btn-outline-secondary">Add New Method</button>
            </div>
        </div>
    </div>
</div>

