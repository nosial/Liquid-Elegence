{% block scripts %}
<script>
        document.addEventListener('DOMContentLoaded', function() {
            feather.replace();

            const list = document.getElementById('notificationList');
            const markAllBtn = document.getElementById('markAllReadBtn');
            const unreadCountEl = document.getElementById('unreadCount');
            const filterStatus = document.getElementById('filterStatus');
            const filterType = document.getElementById('filterType');
            const loadMoreBtn = document.getElementById('loadMoreBtn');

            function updateUnreadCount() {
                const count = list.querySelectorAll('.list-group-item.unread').length;
                unreadCountEl.textContent = count + ' unread notification' + (count !== 1 ? 's' : '');
            }

            function applyFilters() {
                const status = filterStatus.value;
                const type = filterType.value;
                list.querySelectorAll('.list-group-item').forEach(function(item) {
                    let showStatus = true;
                    let showType = true;
                    if (status === 'unread') showStatus = item.classList.contains('unread');
                    if (status === 'read') showStatus = !item.classList.contains('unread');
                    if (type !== 'all') showType = item.getAttribute('data-type') === type;
                    item.style.display = (showStatus && showType) ? '' : 'none';
                });
            }

            // Mark all read
            markAllBtn.addEventListener('click', function() {
                list.querySelectorAll('.list-group-item.unread').forEach(function(item) {
                    item.classList.remove('unread');
                    var dot = item.querySelector('.unread-dot');
                    if (dot) dot.remove();
                });
                updateUnreadCount();
                applyFilters();
            });

            // Click notification to toggle read/unread
            list.addEventListener('click', function(e) {
                var deleteBtn = e.target.closest('.notif-delete');
                if (deleteBtn) return;
                var item = e.target.closest('.list-group-item');
                if (!item) return;
                if (item.classList.contains('unread')) {
                    item.classList.remove('unread');
                    var dot = item.querySelector('.unread-dot');
                    if (dot) dot.remove();
                } else {
                    item.classList.add('unread');
                    var titleEl = item.querySelector('.notif-title');
                    if (titleEl && !titleEl.querySelector('.unread-dot')) {
                        var newDot = document.createElement('span');
                        newDot.className = 'unread-dot';
                        titleEl.appendChild(newDot);
                    }
                }
                updateUnreadCount();
                applyFilters();
            });

            // Delete notification
            list.addEventListener('click', function(e) {
                var deleteBtn = e.target.closest('.notif-delete');
                if (!deleteBtn) return;
                e.stopPropagation();
                var item = deleteBtn.closest('.list-group-item');
                if (!item) return;
                item.classList.add('fade-out');
                setTimeout(function() {
                    item.remove();
                    updateUnreadCount();
                    applyFilters();
                    feather.replace();
                }, 300);
            });

            // Filters
            filterStatus.addEventListener('change', applyFilters);
            filterType.addEventListener('change', applyFilters);

            // Load more
            loadMoreBtn.addEventListener('click', function() {
                LiquidElegance.showToast('No more notifications', 'info');
            });
        });
</script>
{% endblock %}
