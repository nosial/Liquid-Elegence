                                San Francisco, CA 94107<br>
                                Phone: (415) 555-0198<br>
                                Email: billing@liquidadmin.com
                            </div>
                        </div>
                        <div class="invoice-meta">
                            <div class="invoice-number" id="modalInvoiceNumber">INV-2024-001</div>
                            <div class="invoice-meta-item">Date: <strong id="modalIssueDate">Jan 15, 2024</strong></div>
                            <div class="invoice-meta-item">Due: <strong id="modalDueDate">Feb 14, 2024</strong></div>
                            <div class="invoice-meta-item mt-2" id="modalStatusBadge"></div>
                        </div>
                    </div>
