{% set root = "../../" %}
{% extends "layouts/dashboard.njk" %}


{% block content %}
<div class="page-header"><h1 class="page-title">Invoices</h1></div>

<!-- Summary Metric Cards -->
<div class="row g-4 mb-4">
    <div class="col-xl-3 col-md-6">
        <div class="metric-card">
            <div class="d-flex align-items-center justify-content-between mb-3">
                <div class="metric-icon bg-primary-subtle"><i data-feather="file-text"></i></div>
                <span class="badge bg-primary bg-opacity-10 text-primary">+12%</span>
            </div>
            <p class="metric-value">156</p>
            <p class="metric-label">Total Invoices</p>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="metric-card">
            <div class="d-flex align-items-center justify-content-between mb-3">
                <div class="metric-icon bg-success-subtle"><i data-feather="check-circle"></i></div>
                <span class="badge bg-success bg-opacity-10 text-success">+8.2%</span>
            </div>
            <p class="metric-value">$84,250</p>
            <p class="metric-label">Paid</p>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="metric-card">
            <div class="d-flex align-items-center justify-content-between mb-3">
                <div class="metric-icon bg-warning-subtle"><i data-feather="clock"></i></div>
                <span class="badge bg-warning bg-opacity-10 text-warning">4 new</span>
            </div>
            <p class="metric-value">$12,480</p>
            <p class="metric-label">Pending</p>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="metric-card">
            <div class="d-flex align-items-center justify-content-between mb-3">
                <div class="metric-icon bg-danger-subtle"><i data-feather="alert-circle"></i></div>
                <span class="badge bg-danger bg-opacity-10 text-danger">-3.1%</span>
            </div>
            <p class="metric-value">$3,200</p>
            <p class="metric-label">Overdue</p>
        </div>
    </div>
</div>

