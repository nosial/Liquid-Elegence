                    document.getElementById('modalInvoiceNumber').textContent = invoiceNum;
                    document.getElementById('modalIssueDate').textContent = issueDate;
                    document.getElementById('modalDueDate').textContent = dueDate;
                    document.getElementById('modalClientName').textContent = client;
                    document.getElementById('modalClientEmail').textContent = email;
