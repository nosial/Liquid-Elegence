{% set root = "../../" %}
{% extends "layouts/dashboard.njk" %}


{% block content %}
<div class="page-header"><h1 class="page-title">Settings</h1></div>

<div class="settings-card">
<div class="row g-4">
    <!-- Left Column - Navigation Pills -->
    <div class="col-lg-3">
        <div class="glass-card no-hover">
            <nav class="nav nav-pills flex-column" id="settingsNav" role="tablist">
                <a class="nav-link active" data-bs-toggle="pill" href="#tab-general" role="tab" aria-selected="true"><i data-feather="settings"></i><span>General</span></a>
                <a class="nav-link" data-bs-toggle="pill" href="#tab-security" role="tab" aria-selected="false"><i data-feather="shield"></i><span>Security</span></a>
                <a class="nav-link" data-bs-toggle="pill" href="#tab-notifications" role="tab" aria-selected="false"><i data-feather="bell"></i><span>Notifications</span></a>
                <a class="nav-link" data-bs-toggle="pill" href="#tab-appearance" role="tab" aria-selected="false"><i data-feather="monitor"></i><span>Appearance</span></a>
                <a class="nav-link" data-bs-toggle="pill" href="#tab-integrations" role="tab" aria-selected="false"><i data-feather="link-2"></i><span>Integrations</span></a>
            </nav>
        </div>
    </div>

    <!-- Right Column - Tab Content -->
    <div class="col-lg-9">
        <div class="tab-content">

        <!-- General Tab -->
        <div class="tab-pane fade show active" id="tab-general" role="tabpanel">
            <div class="glass-card">
                <h5 class="card-header-title">General Settings</h5>

                <div class="d-flex align-items-center gap-3 mb-4">
                    <div class="profile-upload" id="profileUpload">
                        <div class="camera-overlay">
                            <i data-feather="camera"></i>
                            <span>Upload Photo</span>
                        </div>
                    </div>
                    <div>
                        <div class="fw-semibold">Profile Picture</div>
                        <div class="small le-opacity-60">JPG, PNG or GIF. Max 2MB.</div>
                    </div>
                </div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Full Name</label>
                        <input type="text" class="form-control glass-input" value="John Doe">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Email</label>
                        <input type="email" class="form-control glass-input" value="john.doe@techcorp.com">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Phone</label>
                        <input type="text" class="form-control glass-input" value="+1 (415) 555-0142">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Timezone</label>
                        <select class="form-select glass-input">
                            <option value="utc-8" selected>UTC-8 Pacific Time</option>
                            <option value="utc-5">UTC-5 Eastern Time</option>
                            <option value="utc+0">UTC+0 GMT</option>
                            <option value="utc+1">UTC+1 CET</option>
                            <option value="utc+5:30">UTC+5:30 IST</option>
                            <option value="utc+9">UTC+9 JST</option>
                        </select>
                    </div>
                    <div class="col-12">
                        <label class="form-label">Bio</label>
                        <textarea class="form-control glass-input" rows="4">Senior Full-Stack Developer with 8+ years of experience building scalable web applications. Passionate about clean code architecture, mentoring junior developers, and exploring emerging technologies.</textarea>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Language</label>
                        <select class="form-select glass-input">
                            <option value="en" selected>English</option>
                            <option value="es">Spanish</option>
                            <option value="fr">French</option>
                            <option value="de">German</option>
                            <option value="ja">Japanese</option>
                            <option value="pt">Portuguese</option>
                        </select>
                    </div>
                </div>

                <div class="d-flex gap-2 mt-4">
                    <button class="btn btn-primary">Save Changes</button>
                    <button class="btn btn-outline-secondary">Cancel</button>
                </div>
            </div>
        </div>

        <!-- Security Tab -->
        <div class="tab-pane fade" id="tab-security" role="tabpanel">
            <div class="glass-card glass-card-body d-flex flex-column gap-0">
                <!-- Change Password -->
                <div>
                    <h5 class="card-header-title">Change Password</h5>
                    <div class="row g-3">
                        <div class="col-md-12">
                            <label class="form-label">Current Password</label>
                            <input type="password" class="form-control glass-input" placeholder="Enter current password">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">New Password</label>
                            <input type="password" class="form-control glass-input" placeholder="Enter new password">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Confirm New Password</label>
                            <input type="password" class="form-control glass-input" placeholder="Confirm new password">
                        </div>
                    </div>
                    <ul class="password-requirements">
                        <li>At least 8 characters long</li>
                        <li>Contains at least one uppercase letter</li>
                        <li>Contains at least one number</li>
                        <li>Contains at least one special character (!@#$%)</li>
                    </ul>
                    <div class="mt-3">
                        <button class="btn btn-primary">Update Password</button>
                    </div>
                </div>

                <div class="glass-divider my-4"></div>

                <!-- Two-Factor Authentication -->
                <div>
                    <h5 class="card-header-title">Two-Factor Authentication</h5>
                    <div class="tfa-section">
                        <div class="flex-grow-1">
                            <div class="d-flex align-items-center justify-content-between mb-2">
                                <span class="fw-semibold">Enable Two-Factor Authentication</span>
                                <div class="form-check form-switch mb-0">
                                    <input class="form-check-input" type="checkbox" id="tfa-toggle">
                                </div>
                            </div>
                            <p class="mb-2 small le-opacity-65">Add an extra layer of security to your account by requiring a verification code in addition to your password when signing in.</p>
                            <button class="btn btn-sm btn-outline-primary" id="setup2fa-btn" disabled>Set Up 2FA</button>
                        </div>
                    </div>
                </div>

                <div class="glass-divider my-4"></div>

                <!-- Active Sessions -->
                <div>
                    <h5 class="card-header-title">Active Sessions</h5>
                    <div class="glass-table-wrapper">
                        <table class="table">
                            <thead>
                                <tr>
                                    <th>Device</th>
                                    <th>IP Address</th>
                                    <th>Location</th>
                                    <th>Last Active</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td><i data-feather="monitor" class="le-icon-15 le-icon-mr-6"></i>Chrome on macOS</td>
                                    <td>192.168.1.105</td>
                                    <td>San Francisco, CA</td>
                                    <td>Just now</td>
                                    <td><span class="badge bg-success badge-status">Current Session</span></td>
                                </tr>
                                <tr>
                                    <td><i data-feather="monitor" class="le-icon-15 le-icon-mr-6"></i>Firefox on Windows</td>
                                    <td>74.125.68.102</td>
                                    <td>New York, NY</td>
                                    <td>2 hours ago</td>
                                    <td><button class="btn btn-sm btn-outline-danger">Revoke</button></td>
                                </tr>
                                <tr>
                                    <td><i data-feather="smartphone" class="le-icon-15 le-icon-mr-6"></i>Safari on iPhone</td>
                                    <td>203.0.113.42</td>
                                    <td>Los Angeles, CA</td>
                                    <td>1 day ago</td>
                                    <td><button class="btn btn-sm btn-outline-danger">Revoke</button></td>
                                </tr>
                                <tr>
                                    <td><i data-feather="smartphone" class="le-icon-15 le-icon-mr-6"></i>Chrome on Android</td>
                                    <td>172.217.14.99</td>
                                    <td>Chicago, IL</td>
                                    <td>3 days ago</td>
                                    <td><button class="btn btn-sm btn-outline-danger">Revoke</button></td>
                                </tr>
                                <tr>
                                    <td><i data-feather="monitor" class="le-icon-15 le-icon-mr-6"></i>Edge on Windows</td>
                                    <td>98.137.11.164</td>
                                    <td>Seattle, WA</td>
                                    <td>5 days ago</td>
                                    <td><button class="btn btn-sm btn-outline-danger">Revoke</button></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Notifications Tab -->
        <div class="tab-pane fade" id="tab-notifications" role="tabpanel">
            <div class="glass-card">
                <h5 class="card-header-title">Notification Preferences</h5>

                <div class="notification-group">
                    <h6>Email Notifications</h6>
                    <div class="notification-row">
                        <span>New order received</span>
                        <div class="form-check form-switch mb-0">
                            <input class="form-check-input" type="checkbox" checked>
                        </div>
                    </div>
                    <div class="notification-row">
                        <span>Order status updates</span>
                        <div class="form-check form-switch mb-0">
                            <input class="form-check-input" type="checkbox" checked>
                        </div>
                    </div>
                    <div class="notification-row">
                        <span>Newsletter and promotions</span>
                        <div class="form-check form-switch mb-0">
                            <input class="form-check-input" type="checkbox">
                        </div>
                    </div>
                    <div class="notification-row">
                        <span>Weekly activity digest</span>
                        <div class="form-check form-switch mb-0">
                            <input class="form-check-input" type="checkbox" checked>
                        </div>
                    </div>
                </div>

                <div class="notification-group">
                    <h6>Push Notifications</h6>
                    <div class="notification-row">
                        <span>New messages</span>
                        <div class="form-check form-switch mb-0">
                            <input class="form-check-input" type="checkbox" checked>
                        </div>
                    </div>
                    <div class="notification-row">
                        <span>Mentions and replies</span>
                        <div class="form-check form-switch mb-0">
                            <input class="form-check-input" type="checkbox" checked>
                        </div>
                    </div>
                    <div class="notification-row">
                        <span>Task reminders</span>
                        <div class="form-check form-switch mb-0">
                            <input class="form-check-input" type="checkbox" checked>
                        </div>
                    </div>
                    <div class="notification-row">
                        <span>System announcements</span>
                        <div class="form-check form-switch mb-0">
                            <input class="form-check-input" type="checkbox">
                        </div>
                    </div>
                </div>

                <div class="notification-group">
                    <h6>Desktop Notifications</h6>
                    <div class="notification-row">
                        <span>Real-time alerts</span>
                        <div class="form-check form-switch mb-0">
                            <input class="form-check-input" type="checkbox" checked>
                        </div>
                    </div>
                    <div class="notification-row">
                        <span>Sound notifications</span>
                        <div class="form-check form-switch mb-0">
                            <input class="form-check-input" type="checkbox">
                        </div>
                    </div>
                    <div class="notification-row">
                        <span>Badge counter</span>
                        <div class="form-check form-switch mb-0">
                            <input class="form-check-input" type="checkbox" checked>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Appearance Tab -->
        <div class="tab-pane fade" id="tab-appearance" role="tabpanel">
            <div class="glass-card glass-card-body d-flex flex-column gap-0">
                <!-- Theme Mode -->
                <div>
                    <h5 class="card-header-title">Theme Mode</h5>
                    <div class="row g-3">
                        <div class="col-4">
                            <div class="theme-mode-card selected" data-mode="light">
                                <i data-feather="sun"></i>
                                <span class="mode-label">Light</span>
                            </div>
                        </div>
                        <div class="col-4">
                            <div class="theme-mode-card" data-mode="dark">
                                <i data-feather="moon"></i>
                                <span class="mode-label">Dark</span>
                            </div>
                        </div>
                        <div class="col-4">
                            <div class="theme-mode-card" data-mode="system">
                                <i data-feather="monitor"></i>
                                <span class="mode-label">System</span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="glass-divider my-4"></div>

                <!-- Color Preset -->
                <div>
                    <h5 class="card-header-title">Color Preset</h5>
                    <div class="d-flex flex-wrap le-gap-16">
                        <div class="text-center">
                            <div class="color-preset preset-default selected" data-color="default" title="Default"></div>
                            <div class="small mt-1 le-opacity-70">Default</div>
                        </div>
                        <div class="text-center">
                            <div class="color-preset preset-ocean" data-color="ocean" title="Ocean"></div>
                            <div class="small mt-1 le-opacity-70">Ocean</div>
                        </div>
                        <div class="text-center">
                            <div class="color-preset preset-sunset" data-color="sunset" title="Sunset"></div>
                            <div class="small mt-1 le-opacity-70">Sunset</div>
                        </div>
                        <div class="text-center">
                            <div class="color-preset preset-forest" data-color="forest" title="Forest"></div>
                            <div class="small mt-1 le-opacity-70">Forest</div>
                        </div>
                        <div class="text-center">
                            <div class="color-preset preset-berry" data-color="berry" title="Berry"></div>
                            <div class="small mt-1 le-opacity-70">Berry</div>
                        </div>
                        <div class="text-center">
                            <div class="color-preset preset-slate" data-color="slate" title="Slate"></div>
                            <div class="small mt-1 le-opacity-70">Slate</div>
                        </div>
                    </div>
                </div>

                <div class="glass-divider my-4"></div>

                <!-- Density -->
                <div>
                    <h5 class="card-header-title">Density</h5>
                    <div class="settings-radio d-flex flex-column gap-2">
                        <div class="form-check density-option" data-density="comfortable">
                            <input class="form-check-input" type="radio" name="density" id="density-comfortable">
                            <label class="form-check-label" for="density-comfortable">
                                <div class="fw-semibold">Comfortable</div>
                                <div class="small le-opacity-60">More spacing between elements</div>
                            </label>
                        </div>
                        <div class="form-check density-option selected" data-density="default">
                            <input class="form-check-input" type="radio" name="density" id="density-default" checked>
                            <label class="form-check-label" for="density-default">
                                <div class="fw-semibold">Default</div>
                                <div class="small le-opacity-60">Standard spacing</div>
                            </label>
                        </div>
                        <div class="form-check density-option" data-density="compact">
                            <input class="form-check-input" type="radio" name="density" id="density-compact">
                            <label class="form-check-label" for="density-compact">
                                <div class="fw-semibold">Compact</div>
                                <div class="small le-opacity-60">Reduced spacing for more content</div>
                            </label>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Integrations Tab -->
        <div class="tab-pane fade" id="tab-integrations" role="tabpanel">
            <div class="glass-card">
                <h5 class="card-header-title">Connected Apps</h5>

                <div class="integration-item">
                    <div class="integration-icon le-bg-primary-20 le-text-primary"><i data-feather="hash" class="le-icon-22"></i></div>
                    <div class="integration-details">
                        <div class="app-name">Slack <span class="badge bg-success badge-status">Connected</span></div>
                        <div class="app-desc">Receive notifications in your Slack workspace</div>
                    </div>
                    <button class="btn btn-sm btn-outline-danger flex-shrink-0">Disconnect</button>
                </div>

                <div class="integration-item">
                    <div class="integration-icon le-bg-glass-subtle le-text-muted"><i data-feather="github" class="le-icon-22"></i></div>
                    <div class="integration-details">
                        <div class="app-name">GitHub <span class="badge bg-success badge-status">Connected</span></div>
                        <div class="app-desc">Sync repositories and manage deployments</div>
                    </div>
                    <button class="btn btn-sm btn-outline-danger flex-shrink-0">Disconnect</button>
                </div>

                <div class="integration-item">
                    <div class="integration-icon le-bg-primary-20 le-text-primary"><i data-feather="mail" class="le-icon-22"></i></div>
                    <div class="integration-details">
                        <div class="app-name">Google Workspace <span class="badge bg-secondary badge-status">Not Connected</span></div>
                        <div class="app-desc">Import contacts and calendar events</div>
                    </div>
                    <button class="btn btn-sm btn-primary flex-shrink-0">Connect</button>
                </div>

                <div class="integration-item">
                    <div class="integration-icon le-bg-primary-20 le-text-primary"><i data-feather="droplet" class="le-icon-22"></i></div>
                    <div class="integration-details">
                        <div class="app-name">Dropbox <span class="badge bg-secondary badge-status">Not Connected</span></div>
                        <div class="app-desc">Sync files and documents</div>
                    </div>
                    <button class="btn btn-sm btn-primary flex-shrink-0">Connect</button>
                </div>

                <div class="integration-item">
                    <div class="integration-icon le-bg-primary-20 le-text-primary"><i data-feather="check-square" class="le-icon-22"></i></div>
                    <div class="integration-details">
                        <div class="app-name">Jira <span class="badge bg-success badge-status">Connected</span></div>
                        <div class="app-desc">Track issues and project progress</div>
                    </div>
                    <button class="btn btn-sm btn-outline-danger flex-shrink-0">Disconnect</button>
                </div>
            </div>
        </div>

    </div>
    </div>
</div>
</div>

{% endblock %}

{% block scripts %}
<script>
        // Initialize feather icons
        if (typeof feather !== 'undefined') feather.replace();

        // 2FA toggle enables/disables setup button
        var tfaToggle = document.getElementById('tfa-toggle');
        var setup2faBtn = document.getElementById('setup2fa-btn');
        if (tfaToggle && setup2faBtn) {
            tfaToggle.addEventListener('change', function() {
                setup2faBtn.disabled = !this.checked;
            });
        }

        // Theme mode selection
        document.querySelectorAll('.theme-mode-card').forEach(function(card) {
            card.addEventListener('click', function() {
                document.querySelectorAll('.theme-mode-card').forEach(function(c) { c.classList.remove('selected'); });
                this.classList.add('selected');
            });
        });

        // Color preset selection
        document.querySelectorAll('.color-preset').forEach(function(preset) {
            preset.addEventListener('click', function() {
                document.querySelectorAll('.color-preset').forEach(function(p) { p.classList.remove('selected'); });
                this.classList.add('selected');
            });
        });

        // Density selection
        document.querySelectorAll('.density-option').forEach(function(option) {
            option.addEventListener('click', function() {
                document.querySelectorAll('.density-option').forEach(function(o) { o.classList.remove('selected'); });
                this.classList.add('selected');
                this.querySelector('input[type="radio"]').checked = true;
            });
        });
</script>
{% endblock %}
