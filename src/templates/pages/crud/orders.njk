{% set root = "../../" %}
{% extends "layouts/dashboard.njk" %}


{% block content %}

<div class="orders-page">

<div class="page-header">
    <h1>Orders Management</h1>
    <p>Manage and track all customer orders</p>
</div>

<!-- Toolbar -->
<div class="toolbar-glass">
    <input type="text" class="form-control toolbar-search" id="searchInput" placeholder="Search orders...">
    <select class="form-select toolbar-filter" id="statusFilter">
        <option value="">All Statuses</option>
        <option value="Processing">Processing</option>
        <option value="Shipped">Shipped</option>
        <option value="Completed">Completed</option>
        <option value="Cancelled">Cancelled</option>
        <option value="Refunded">Refunded</option>
    </select>
    <input type="date" class="form-control toolbar-date" id="dateFrom" title="From date">
    <input type="date" class="form-control toolbar-date" id="dateTo" title="To date">
    <div class="ms-auto d-flex gap-2">
        <button class="btn btn-outline-secondary" id="exportBtn"><i data-feather="download" class="le-icon-16"></i> Export CSV</button>
        <button class="btn btn-primary" id="addOrderBtn"><i data-feather="plus" class="le-icon-16"></i> Add Order</button>
    </div>
</div>

<!-- Table view -->
<div class="glass-card p-0">
    <div class="table-glass-wrapper">
        <table class="table table-glass" id="ordersTable">
            <thead>
                <tr>
                    <th data-sort="id">Order ID <span class="sort-icon">↕</span></th>
                    <th data-sort="customer">Customer <span class="sort-icon">↕</span></th>
                    <th data-sort="products">Products <span class="sort-icon">↕</span></th>
                    <th data-sort="date">Date <span class="sort-icon">↕</span></th>
                    <th data-sort="amount">Amount <span class="sort-icon">↕</span></th>
                    <th data-sort="payment">Payment <span class="sort-icon">↕</span></th>
                    <th data-sort="status">Status <span class="sort-icon">↕</span></th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody id="tableBody"></tbody>
        </table>
    </div>

    <!-- Pagination -->
    <div class="pagination-wrapper">
        <span class="pagination-info" id="paginationInfo">Showing 1-10 of 20 orders</span>
        <nav>
            <ul class="pagination" id="paginationList"></ul>
        </nav>
    </div>
</div>

<!-- Card view (mobile) -->
<div class="cards-container" id="cardsContainer"></div>

<!-- Add/Edit Order Modal -->
<div class="modal fade modal-glass" id="orderModal" tabindex="-1" aria-labelledby="orderModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="orderModalLabel">Add Order</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="orderForm">
                    <input type="hidden" id="editOrderId">
                    <div class="mb-3">
                        <label for="formCustomer" class="form-label">Customer Name</label>
                        <input type="text" class="form-control" id="formCustomer" required>
                    </div>
                    <div class="mb-3">
                        <label for="formProducts" class="form-label">Products Count</label>
                        <input type="number" class="form-control" id="formProducts" min="1" required>
                    </div>
                    <div class="mb-3">
                        <label for="formAmount" class="form-label">Amount ($)</label>
                        <input type="number" class="form-control" id="formAmount" step="0.01" min="0" required>
                    </div>
                    <div class="mb-3">
                        <label for="formPayment" class="form-label">Payment Method</label>
                        <select class="form-select" id="formPayment" required>
                            <option value="Credit Card">Credit Card</option>
                            <option value="PayPal">PayPal</option>
                            <option value="Bank Transfer">Bank Transfer</option>
                            <option value="Apple Pay">Apple Pay</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label for="formStatus" class="form-label">Status</label>
                        <select class="form-select" id="formStatus" required>
                            <option value="Processing">Processing</option>
                            <option value="Shipped">Shipped</option>
                            <option value="Completed">Completed</option>
                            <option value="Cancelled">Cancelled</option>
                            <option value="Refunded">Refunded</option>
                        </select>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="saveOrderBtn">Save Order</button>
            </div>
        </div>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade modal-glass" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="deleteModalLabel">Confirm Deletion</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="mb-0">Are you sure you want to delete order <strong id="deleteOrderId"></strong>? This action cannot be undone.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger" id="confirmDeleteBtn">Delete</button>
            </div>
        </div>
    </div>
</div>

<!-- View Order Modal -->
<div class="modal fade modal-glass" id="viewModal" tabindex="-1" aria-labelledby="viewModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="viewModalLabel">Order Details</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="viewModalBody"></div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

</div>
{% endblock %}

{% block scripts %}
<script>
    (function() {
        'use strict';

        // ---- Data ----
        let ordersData = [
            { id: 'ORD-2024-001', customer: 'Sarah Johnson',      products: 3, date: '2024-12-15', amount: 245.99,  payment: 'Credit Card',    status: 'Completed'  },
            { id: 'ORD-2024-002', customer: 'Michael Chen',        products: 1, date: '2024-12-14', amount: 89.50,   payment: 'PayPal',         status: 'Shipped'    },
            { id: 'ORD-2024-003', customer: 'Emily Davis',         products: 5, date: '2024-12-14', amount: 432.00,  payment: 'Credit Card',    status: 'Processing' },
            { id: 'ORD-2024-004', customer: 'James Wilson',        products: 2, date: '2024-12-13', amount: 167.25,  payment: 'Bank Transfer',  status: 'Processing' },
            { id: 'ORD-2024-005', customer: 'Lisa Anderson',       products: 4, date: '2024-12-12', amount: 578.99,  payment: 'Apple Pay',      status: 'Completed'  },
            { id: 'ORD-2024-006', customer: 'Robert Taylor',       products: 1, date: '2024-12-11', amount: 34.99,   payment: 'Credit Card',    status: 'Cancelled'  },
            { id: 'ORD-2024-007', customer: 'Amanda Martinez',     products: 3, date: '2024-12-10', amount: 299.00,  payment: 'PayPal',         status: 'Shipped'    },
            { id: 'ORD-2024-008', customer: 'David Brown',         products: 2, date: '2024-12-09', amount: 156.50,  payment: 'Credit Card',    status: 'Completed'  },
            { id: 'ORD-2024-009', customer: 'Jennifer Lee',        products: 6, date: '2024-12-08', amount: 723.75,  payment: 'Bank Transfer',  status: 'Processing' },
            { id: 'ORD-2024-010', customer: 'Thomas White',        products: 1, date: '2024-12-07', amount: 45.00,   payment: 'Apple Pay',      status: 'Refunded'   },
            { id: 'ORD-2024-011', customer: 'Maria Garcia',        products: 2, date: '2024-12-06', amount: 198.25,  payment: 'Credit Card',    status: 'Shipped'    },
            { id: 'ORD-2024-012', customer: 'Christopher Hall',    products: 4, date: '2024-12-05', amount: 467.80,  payment: 'PayPal',         status: 'Completed'  },
            { id: 'ORD-2024-013', customer: 'Jessica Clark',       products: 1, date: '2024-12-04', amount: 72.99,   payment: 'Bank Transfer',  status: 'Cancelled'  },
            { id: 'ORD-2024-014', customer: 'Daniel Lewis',        products: 3, date: '2024-12-03', amount: 334.50,  payment: 'Credit Card',    status: 'Processing' },
            { id: 'ORD-2024-015', customer: 'Ashley Robinson',     products: 2, date: '2024-12-02', amount: 189.00,  payment: 'PayPal',         status: 'Shipped'    },
            { id: 'ORD-2024-016', customer: 'Matthew Walker',      products: 5, date: '2024-12-01', amount: 612.25,  payment: 'Apple Pay',      status: 'Completed'  },
            { id: 'ORD-2024-017', customer: 'Stephanie Young',     products: 1, date: '2024-11-30', amount: 28.99,   payment: 'Credit Card',    status: 'Refunded'   },
            { id: 'ORD-2024-018', customer: 'Andrew King',         products: 3, date: '2024-11-29', amount: 387.00,  payment: 'Bank Transfer',  status: 'Completed'  },
            { id: 'ORD-2024-019', customer: 'Nicole Wright',       products: 2, date: '2024-11-28', amount: 143.75,  payment: 'PayPal',         status: 'Completed'  },
            { id: 'ORD-2024-020', customer: 'Kevin Scott',         products: 4, date: '2024-11-27', amount: 521.50,  payment: 'Apple Pay',      status: 'Processing' }
        ];

        let nextOrderNum = 21;
        let currentPage = 1;
        const perPage = 10;
        let sortField = 'id';
        let sortDir = 'asc';
        let deleteTargetId = null;

        // ---- DOM refs ----
        const searchInput    = document.getElementById('searchInput');
        const statusFilter   = document.getElementById('statusFilter');
        const dateFrom       = document.getElementById('dateFrom');
        const dateTo         = document.getElementById('dateTo');
        const tableBody      = document.getElementById('tableBody');
        const cardsContainer = document.getElementById('cardsContainer');
        const paginationInfo = document.getElementById('paginationInfo');
        const paginationList = document.getElementById('paginationList');

        const orderModal     = new bootstrap.Modal(document.getElementById('orderModal'));
        const deleteModal    = new bootstrap.Modal(document.getElementById('deleteModal'));
        const viewModal      = new bootstrap.Modal(document.getElementById('viewModal'));

        // ---- Helpers ----
        function getInitials(name) {
            return name.split(' ').map(function(w){ return w[0]; }).join('').toUpperCase();
        }

        function statusBadgeClass(status) {
            var map = { Processing: 'info', Shipped: 'primary', Completed: 'success', Cancelled: 'danger', Refunded: 'warning' };
            return 'badge badge-status bg-' + (map[status] || 'secondary');
        }

        function formatCurrency(n) {
            return '$' + Number(n).toFixed(2);
        }

        function formatDate(d) {
            var parts = d.split('-');
            return parts[1] + '/' + parts[2] + '/' + parts[0];
        }

        // ---- Filtering ----
        function getFilteredData() {
            var search = searchInput.value.toLowerCase().trim();
            var status = statusFilter.value;
            var from   = dateFrom.value;
            var to     = dateTo.value;

            return ordersData.filter(function(o) {
                if (status && o.status !== status) return false;
                if (from && o.date < from) return false;
                if (to && o.date > to) return false;
                if (search) {
                    var haystack = (o.id + ' ' + o.customer + ' ' + o.payment + ' ' + o.status + ' ' + o.amount).toLowerCase();
                    if (haystack.indexOf(search) === -1) return false;
                }
                return true;
            });
        }

        // ---- Sorting ----
        function getSortedData(data) {
            var field = sortField;
            var dir = sortDir === 'asc' ? 1 : -1;
            return data.slice().sort(function(a, b) {
                var va = a[field], vb = b[field];
                if (field === 'amount' || field === 'products') {
                    return (va - vb) * dir;
                }
                if (typeof va === 'string') {
                    return va.localeCompare(vb) * dir;
                }
                return 0;
            });
        }

        // ---- Pagination ----
        function paginate(data) {
            var start = (currentPage - 1) * perPage;
            return data.slice(start, start + perPage);
        }

        // ---- Render table ----
        function renderTable() {
            var filtered = getFilteredData();
            var sorted   = getSortedData(filtered);
            var total    = sorted.length;
            var totalPages = Math.max(1, Math.ceil(total / perPage));
            if (currentPage > totalPages) currentPage = totalPages;
            var page = paginate(sorted);

            // Table
            var html = '';
            page.forEach(function(o) {
                html += '<tr>' +
                    '<td><strong>' + o.id + '</strong></td>' +
                    '<td><div class="customer-cell"><div class="avatar-sm-table">' + getInitials(o.customer) + '</div><span>' + o.customer + '</span></div></td>' +
                    '<td>' + o.products + '</td>' +
                    '<td>' + formatDate(o.date) + '</td>' +
                    '<td>' + formatCurrency(o.amount) + '</td>' +
                    '<td>' + o.payment + '</td>' +
                    '<td><span class="' + statusBadgeClass(o.status) + '">' + o.status + '</span></td>' +
                    '<td><div class="action-btns">' +
                        '<button class="btn btn-sm btn-outline-info" onclick="viewOrder(\'' + o.id + '\')" title="View"><i data-feather="eye"></i></button>' +
                        '<button class="btn btn-sm btn-outline-warning" onclick="editOrder(\'' + o.id + '\')" title="Edit"><i data-feather="edit-2"></i></button>' +
                        '<button class="btn btn-sm btn-outline-danger" onclick="deleteOrder(\'' + o.id + '\')" title="Delete"><i data-feather="trash-2"></i></button>' +
                    '</div></td>' +
                '</tr>';
            });
            tableBody.innerHTML = html;

            // Update sort indicators
            document.querySelectorAll('#ordersTable thead th[data-sort]').forEach(function(th) {
                var f = th.getAttribute('data-sort');
                th.classList.toggle('sort-active', f === sortField);
                var icon = th.querySelector('.sort-icon');
                if (f === sortField) {
                    icon.textContent = sortDir === 'asc' ? '↑' : '↓';
                } else {
                    icon.textContent = '↕';
                }
            });

            renderCards(page);
            renderPagination(total, totalPages);
            if (typeof feather !== 'undefined') feather.replace();
        }

        // ---- Render cards (mobile) ----
        function renderCards(page) {
            var html = '';
            page.forEach(function(o) {
                html += '<div class="order-card-glass">' +
                    '<div class="card-header-row"><strong>' + o.id + '</strong><span class="' + statusBadgeClass(o.status) + '">' + o.status + '</span></div>' +
                    '<div class="card-field"><span class="card-field-label">Customer</span><span>' + o.customer + '</span></div>' +
                    '<div class="card-field"><span class="card-field-label">Amount</span><span>' + formatCurrency(o.amount) + '</span></div>' +
                    '<div class="card-field"><span class="card-field-label">Date</span><span>' + formatDate(o.date) + '</span></div>' +
                    '<div class="card-field"><span class="card-field-label">Payment</span><span>' + o.payment + '</span></div>' +
                    '<div class="card-actions">' +
                        '<button class="btn btn-sm btn-outline-info" onclick="viewOrder(\'' + o.id + '\')"><i data-feather="eye"></i> View</button>' +
                        '<button class="btn btn-sm btn-outline-warning" onclick="editOrder(\'' + o.id + '\')"><i data-feather="edit-2"></i> Edit</button>' +
                        '<button class="btn btn-sm btn-outline-danger" onclick="deleteOrder(\'' + o.id + '\')"><i data-feather="trash-2"></i> Delete</button>' +
                    '</div>' +
                '</div>';
            });
            cardsContainer.innerHTML = html;
        }

        // ---- Render pagination ----
        function renderPagination(total, totalPages) {
            var start = total === 0 ? 0 : (currentPage - 1) * perPage + 1;
            var end   = Math.min(currentPage * perPage, total);
            paginationInfo.textContent = 'Showing ' + start + '-' + end + ' of ' + total + ' orders';

            var html = '<li class="page-item ' + (currentPage <= 1 ? 'disabled' : '') + '">' +
                '<a class="page-link" href="javascript:void(0)" data-page="prev">Previous</a></li>';
            for (var i = 1; i <= totalPages; i++) {
                html += '<li class="page-item ' + (i === currentPage ? 'active' : '') + '">' +
                    '<a class="page-link" href="javascript:void(0)" data-page="' + i + '">' + i + '</a></li>';
            }
            html += '<li class="page-item ' + (currentPage >= totalPages ? 'disabled' : '') + '">' +
                '<a class="page-link" href="javascript:void(0)" data-page="next">Next</a></li>';
            paginationList.innerHTML = html;
        }

        // ---- Pagination clicks ----
        paginationList.addEventListener('click', function(e) {
            e.preventDefault();
            var target = e.target.closest('.page-link');
            if (!target) return;
            var p = target.getAttribute('data-page');
            if (p === 'prev') { if (currentPage > 1) currentPage--; }
            else if (p === 'next') {
                var total = getFilteredData().length;
                var totalPages = Math.max(1, Math.ceil(total / perPage));
                if (currentPage < totalPages) currentPage++;
            }
            else { currentPage = parseInt(p); }
            renderTable();
        });

        // ---- Sorting clicks ----
        document.querySelectorAll('#ordersTable thead th[data-sort]').forEach(function(th) {
            th.addEventListener('click', function() {
                var field = th.getAttribute('data-sort');
                if (sortField === field) {
                    sortDir = sortDir === 'asc' ? 'desc' : 'asc';
                } else {
                    sortField = field;
                    sortDir = 'asc';
                }
                currentPage = 1;
                renderTable();
            });
        });

        // ---- Filter events ----
        searchInput.addEventListener('input', function() { currentPage = 1; renderTable(); });
        statusFilter.addEventListener('change', function() { currentPage = 1; renderTable(); });
        dateFrom.addEventListener('change', function() { currentPage = 1; renderTable(); });
        dateTo.addEventListener('change', function() { currentPage = 1; renderTable(); });

        // ---- CSV Export ----
        document.getElementById('exportBtn').addEventListener('click', function() {
            var filtered = getSortedData(getFilteredData());
            var csv = 'Order ID,Customer,Products,Date,Amount,Payment Method,Status\n';
            filtered.forEach(function(o) {
                csv += '"' + o.id + '","' + o.customer + '",' + o.products + ',' + o.date + ',' + o.amount + ',"' + o.payment + '","' + o.status + '"\n';
            });
            var blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
            var link = document.createElement('a');
            link.href = URL.createObjectURL(blob);
            link.download = 'orders_export.csv';
            link.click();
            URL.revokeObjectURL(link.href);
        });

        // ---- Add Order ----
        document.getElementById('addOrderBtn').addEventListener('click', function() {
            document.getElementById('orderModalLabel').textContent = 'Add Order';
            document.getElementById('editOrderId').value = '';
            document.getElementById('orderForm').reset();
            orderModal.show();
        });

        // ---- Save Order (Add/Edit) ----
        document.getElementById('saveOrderBtn').addEventListener('click', function() {
            var form = document.getElementById('orderForm');
            if (!form.checkValidity()) { form.reportValidity(); return; }

            var customer = document.getElementById('formCustomer').value.trim();
            var products = parseInt(document.getElementById('formProducts').value);
            var amount   = parseFloat(document.getElementById('formAmount').value);
            var payment  = document.getElementById('formPayment').value;
            var status   = document.getElementById('formStatus').value;
            var editId   = document.getElementById('editOrderId').value;

            if (editId) {
                var order = ordersData.find(function(o) { return o.id === editId; });
                if (order) {
                    order.customer = customer;
                    order.products = products;
                    order.amount   = amount;
                    order.payment  = payment;
                    order.status   = status;
                }
            } else {
                var numStr = String(nextOrderNum).padStart(3, '0');
                ordersData.push({
                    id: 'ORD-2024-' + numStr,
                    customer: customer,
                    products: products,
                    date: new Date().toISOString().split('T')[0],
                    amount: amount,
                    payment: payment,
                    status: status
                });
                nextOrderNum++;
            }

            orderModal.hide();
            renderTable();
        });

        // ---- Edit Order ----
        window.editOrder = function(id) {
            var order = ordersData.find(function(o) { return o.id === id; });
            if (!order) return;
            document.getElementById('orderModalLabel').textContent = 'Edit Order';
            document.getElementById('editOrderId').value = order.id;
            document.getElementById('formCustomer').value = order.customer;
            document.getElementById('formProducts').value = order.products;
            document.getElementById('formAmount').value = order.amount;
            document.getElementById('formPayment').value = order.payment;
            document.getElementById('formStatus').value = order.status;
            orderModal.show();
        };

        // ---- Delete Order ----
        window.deleteOrder = function(id) {
            deleteTargetId = id;
            document.getElementById('deleteOrderId').textContent = id;
            deleteModal.show();
        };

        document.getElementById('confirmDeleteBtn').addEventListener('click', function() {
            if (deleteTargetId) {
                ordersData = ordersData.filter(function(o) { return o.id !== deleteTargetId; });
                deleteTargetId = null;
                deleteModal.hide();
                renderTable();
            }
        });

        // ---- View Order ----
        window.viewOrder = function(id) {
            var order = ordersData.find(function(o) { return o.id === id; });
            if (!order) return;
            var html =
                '<div class="view-detail-row"><span class="view-detail-label">Order ID</span><span class="view-detail-value"><strong>' + order.id + '</strong></span></div>' +
                '<div class="view-detail-row"><span class="view-detail-label">Customer</span><span class="view-detail-value">' + order.customer + '</span></div>' +
                '<div class="view-detail-row"><span class="view-detail-label">Products</span><span class="view-detail-value">' + order.products + ' item' + (order.products !== 1 ? 's' : '') + '</span></div>' +
                '<div class="view-detail-row"><span class="view-detail-label">Date</span><span class="view-detail-value">' + formatDate(order.date) + '</span></div>' +
                '<div class="view-detail-row"><span class="view-detail-label">Amount</span><span class="view-detail-value">' + formatCurrency(order.amount) + '</span></div>' +
                '<div class="view-detail-row"><span class="view-detail-label">Payment Method</span><span class="view-detail-value">' + order.payment + '</span></div>' +
                '<div class="view-detail-row"><span class="view-detail-label">Status</span><span class="view-detail-value"><span class="' + statusBadgeClass(order.status) + '">' + order.status + '</span></span></div>';
            document.getElementById('viewModalBody').innerHTML = html;
            document.getElementById('viewModalLabel').textContent = 'Order Details — ' + order.id;
            viewModal.show();
        };

        // ---- Initial render ----
        renderTable();
    })();
</script>
{% endblock %}
