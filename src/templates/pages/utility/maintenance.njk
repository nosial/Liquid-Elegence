{% set root = "../../" %}
{% extends "layouts/error.njk" %}

{% block body_attrs %} class="error-page page-maintenance"{% endblock %}

{% block body %}
<div class="mesh-bg"></div>
    <div class="glass-orb"></div>
    <div class="glass-orb"></div>
    <div class="glass-orb"></div>
    <div class="glass-orb"></div>

    <div class="page-content">
        <div class="gear-icon">
            <div class="gear-glass">
                <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="3"/>
                    <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/>
                </svg>
            </div>
        </div>

        <h1 class="page-heading">Under Maintenance</h1>
        <p class="page-subtitle">We're performing scheduled maintenance</p>
        <p class="page-desc">We'll be back shortly. Expected completion time:</p>

        <div class="time-badge">March 17, 2026 at 12:00 PM UTC</div>
        <div class="countdown-text">Time remaining: <span id="mt-countdown">Calculating...</span></div>

        <div class="overall-progress">
            <div class="progress-ring">
                <svg viewBox="0 0 120 120" class="progress-svg" width="72" height="72">
                    <defs>
                        <linearGradient id="progressGrad" x1="0%" y1="0%" x2="100%" y2="100%">
                            <stop offset="0%" stop-color="#60a5fa"/>
                            <stop offset="100%" stop-color="#a78bfa"/>
                        </linearGradient>
                    </defs>
                    <circle cx="60" cy="60" r="52" class="progress-track" fill="none" stroke="rgba(255,255,255,0.08)" stroke-width="8"/>
                    <circle cx="60" cy="60" r="52" class="progress-fill" id="progressFill" fill="none" stroke="url(#progressGrad)" stroke-width="8" stroke-linecap="round" stroke-dasharray="326.73" style="stroke-dashoffset: 163.36;"/>
                </svg>
                <div class="progress-value">60<span>%</span></div>
            </div>
            <div class="progress-info">
                <div class="progress-info-label">Overall Progress</div>
                <div class="progress-info-detail">3 of 5 tasks completed</div>
            </div>
        </div>

        <div class="services-grid">
            <div class="service-card service-up">
                <div class="service-dot"></div>
                <div class="service-name">Web App</div>
                <div class="service-status">Operational</div>
            </div>
            <div class="service-card service-up">
                <div class="service-dot"></div>
                <div class="service-name">API</div>
                <div class="service-status">Operational</div>
            </div>
            <div class="service-card service-degraded">
                <div class="service-dot"></div>
                <div class="service-name">Database</div>
                <div class="service-status">Degraded</div>
            </div>
            <div class="service-card service-down">
                <div class="service-dot"></div>
                <div class="service-name">CDN</div>
                <div class="service-status">Down</div>
            </div>
            <div class="service-card service-up">
                <div class="service-dot"></div>
                <div class="service-name">Email</div>
                <div class="service-status">Operational</div>
            </div>
            <div class="service-card service-degraded">
                <div class="service-dot"></div>
                <div class="service-name">Cache</div>
                <div class="service-status">Degraded</div>
            </div>
        </div>

        <div class="status-card">
            <div class="status-card-title">Status Updates</div>
            <div class="status-item">
                <span class="icon">✅</span>
                <span class="label">Database Migration</span>
                <span class="badge-status badge-completed">Completed</span>
            </div>
            <div class="status-item">
                <span class="icon">✅</span>
                <span class="label">Server Updates</span>
                <span class="badge-status badge-completed">Completed</span>
            </div>
            <div class="status-item">
                <span class="icon">🔄</span>
                <span class="label">Cache Rebuild</span>
                <span class="badge-status badge-progress">In Progress <span class="spinner-sm"></span></span>
            </div>
            <div class="status-item">
                <span class="icon">⏳</span>
                <span class="label">DNS Propagation</span>
                <span class="badge-status badge-pending">Pending</span>
            </div>
            <div class="status-item">
                <span class="icon">⏳</span>
                <span class="label">Final Testing</span>
                <span class="badge-status badge-pending">Pending</span>
            </div>
        </div>

        <div class="announcement-card">
            <div class="announcement-header">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
                <span>Latest Announcement</span>
            </div>
            <p class="announcement-text">We are currently performing scheduled maintenance to upgrade our infrastructure. Some services may experience temporary interruptions. We apologize for any inconvenience.</p>
            <div class="announcement-time">Updated 15 minutes ago</div>
        </div>

        <form class="subscribe-form" id="subForm" onsubmit="return false;">
            <input type="email" placeholder="Subscribe for updates" id="mtEmail" required>
            <button type="submit" class="btn-glass" id="mtSubBtn">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
                Subscribe
            </button>
        </form>
        <div class="subscribe-success" id="mtSuccess">✅ You'll receive updates at your email address.</div>

        <div class="social-links">
            <a href="javascript:void(0)" class="social-link" title="Twitter" aria-label="Twitter">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"/></svg>
            </a>
            <a href="javascript:void(0)" class="social-link" title="GitHub" aria-label="GitHub">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
            </a>
            <a href="javascript:void(0)" class="social-link" title="LinkedIn" aria-label="LinkedIn">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
            </a>
            <a href="javascript:void(0)" class="social-link" title="Instagram" aria-label="Instagram">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
            </a>
        </div>
    </div>
{% endblock %}

{% block scripts %}
<script>
        (function() {
            var target = new Date('2026-03-17T12:00:00Z');
            var countdownEl = document.getElementById('mt-countdown');

            function pad(n) { return n < 10 ? '0' + n : String(n); }

            function updateCountdown() {
                var now = new Date();
                var diff = target - now;
                if (diff <= 0) {
                    countdownEl.textContent = 'Maintenance complete!';
                    return;
                }
                var d = Math.floor(diff / 86400000);
                var h = Math.floor((diff % 86400000) / 3600000);
                var m = Math.floor((diff % 3600000) / 60000);
                var s = Math.floor((diff % 60000) / 1000);
                countdownEl.textContent = d + 'd ' + pad(h) + 'h ' + pad(m) + 'm ' + pad(s) + 's';
            }

            updateCountdown();
            setInterval(updateCountdown, 1000);

            document.getElementById('mtSubBtn').addEventListener('click', function() {
                var email = document.getElementById('mtEmail').value;
                if (email && email.indexOf('@') > 0) {
                    document.getElementById('mtSuccess').classList.add('show');
                    document.getElementById('mtEmail').value = '';
                }
            });
        })();
</script>
{% endblock %}
