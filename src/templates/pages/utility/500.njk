{% set root = "../../" %}
{% extends "layouts/error.njk" %}

{% block body_attrs %} class="error-page page-500"{% endblock %}

{% block error_content %}
<div class="mesh-bg"></div>
    <div class="glass-orb"></div>
    <div class="glass-orb"></div>
    <div class="glass-orb"></div>
    <div class="glass-orb"></div>

    <div class="error-content">
        <div class="warning-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
                <line x1="12" y1="9" x2="12" y2="13"/>
                <line x1="12" y1="17" x2="12.01" y2="17"/>
            </svg>
        </div>

        <div class="error-code">
            <span class="error-code-main">500</span>
            <span class="error-code-glitch" aria-hidden="true">500</span>
        </div>
        <h1 class="error-subtitle">Internal Server Error</h1>
        <p class="error-description">Something went wrong on our end. Our team has been notified and is working to resolve the issue.</p>

        <div class="status-indicator">
            <span class="status-dot" id="statusDot"></span>
            <span id="statusText">System Status: Checking...</span>
        </div>

        <div class="btn-group-actions">
            <a href="../../index.html" class="btn-glass btn-glass-primary">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                Go Home
            </a>
            <button onclick="location.reload()" class="btn-glass btn-glass-outline">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg>
                Retry
            </button>
        </div>

        <div class="quick-actions">
            <a href="mailto:support@example.com" class="action-card">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                <span>Report Issue</span>
            </a>
            <a href="../utility/coming-soon.html" class="action-card">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                <span>Check Status</span>
            </a>
            <a href="../../index.html" class="action-card">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                <span>Go to Dashboard</span>
            </a>
        </div>

        <div class="error-help">
            <p>If this issue persists, please contact our support team with the error details above.</p>
        </div>
    </div>
{% endblock %}

{% block scripts %}
<script>
        setTimeout(function() {
            document.getElementById('statusDot').classList.add('degraded');
            document.getElementById('statusText').textContent = 'System Status: Partially Degraded';
        }, 2000);
</script>
{% endblock %}
