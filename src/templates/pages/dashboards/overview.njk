{% block scripts %}
<script>
document.addEventListener('DOMContentLoaded', function() {
    const chartColors = {
        primary: getComputedStyle(document.documentElement).getPropertyValue('--le-primary').trim() || '#6366f1',
        success: getComputedStyle(document.documentElement).getPropertyValue('--le-success').trim() || '#10b981',
        warning: getComputedStyle(document.documentElement).getPropertyValue('--le-warning').trim() || '#f59e0b',
        info: getComputedStyle(document.documentElement).getPropertyValue('--le-info').trim() || '#06b6d4',
        danger: getComputedStyle(document.documentElement).getPropertyValue('--le-danger').trim() || '#ef4444'
    };

    function createSparkline(id, data, color) {
        const ctx = document.getElementById(id);
        if (!ctx) return;
        new Chart(ctx, {
            type: 'line',
            data: { labels: data.map((_, i) => i), datasets: [{ data, borderColor: color, borderWidth: 2, fill: true, backgroundColor: color + '20', tension: 0.4, pointRadius: 0 }] },
            options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { x: { display: false }, y: { display: false } } }
        });
    }

    createSparkline('sparkRevenue', [28, 35, 32, 40, 38, 45, 42, 48], chartColors.primary);
    createSparkline('sparkOrders', [120, 145, 135, 160, 155, 170, 165, 185], chartColors.success);
    createSparkline('sparkUsers', [8200, 8800, 9100, 9600, 10200, 11000, 11800, 12459], chartColors.info);
    createSparkline('sparkConversion', [3.8, 3.6, 3.5, 3.4, 3.3, 3.28, 3.26, 3.24], chartColors.warning);

    // Revenue Chart
    const revenueCtx = document.getElementById('revenueChart');
    if (revenueCtx) {
        new Chart(revenueCtx, {
            type: 'bar',
            data: {
                labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'],
                datasets: [{
                    label: 'Revenue',
                    data: [18500, 22300, 19800, 25400, 28100, 24600, 31200, 29800, 35400, 38200, 42100, 48295],
                    backgroundColor: chartColors.primary + '80',
                    borderColor: chartColors.primary,
                    borderWidth: 1,
                    borderRadius: 6
                }, {
                    label: 'Profit',
                    data: [8200, 10500, 9100, 12800, 13200, 11400, 15600, 14200, 17800, 19500, 21200, 24100],
                    backgroundColor: chartColors.success + '80',
                    borderColor: chartColors.success,
                    borderWidth: 1,
                    borderRadius: 6
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { position: 'top' } },
                scales: { y: { beginAtZero: true, ticks: { callback: v => '$' + (v/1000) + 'k' } } }
            }
        });
    }

    // Traffic Chart
    const trafficCtx = document.getElementById('trafficChart');
    if (trafficCtx) {
        new Chart(trafficCtx, {
            type: 'doughnut',
            data: {
                labels: ['Direct', 'Organic', 'Referral', 'Social'],
                datasets: [{ data: [42, 28, 18, 12], backgroundColor: [chartColors.primary, chartColors.success, chartColors.warning, chartColors.info], borderWidth: 0 }]
            },
            options: { responsive: true, maintainAspectRatio: false, cutout: '70%', plugins: { legend: { display: false } } }
        });
    }
});
</script>
{% endblock %}
