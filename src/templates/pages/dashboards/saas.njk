{% set root = "../../" %}
{% extends "layouts/dashboard.njk" %}

{% block title %}SaaS — Liquid Elegance{% endblock %}

{% block scripts_before %}
<script src="{{ asset_root or root }}vendor/chart.js/chart.min.js"></script>
{% endblock %}

{% block content %}
<!-- Breadcrumb -->
<nav aria-label="breadcrumb" class="mb-3">
  <ol class="breadcrumb mb-0">
    <li class="breadcrumb-item"><a href="javascript:void(0)">Dashboards</a></li>
    <li class="breadcrumb-item active" aria-current="page">SaaS</li>
  </ol>
</nav>

<!-- Page Header -->
<div class="mb-4">
  <h1 class="h3 mb-1">SaaS</h1>
  <p class="text-muted mb-0">Monitor your subscription metrics</p>
</div>

<!-- Metric Cards -->
<div class="row g-4 mb-4">
  <div class="col-sm-6 col-xl-3">
    <div class="glass-card metric-card glass-card-animated">
      <div class="glass-card-body">
        <div class="d-flex justify-content-between align-items-start">
          <div>
            <p class="metric-label text-muted mb-1">MRR</p>
            <h3 class="metric-value mb-1">$38,450</h3>
            <span class="metric-change text-success"><i data-feather="trending-up"></i> +7.2%</span>
          </div>
          <div class="metric-icon bg-primary-subtle">
            <i data-feather="dollar-sign"></i>
          </div>
        </div>
        <div class="chart-wrapper le-chart-60"><canvas id="saasSparkMRR" height="60"></canvas></div>
      </div>
    </div>
  </div>
  <div class="col-sm-6 col-xl-3">
    <div class="glass-card metric-card glass-card-animated">
      <div class="glass-card-body">
        <div class="d-flex justify-content-between align-items-start">
          <div>
            <p class="metric-label text-muted mb-1">Annual Churn</p>
            <h3 class="metric-value mb-1">4.2%</h3>
            <span class="metric-change text-success"><i data-feather="trending-down"></i> -0.8%</span>
          </div>
          <div class="metric-icon bg-danger-subtle">
            <i data-feather="user-minus"></i>
          </div>
        </div>
        <div class="chart-wrapper le-chart-60"><canvas id="saasSparkChurn" height="60"></canvas></div>
      </div>
    </div>
  </div>
  <div class="col-sm-6 col-xl-3">
    <div class="glass-card metric-card glass-card-animated">
      <div class="glass-card-body">
        <div class="d-flex justify-content-between align-items-start">
          <div>
            <p class="metric-label text-muted mb-1">Active Subscribers</p>
            <h3 class="metric-value mb-1">2,847</h3>
            <span class="metric-change text-success"><i data-feather="trending-up"></i> +12.3%</span>
          </div>
          <div class="metric-icon bg-success-subtle">
            <i data-feather="users"></i>
          </div>
        </div>
        <div class="chart-wrapper le-chart-60"><canvas id="saasSparkSubs" height="60"></canvas></div>
      </div>
    </div>
  </div>
  <div class="col-sm-6 col-xl-3">
    <div class="glass-card metric-card glass-card-animated">
      <div class="glass-card-body">
        <div class="d-flex justify-content-between align-items-start">
          <div>
            <p class="metric-label text-muted mb-1">ARPU</p>
            <h3 class="metric-value mb-1">$13.50</h3>
            <span class="metric-change text-success"><i data-feather="trending-up"></i> +3.1%</span>
          </div>
          <div class="metric-icon bg-info-subtle">
            <i data-feather="bar-chart-2"></i>
          </div>
        </div>
        <div class="chart-wrapper le-chart-60"><canvas id="saasSparkARPU" height="60"></canvas></div>
      </div>
    </div>
  </div>
</div>

<!-- MRR Growth Chart -->
<div class="row g-4 mb-4">
  <div class="col-12">
    <div class="glass-card">
      <div class="glass-card-header d-flex justify-content-between align-items-center">
        <h5 class="glass-card-title mb-0">MRR Growth</h5>
        <div class="btn-group btn-group-sm" role="group">
          <button type="button" class="btn btn-outline-primary">6M</button>
          <button type="button" class="btn btn-outline-primary active">12M</button>
          <button type="button" class="btn btn-outline-primary">All</button>
        </div>
      </div>
      <div class="glass-card-body">
        <div class="chart-wrapper le-chart-320"><canvas id="mrrChart" height="320"></canvas></div>
      </div>
    </div>
  </div>
</div>

<!-- Subscription Breakdown & Churn Analysis -->
