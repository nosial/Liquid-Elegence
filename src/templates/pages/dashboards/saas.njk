            <div class="d-flex align-items-center gap-2">
              <i data-feather="shield" class="text-warning le-icon-18"></i>
              <span class="fw-medium">Enterprise</span>
              <span class="badge bg-warning bg-opacity-10 text-warning">$99/mo</span>
            </div>
            <div class="text-end">
              <span class="fw-semibold">207</span>
              <span class="text-muted small ms-1">users</span>
            </div>
          </div>
          <div class="progress le-h-8 progress-shimmer">
            <div class="progress-bar" role="progressbar" style="width:7.3%;background:var(--le-warning,#f59e0b);"></div>
          </div>
          <p class="text-muted small mt-1 mb-0">7.3% of total · $20,493 MRR</p>
        </div>
      </div>
    </div>
  </div>
  <div class="col-lg-6">
    <div class="glass-card h-100">
      <div class="glass-card-header">
        <h5 class="glass-card-title mb-0">Churn Analysis</h5>
      </div>
      <div class="glass-card-body">
        <div class="mb-4">
          <div class="d-flex align-items-center justify-content-between mb-2">
            <span class="fw-medium">Price</span>
            <span class="fw-semibold">35%</span>
          </div>
          <div class="progress le-h-10 progress-shimmer">
            <div class="progress-bar" role="progressbar" style="width:35%;background:var(--le-danger,#ef4444);"></div>
          </div>
        </div>
        <div class="mb-4">
          <div class="d-flex align-items-center justify-content-between mb-2">
            <span class="fw-medium">Missing Features</span>
            <span class="fw-semibold">25%</span>
          </div>
          <div class="progress le-h-10 progress-shimmer">
            <div class="progress-bar" role="progressbar" style="width:25%;background:var(--le-warning,#f59e0b);"></div>
          </div>
        </div>
        <div class="mb-4">
          <div class="d-flex align-items-center justify-content-between mb-2">
            <span class="fw-medium">Support Quality</span>
            <span class="fw-semibold">15%</span>
          </div>
          <div class="progress le-h-10 progress-shimmer">
            <div class="progress-bar" role="progressbar" style="width:15%;background:var(--le-primary,#6366f1);"></div>
          </div>
        </div>
        <div class="mb-4">
          <div class="d-flex align-items-center justify-content-between mb-2">
            <span class="fw-medium">Competitor</span>
            <span class="fw-semibold">15%</span>
          </div>
          <div class="progress le-h-10 progress-shimmer">
            <div class="progress-bar" role="progressbar" style="width:15%;background:var(--le-info,#06b6d4);"></div>
          </div>
        </div>
        <div class="mb-0">
          <div class="d-flex align-items-center justify-content-between mb-2">
            <span class="fw-medium">Other</span>
            <span class="fw-semibold">10%</span>
          </div>
          <div class="progress le-h-10 progress-shimmer">
            <div class="progress-bar" role="progressbar" style="width:10%;background:var(--le-secondary,#94a3b8);"></div>
          </div>
        </div>
        <div class="mt-4 pt-3 border-top">
          <div class="d-flex align-items-center gap-2">
            <i data-feather="info" class="text-muted le-icon-16"></i>
            <span class="text-muted small">Based on 124 exit surveys collected this quarter</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

