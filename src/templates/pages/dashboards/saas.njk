{% block scripts %}
<script>
document.addEventListener('DOMContentLoaded', function () {
  const leStyles = getComputedStyle(document.documentElement);
  const lePrimary = leStyles.getPropertyValue('--le-primary').trim() || '#6366f1';
  const leSuccess = leStyles.getPropertyValue('--le-success').trim() || '#10b981';
  const leDanger  = leStyles.getPropertyValue('--le-danger').trim()  || '#ef4444';
  const leInfo    = leStyles.getPropertyValue('--le-info').trim()    || '#06b6d4';

  function createSparkline(id, data, color) {
    const ctx = document.getElementById(id);
    if (!ctx) return;
    new Chart(ctx, {
      type: 'line',
      data: { labels: data.map((_, i) => i), datasets: [{ data, borderColor: color, borderWidth: 2, fill: true, backgroundColor: color + '20', tension: 0.4, pointRadius: 0 }] },
      options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { x: { display: false }, y: { display: false } } }
    });
  }

  createSparkline('saasSparkMRR', [22, 24, 25, 27, 28, 30, 32, 35], lePrimary);
  createSparkline('saasSparkChurn', [5.8, 5.5, 5.2, 5.0, 4.8, 4.6, 4.4, 4.2], leDanger);
  createSparkline('saasSparkSubs', [1800, 1950, 2050, 2180, 2300, 2450, 2600, 2847], leSuccess);
  createSparkline('saasSparkARPU', [11.2, 11.5, 11.8, 12.1, 12.4, 12.8, 13.1, 13.5], leInfo);

  // MRR Growth chart
  const mrrCtx = document.getElementById('mrrChart');
  if (mrrCtx) {
    new Chart(mrrCtx.getContext('2d'), {
      type: 'line',
      data: {
        labels: ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'],
        datasets: [
          {
            label: 'MRR',
            data: [22400,23800,25100,26500,28200,29800,31400,33100,34600,35900,37200,38450],
            borderColor: lePrimary,
            backgroundColor: lePrimary + '20',
            fill: true,
            tension: 0.4,
            pointRadius: 4,
            pointHoverRadius: 7,
            pointBackgroundColor: lePrimary,
            borderWidth: 2.5
          },
          {
            label: 'New MRR',
            data: [1800,2100,1900,2400,2700,2500,2800,3000,2600,2900,3100,3200],
            borderColor: leSuccess,
            backgroundColor: 'transparent',
            borderDash: [5, 5],
            tension: 0.4,
            pointRadius: 3,
            pointHoverRadius: 6,
            borderWidth: 2
          }
        ]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        interaction: { mode: 'index', intersect: false },
        plugins: { legend: { position: 'top' } },
        scales: {
          x: { grid: { display: false } },
          y: {
            beginAtZero: false,
            grid: { color: 'rgba(148,163,184,0.1)' },
            ticks: { callback: function(v) { return '$' + (v / 1000) + 'k'; } }
          }
        }
      }
    });
  }
  if (typeof feather !== 'undefined') feather.replace();
});
</script>
{% endblock %}
