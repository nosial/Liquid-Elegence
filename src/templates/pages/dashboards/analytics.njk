{% block scripts %}
<script>
document.addEventListener('DOMContentLoaded', function () {
  const leStyles = getComputedStyle(document.documentElement);
  const lePrimary = leStyles.getPropertyValue('--le-primary').trim() || '#6366f1';
  const leInfo    = leStyles.getPropertyValue('--le-info').trim()    || '#06b6d4';
  const leWarning = leStyles.getPropertyValue('--le-warning').trim() || '#f59e0b';
  const leSuccess = leStyles.getPropertyValue('--le-success').trim() || '#10b981';

  function createSparkline(id, data, color) {
    const ctx = document.getElementById(id);
    if (!ctx) return;
    new Chart(ctx, {
      type: 'line',
      data: { labels: data.map((_, i) => i), datasets: [{ data, borderColor: color, borderWidth: 2, fill: true, backgroundColor: color + '20', tension: 0.4, pointRadius: 0 }] },
      options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { x: { display: false }, y: { display: false } } }
    });
  }

  createSparkline('analytSparkVisitors', [18, 20, 19, 22, 21, 24, 23, 25], lePrimary);
  createSparkline('analytSparkPageviews', [62, 68, 65, 72, 70, 78, 82, 89], leInfo);
  createSparkline('analytSparkBounce', [48, 47, 46, 45, 44, 44, 43, 42], leWarning);
  createSparkline('analytSparkSession', [240, 248, 252, 255, 258, 260, 265, 272], leSuccess);

  // Sessions & Visitors area chart
  const sessionsCtx = document.getElementById('sessionsChart');
  if (sessionsCtx) {
    new Chart(sessionsCtx.getContext('2d'), {
      type: 'line',
      data: {
        labels: ['Jan 1','Jan 3','Jan 5','Jan 7','Jan 9','Jan 11','Jan 13','Jan 15','Jan 17','Jan 19','Jan 21','Jan 23','Jan 25','Jan 27','Jan 29','Jan 31'],
        datasets: [
          {
            label: 'Sessions',
            data: [1200,1350,1280,1420,1510,1390,1620,1780,1650,1720,1890,1940,2010,1870,2150,2240],
            borderColor: lePrimary,
            backgroundColor: lePrimary + '22',
            fill: true,
            tension: 0.4,
            pointRadius: 0,
            pointHoverRadius: 5
          },
          {
            label: 'Unique Visitors',
            data: [820,940,870,960,1050,950,1120,1230,1140,1180,1310,1350,1390,1280,1480,1540],
            borderColor: leInfo,
            backgroundColor: leInfo + '22',
            fill: true,
            tension: 0.4,
            pointRadius: 0,
            pointHoverRadius: 5
          }
        ]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        interaction: { mode: 'index', intersect: false },
        plugins: { legend: { position: 'top' } },
        scales: {
          x: { grid: { display: false } },
          y: { beginAtZero: true, grid: { color: 'rgba(148,163,184,0.1)' } }
        }
      }
    });
  }
});
</script>
{% endblock %}
