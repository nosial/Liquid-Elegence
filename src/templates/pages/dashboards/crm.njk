{% block scripts %}
<script>
document.addEventListener('DOMContentLoaded', function () {
  const leStyles = getComputedStyle(document.documentElement);
  const leInfo    = leStyles.getPropertyValue('--le-info').trim()    || '#06b6d4';
  const lePrimary = leStyles.getPropertyValue('--le-primary').trim() || '#6366f1';
  const leWarning = leStyles.getPropertyValue('--le-warning').trim() || '#f59e0b';
  const leSuccess = leStyles.getPropertyValue('--le-success').trim() || '#10b981';
  const leDanger  = leStyles.getPropertyValue('--le-danger').trim()  || '#ef4444';

  function createSparkline(id, data, color) {
    const ctx = document.getElementById(id);
    if (!ctx) return;
    new Chart(ctx, {
      type: 'line',
      data: { labels: data.map((_, i) => i), datasets: [{ data, borderColor: color, borderWidth: 2, fill: true, backgroundColor: color + '20', tension: 0.4, pointRadius: 0 }] },
      options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { x: { display: false }, y: { display: false } } }
    });
  }

  createSparkline('crmSparkContacts', [6.2, 6.5, 6.8, 7.1, 7.0, 7.4, 7.8, 8.5], lePrimary);
  createSparkline('crmSparkDeals', [95, 102, 108, 115, 120, 128, 135, 142], leInfo);
  createSparkline('crmSparkWon', [52, 56, 60, 65, 70, 74, 82, 89], leSuccess);
  createSparkline('crmSparkPipeline', [1.6, 1.7, 1.8, 1.9, 2.0, 2.1, 2.2, 2.4], leWarning);

  // Pipeline funnel chart (horizontal bar)
  const pipeCtx = document.getElementById('pipelineChart');
  if (pipeCtx) {
    new Chart(pipeCtx.getContext('2d'), {
      type: 'bar',
      data: {
        labels: ['Lead','Qualified','Proposal','Negotiation','Closed'],
        datasets: [
          {
            label: 'Deal Count',
            data: [48, 35, 28, 18, 13],
            backgroundColor: [leInfo, lePrimary, leWarning, leSuccess, leDanger],
            borderRadius: 6,
            barPercentage: 0.6
          },
          {
            label: 'Value ($K)',
            data: [520, 680, 490, 420, 290],
            backgroundColor: [leInfo + '55', lePrimary + '55', leWarning + '55', leSuccess + '55', leDanger + '55'],
            borderRadius: 6,
            barPercentage: 0.6,
            yAxisID: 'y1'
          }
        ]
      },
      options: {
        indexAxis: 'y',
        responsive: true,
        maintainAspectRatio: false,
        plugins: { legend: { position: 'top' } },
        scales: {
          x: {
            beginAtZero: true,
            grid: { color: 'rgba(148,163,184,0.1)' }
          },
          y: { grid: { display: false } },
          y1: { display: false }
        }
      }
    });
  }
});
</script>
{% endblock %}
