              <span class="rounded-circle d-inline-block le-legend-dot le-bar-warning"></span>
              <span class="fw-medium">Proposal</span>
            </div>
            <div class="text-end">
              <span class="fw-semibold">28 deals</span>
              <span class="text-muted small d-block">$490,000</span>
            </div>
          </div>
          <div class="progress le-h-8 progress-shimmer">
            <div class="progress-bar" role="progressbar" style="width:58%;background:var(--le-warning,#f59e0b);"></div>
          </div>
        </div>
        <div class="mb-4">
          <div class="d-flex align-items-center justify-content-between mb-2">
            <div class="d-flex align-items-center gap-2">
              <span class="rounded-circle d-inline-block le-legend-dot le-bar-success"></span>
              <span class="fw-medium">Negotiation</span>
            </div>
            <div class="text-end">
              <span class="fw-semibold">18 deals</span>
              <span class="text-muted small d-block">$420,000</span>
            </div>
          </div>
          <div class="progress le-h-8 progress-shimmer">
            <div class="progress-bar" role="progressbar" style="width:38%;background:var(--le-success,#10b981);"></div>
          </div>
        </div>
        <div class="mb-0">
          <div class="d-flex align-items-center justify-content-between mb-2">
            <div class="d-flex align-items-center gap-2">
              <span class="rounded-circle d-inline-block le-legend-dot le-bar-danger"></span>
              <span class="fw-medium">Closed</span>
            </div>
            <div class="text-end">
              <span class="fw-semibold">13 deals</span>
              <span class="text-muted small d-block">$290,000</span>
            </div>
          </div>
          <div class="progress le-h-8 progress-shimmer">
            <div class="progress-bar" role="progressbar" style="width:27%;background:var(--le-danger,#ef4444);"></div>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-lg-7">
    <div class="glass-card h-100">
      <div class="glass-card-header d-flex justify-content-between align-items-center">
        <h5 class="glass-card-title mb-0">Pipeline Funnel</h5>
        <div class="btn-group btn-group-sm" role="group">
          <button type="button" class="btn btn-outline-primary active">This Quarter</button>
          <button type="button" class="btn btn-outline-primary">Last Quarter</button>
        </div>
      </div>
      <div class="glass-card-body">
        <div class="chart-wrapper le-chart-300"><canvas id="pipelineChart" height="300"></canvas></div>
      </div>
    </div>
  </div>
</div>

