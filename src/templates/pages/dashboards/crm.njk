{% set root = "../../" %}
{% extends "layouts/dashboard.njk" %}

{% block title %}CRM — Liquid Elegance{% endblock %}

{% block scripts_before %}
<script src="{{ asset_root or root }}vendor/chart.js/chart.min.js"></script>
{% endblock %}

{% block content %}
<!-- Breadcrumb -->
<nav aria-label="breadcrumb" class="mb-3">
  <ol class="breadcrumb mb-0">
    <li class="breadcrumb-item"><a href="javascript:void(0)">Dashboards</a></li>
    <li class="breadcrumb-item active" aria-current="page">CRM</li>
  </ol>
</nav>

<!-- Page Header -->
<div class="mb-4">
  <h1 class="h3 mb-1">CRM</h1>
  <p class="text-muted mb-0">Manage your contacts and pipeline</p>
</div>

<!-- Metric Cards -->
<div class="row g-4 mb-4">
  <div class="col-sm-6 col-xl-3">
    <div class="glass-card metric-card glass-card-animated">
      <div class="glass-card-body">
        <div class="d-flex justify-content-between align-items-start">
          <div>
            <p class="metric-label text-muted mb-1">Total Contacts</p>
            <h3 class="metric-value mb-1">8,492</h3>
            <span class="metric-change text-success"><i data-feather="trending-up"></i> +6.3%</span>
          </div>
          <div class="metric-icon bg-primary-subtle">
            <i data-feather="users"></i>
          </div>
        </div>
        <div class="chart-wrapper le-chart-60"><canvas id="crmSparkContacts" height="60"></canvas></div>
      </div>
    </div>
  </div>
  <div class="col-sm-6 col-xl-3">
    <div class="glass-card metric-card glass-card-animated">
      <div class="glass-card-body">
        <div class="d-flex justify-content-between align-items-start">
          <div>
            <p class="metric-label text-muted mb-1">Active Deals</p>
            <h3 class="metric-value mb-1">142</h3>
            <span class="metric-change text-success"><i data-feather="trending-up"></i> +15.1%</span>
          </div>
          <div class="metric-icon bg-info-subtle">
            <i data-feather="briefcase"></i>
          </div>
        </div>
        <div class="chart-wrapper le-chart-60"><canvas id="crmSparkDeals" height="60"></canvas></div>
      </div>
    </div>
  </div>
  <div class="col-sm-6 col-xl-3">
    <div class="glass-card metric-card glass-card-animated">
      <div class="glass-card-body">
        <div class="d-flex justify-content-between align-items-start">
          <div>
            <p class="metric-label text-muted mb-1">Won Deals</p>
            <h3 class="metric-value mb-1">89</h3>
            <span class="metric-change text-success"><i data-feather="trending-up"></i> +11.7%</span>
          </div>
          <div class="metric-icon bg-success-subtle">
            <i data-feather="check-circle"></i>
          </div>
        </div>
        <div class="chart-wrapper le-chart-60"><canvas id="crmSparkWon" height="60"></canvas></div>
      </div>
    </div>
  </div>
  <div class="col-sm-6 col-xl-3">
    <div class="glass-card metric-card glass-card-animated">
      <div class="glass-card-body">
        <div class="d-flex justify-content-between align-items-start">
          <div>
            <p class="metric-label text-muted mb-1">Pipeline Value</p>
            <h3 class="metric-value mb-1">$2.4M</h3>
            <span class="metric-change text-success"><i data-feather="trending-up"></i> +8.9%</span>
          </div>
          <div class="metric-icon bg-warning-subtle">
            <i data-feather="dollar-sign"></i>
          </div>
        </div>
        <div class="chart-wrapper le-chart-60"><canvas id="crmSparkPipeline" height="60"></canvas></div>
      </div>
    </div>
  </div>
</div>

<!-- Pipeline Overview & Pipeline Chart -->
<div class="row g-4 mb-4">
  <div class="col-lg-5">
    <div class="glass-card h-100">
