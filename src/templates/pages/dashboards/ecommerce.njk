{% block scripts %}
<script>
document.addEventListener('DOMContentLoaded', function () {
  const leStyles = getComputedStyle(document.documentElement);
  const lePrimary = leStyles.getPropertyValue('--le-primary').trim() || '#6366f1';
  const leSuccess = leStyles.getPropertyValue('--le-success').trim() || '#10b981';
  const leWarning = leStyles.getPropertyValue('--le-warning').trim() || '#f59e0b';
  const leInfo    = leStyles.getPropertyValue('--le-info').trim()    || '#06b6d4';
  const leDanger  = leStyles.getPropertyValue('--le-danger').trim()  || '#ef4444';

  function createSparkline(id, data, color) {
    const ctx = document.getElementById(id);
    if (!ctx) return;
    new Chart(ctx, {
      type: 'line',
      data: { labels: data.map((_, i) => i), datasets: [{ data, borderColor: color, borderWidth: 2, fill: true, backgroundColor: color + '20', tension: 0.4, pointRadius: 0 }] },
      options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { x: { display: false }, y: { display: false } } }
    });
  }

  createSparkline('ecomSparkSales', [28, 32, 30, 36, 34, 40, 42, 48], lePrimary);
  createSparkline('ecomSparkRevenue', [18, 22, 20, 26, 28, 24, 30, 34], leSuccess);
  createSparkline('ecomSparkOrders', [120, 145, 135, 160, 155, 170, 165, 185], leInfo);
  createSparkline('ecomSparkCustomers', [600, 680, 720, 850, 810, 940, 1020, 1140], leWarning);

  // Sales Trend line chart
  const salesCtx = document.getElementById('salesTrendChart');
  if (salesCtx) {
    new Chart(salesCtx.getContext('2d'), {
      type: 'line',
      data: {
        labels: ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'],
        datasets: [
          {
            label: 'Revenue',
            data: [4200,5100,4800,6200,7100,6800,7900,8400,7600,9100,10200,11400],
            borderColor: lePrimary,
            backgroundColor: lePrimary + '18',
            fill: true,
            tension: 0.4,
            pointRadius: 3,
            pointHoverRadius: 6,
            yAxisID: 'y'
          },
          {
            label: 'Orders',
            data: [180,220,210,275,310,295,340,365,330,395,440,480],
            borderColor: leSuccess,
            backgroundColor: 'transparent',
            borderDash: [5, 5],
            tension: 0.4,
            pointRadius: 3,
            pointHoverRadius: 6,
            yAxisID: 'y1'
          }
        ]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        interaction: { mode: 'index', intersect: false },
        plugins: { legend: { position: 'top' } },
        scales: {
          x: { grid: { display: false } },
          y: {
            type: 'linear', position: 'left',
            beginAtZero: true,
            grid: { color: 'rgba(148,163,184,0.1)' },
            ticks: { callback: function(v) { return '$' + (v / 1000) + 'k'; } }
          },
          y1: {
            type: 'linear', position: 'right',
            beginAtZero: true,
            grid: { drawOnChartArea: false }
          }
        }
      }
    });
  }

  // Revenue by Category doughnut chart
  const catCtx = document.getElementById('categoryChart');
  if (catCtx) {
    new Chart(catCtx.getContext('2d'), {
      type: 'doughnut',
      data: {
        labels: ['Electronics','Clothing','Home & Garden','Sports','Other'],
        datasets: [{
          data: [38, 24, 18, 12, 8],
          backgroundColor: [lePrimary, leSuccess, leWarning, leInfo, leDanger],
          borderWidth: 0,
          hoverOffset: 6
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        cutout: '68%',
        plugins: {
          legend: { display: false }
        }
      }
    });
  }
});
</script>
{% endblock %}
