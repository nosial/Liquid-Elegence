            <p class="metric-label text-muted mb-1">Total Sales</p>
            <h3 class="metric-value mb-1">$124,563</h3>
            <span class="metric-change text-success"><i data-feather="trending-up"></i> +18.2%</span>
          </div>
          <div class="metric-icon bg-primary-subtle">
            <i data-feather="shopping-bag"></i>
          </div>
        </div>
        <div class="chart-wrapper le-chart-60"><canvas id="ecomSparkSales" height="60"></canvas></div>
      </div>
    </div>
  </div>
  <div class="col-sm-6 col-xl-3">
    <div class="glass-card metric-card glass-card-animated">
      <div class="glass-card-body">
