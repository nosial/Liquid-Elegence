            <p class="metric-label text-muted mb-1">Customers</p>
            <h3 class="metric-value mb-1">1,249</h3>
            <span class="metric-change text-success"><i data-feather="trending-up"></i> +22.5%</span>
          </div>
          <div class="metric-icon bg-warning-subtle">
