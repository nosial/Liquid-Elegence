{% set root = "../../" %}
{% extends "layouts/dashboard.njk" %}

{% block title %}eCommerce — Liquid Elegance{% endblock %}

{% block scripts_before %}
<script src="{{ asset_root or root }}vendor/chart.js/chart.min.js"></script>
{% endblock %}

{% block content %}
<!-- Breadcrumb -->
<nav aria-label="breadcrumb" class="mb-3">
  <ol class="breadcrumb mb-0">
    <li class="breadcrumb-item"><a href="javascript:void(0)">Dashboards</a></li>
    <li class="breadcrumb-item active" aria-current="page">eCommerce</li>
  </ol>
</nav>

<!-- Page Header -->
<div class="mb-4">
  <h1 class="h3 mb-1">eCommerce</h1>
  <p class="text-muted mb-0">Track your sales and product performance</p>
</div>

<!-- Metric Cards -->
<div class="row g-4 mb-4">
