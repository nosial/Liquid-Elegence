{% extends "layouts/dashboard.njk" %}
{% set root = "../../" %}


{% block content %}
            <div class="calendar-layout">
                <div class="cal-sidebar-backdrop" id="calSidebarBackdrop"></div>
                <!-- Left Sidebar -->
                <div class="calendar-sidebar" id="calSidebar">
                    <div class="glass-card glass-card-body d-flex flex-column gap-3">
                        <div class="cal-sidebar-header-mobile">
                            <span class="cal-sidebar-title">Calendar</span>
                            <button class="cal-sidebar-close" id="calSidebarClose" title="Close"><i data-feather="x"></i></button>
                        </div>
                        <button class="btn-create-event" id="createEventBtn">
                            <i data-feather="plus" class="le-icon-18"></i>
                            Create Event
                        </button>

                        <div class="glass-divider"></div>

                        <!-- Mini Calendar -->
                        <div class="mini-calendar" id="miniCalendar">
                            <div class="mini-cal-header">
                                <button class="mini-cal-nav" id="miniPrev"><i data-feather="chevron-left" class="le-icon-16"></i></button>
                                <h6 id="miniCalTitle">March 2026</h6>
                                <button class="mini-cal-nav" id="miniNext"><i data-feather="chevron-right" class="le-icon-16"></i></button>
                            </div>
                            <div class="mini-cal-grid" id="miniCalGrid"></div>
                        </div>

                        <div class="glass-divider"></div>

                        <!-- Upcoming Events -->
                        <div>
                            <h6 class="le-stat-heading">Today &amp; Tomorrow</h6>
                            <div id="upcomingEvents"></div>
                        </div>

                        <div class="glass-divider"></div>

                        <!-- Calendar Filters -->
                        <div>
                            <h6 class="le-stat-heading">Calendars</h6>
                            <label class="cal-filter-item">
                                <input type="checkbox" value="work" checked>
                                <span class="cal-filter-check le-bg-primary"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg></span>
                                <span>Work</span>
                            </label>
                            <label class="cal-filter-item">
                                <input type="checkbox" value="personal" checked>
                                <span class="cal-filter-check le-bg-success"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg></span>
                                <span>Personal</span>
                            </label>
                            <label class="cal-filter-item">
                                <input type="checkbox" value="meetings" checked>
                                <span class="cal-filter-check le-bg-primary"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg></span>
                                <span>Meetings</span>
                            </label>
                            <label class="cal-filter-item">
                                <input type="checkbox" value="holidays" checked>
                                <span class="cal-filter-check le-bg-warning"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg></span>
                                <span>Holidays</span>
                            </label>
                        </div>
                    </div>
                </div>

                <!-- Main Calendar -->
                <div class="calendar-main">
                    <div class="glass-card glass-card-body d-flex flex-column flex-grow-1">
                        <div class="cal-main-header mb-3">
                            <div class="cal-nav-group">
                                <button class="cal-sidebar-toggle" id="calSidebarToggle" title="Sidebar"><i data-feather="menu"></i></button>
                                <button class="cal-nav-btn" id="mainPrev"><i data-feather="chevron-left" class="le-icon-18"></i></button>
                                <button class="cal-nav-btn" id="mainNext"><i data-feather="chevron-right" class="le-icon-18"></i></button>
                                <button class="cal-today-btn" id="mainTodayBtn">Today</button>
                                <h5 id="mainCalTitle">March 2026</h5>
                            </div>
                            <div class="glass-tabs" id="viewTabs">
                                <button class="glass-tab active" data-view="month">Month</button>
                                <button class="glass-tab" data-view="week">Week</button>
                                <button class="glass-tab" data-view="day">Day</button>
                            </div>
                        </div>

                        <!-- Month View -->
                        <div class="month-view active" id="monthView">
                            <div class="month-grid" id="monthGrid"></div>
                        </div>

                        <!-- Week View -->
                        <div class="week-view" id="weekView"></div>

                        <!-- Day View -->
                        <div class="day-view" id="dayView"></div>
                    </div>
                </div>
            </div>

            <!-- Event Modal -->
            <div class="modal fade modal-glass" id="eventModal" tabindex="-1" aria-labelledby="eventModalLabel" aria-hidden="true">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content glass-modal">
                        <div class="modal-header glass-modal-header">
                            <h5 class="modal-title fw-bold" id="eventModalLabel">New Event</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <div class="modal-body">
                            <div class="form-group">
                                <label for="eventTitle">Title</label>
                                <input type="text" class="glass-input" id="eventTitle" placeholder="Event title">
                            </div>
                            <div class="form-row">
                                <div class="form-group">
                                    <label for="eventDate">Date</label>
                                    <input type="date" class="glass-input" id="eventDate">
                                </div>
                                <div class="form-group">
                                    <label for="eventCalendar">Calendar</label>
                                    <select class="glass-input" id="eventCalendar">
                                        <option value="work">Work</option>
                                        <option value="personal">Personal</option>
                                        <option value="meetings">Meetings</option>
                                        <option value="holidays">Holidays</option>
                                    </select>
                                </div>
                            </div>
                            <div class="form-row">
                                <div class="form-group">
                                    <label for="eventStart">Start Time</label>
                                    <input type="time" class="glass-input" id="eventStart">
                                </div>
                                <div class="form-group">
                                    <label for="eventEnd">End Time</label>
                                    <input type="time" class="glass-input" id="eventEnd">
                                </div>
                            </div>
                            <div class="form-group">
                                <label for="eventLocation">Location</label>
                                <input type="text" class="glass-input" id="eventLocation" placeholder="Location">
                            </div>
                            <div class="form-group">
                                <label for="eventDesc">Description</label>
                                <textarea class="glass-input" id="eventDesc" rows="3" placeholder="Event description"></textarea>
                            </div>
                        </div>
                        <div class="modal-footer glass-modal-footer">
                            <button type="button" class="btn-modal-cancel" id="eventCancelBtn" data-bs-dismiss="modal">Cancel</button>
                            <button type="button" class="btn-modal-save" id="eventSaveBtn">Save Event</button>
                        </div>
                    </div>
                </div>
            </div>
            <button class="cal-fab-create" id="calFabCreate" title="New Event"><i data-feather="plus"></i></button>
{% endblock %}

{% block scripts %}
<script src="{{ asset_root or root }}js/apps/calendar.js"></script>
{% endblock %}
