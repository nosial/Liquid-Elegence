    {# Macro: standard landscape card (Netflix style — title overlaid only, hover shows meta strip) #}
    {% macro movieCard(v, badgeClass="") %}
        <a href="movie-streaming-title.html" class="movie-card">
            <div class="movie-card-thumb" style="background: {{ v.color }};">
                {% if v.badge %}
                    <div class="movie-card-badges">
                        <span class="movie-card-badge{% if v.badge == 'NEW' %} is-new{% elif v.badge == 'HD' %} is-hd{% elif v.badge == '4K' %} is-4k{% elif v.badge == 'CINEFLUX' %} is-cf{% elif v.badge == 'TOP 10' %} is-top{% endif %}">{{ v.badge }}</span>
                    </div>
                {% endif %}
                <span class="movie-card-thumb-title">{{ v.title }}</span>
                <span class="movie-card-icon"><i data-feather="play" class="le-icon-20"></i></span>
                <div class="movie-card-hover">
                    <div class="movie-card-hover-meta">
                        <span class="movie-pill movie-pill-strong">98% Match</span>
                        <span class="movie-pill">{{ v.maturity }}</span>
                        <span>{{ v.duration }}</span>
                        <span class="movie-dot"></span>
                        <span>{{ v.year }}</span>
                    </div>
                </div>
            </div>
        </a>
    {% endmacro %}

    {# ===== Billboard / Hero (full-bleed, no card wrapper) ===== #}
    <section class="movie-billboard glass-card animate-fade-in">
        <div class="movie-billboard-bg" style="background: {{ billboard.color }};"></div>
        <div class="movie-billboard-fade"></div>
        <div class="movie-billboard-side"></div>
        <div class="movie-billboard-content">
            <span class="movie-billboard-eyebrow"><i data-feather="award" class="le-icon-14"></i>{{ billboard.eyebrow }}</span>
            <h2 class="movie-billboard-title">{{ billboard.title }}</h2>
            <div class="movie-billboard-meta">
                <span class="movie-pill movie-pill-strong">{{ billboard.rating }}</span>
                <span>{{ billboard.year }}</span>
                <span class="movie-dot"></span>
                <span>{{ billboard.duration }}</span>
                <span class="movie-pill">{{ billboard.maturity }}</span>
            </div>
            <p class="movie-billboard-desc">{{ billboard.desc }}</p>
            <div class="movie-billboard-actions">
                <a href="movie-streaming-watch.html" class="movie-btn movie-btn-play"><i data-feather="play" class="le-icon-18"></i>Play</a>
                <a href="movie-streaming-title.html" class="movie-btn movie-btn-ghost"><i data-feather="info" class="le-icon-18"></i>More Info</a>
                <button type="button" class="movie-btn movie-btn-ghost movie-btn-icon movie-mylist-btn" aria-label="Add to My List"><i data-feather="plus" class="le-icon-18"></i></button>
            </div>
        </div>
        <div class="movie-billboard-extras">
            <span class="movie-billboard-maturity">{{ billboard.maturity }}</span>
        </div>
    </section>

    {# ===== Browse rails — consolidated into one layered panel =====
       All six rails (Continue Watching → Documentaries) live inside a
       single outer glass-card so the page reads as one frosted shell
       rather than six stacked panels. Each rail keeps its own internal
       horizontal padding for the side-nav buttons, separated by
       `.glass-divider` blocks for the layered look. #}
    <div class="glass-card movie-rails-panel animate-fade-in-up stagger-1">

        {# ===== Continue Watching ===== #}
        <section class="movie-rail">
            <div class="movie-rail-header">
                <h3 class="movie-rail-title">Continue Watching</h3>
                <a href="movie-streaming-browse.html" class="movie-rail-link"><span>Explore All</span><i data-feather="chevron-right" class="le-icon-14"></i></a>
            </div>
            <div class="movie-rail-viewport">
                <button class="movie-rail-nav is-prev" data-rail-nav="prev" aria-label="Scroll left"><i data-feather="chevron-left"></i></button>
                <div class="movie-rail-track">
                    {% for v in continueWatching %}
                    <a href="movie-streaming-watch.html" class="movie-card is-continue">
                        <div class="movie-card-thumb" style="background: {{ v.color }};">
                            <span class="movie-card-icon"><i data-feather="play" class="le-icon-20"></i></span>
                            <span class="movie-card-remaining">{{ v.remaining }}</span>
                            <div class="movie-card-progress"><div class="movie-card-progress-fill" style="width: {{ v.progress }}%;"></div></div>
                            <div class="movie-card-hover">
                                <div class="movie-card-hover-title">{{ v.title }}</div>
                                <div class="movie-card-hover-meta">
                                    {% if v.ep %}<span>{{ v.ep }}</span>{% else %}<span>{{ v.remaining }}</span>{% endif %}
                                </div>
                            </div>
                        </div>
                    </a>
                    {% endfor %}
                </div>
                <button class="movie-rail-nav is-next" data-rail-nav="next" aria-label="Scroll right"><i data-feather="chevron-right"></i></button>
            </div>
        </section>

        <div class="glass-divider my-3"></div>

        {# ===== Trending Now ===== #}
        <section class="movie-rail">
            <div class="movie-rail-header">
                <h3 class="movie-rail-title">Trending Now</h3>
                <a href="movie-streaming-browse.html" class="movie-rail-link"><span>Explore All</span><i data-feather="chevron-right" class="le-icon-14"></i></a>
            </div>
            <div class="movie-rail-viewport">
                <button class="movie-rail-nav is-prev" data-rail-nav="prev" aria-label="Scroll left"><i data-feather="chevron-left"></i></button>
                <div class="movie-rail-track">
                    {% for v in trending %}{{ movieCard(v) }}{% endfor %}
                </div>
                <button class="movie-rail-nav is-next" data-rail-nav="next" aria-label="Scroll right"><i data-feather="chevron-right"></i></button>
            </div>
        </section>

        <div class="glass-divider my-3"></div>

        {# ===== Top 10 ===== #}
        <section class="movie-rail">
            <div class="movie-rail-header">
                <h3 class="movie-rail-title">Top 10 in Your Country Today</h3>
            </div>
            <div class="movie-rail-viewport">
                <button class="movie-rail-nav is-prev" data-rail-nav="prev" aria-label="Scroll left"><i data-feather="chevron-left"></i></button>
                <div class="movie-rail-track is-top10-track">
                    {% for id in top10 %}
                    {% set v = top10Lookup[id] %}
                    <a href="movie-streaming-title.html" class="movie-card is-top10">
                        <span class="movie-card-rank" data-rank="{{ loop.index }}">{{ loop.index }}</span>
                        <div class="movie-card-thumb movie-card-thumb-portrait" style="background: {{ v.color }};">
                            <span class="movie-card-icon"><i data-feather="play" class="le-icon-20"></i></span>
                            <div class="movie-card-hover">
                                <div class="movie-card-hover-title">{{ v.title }}</div>
                                <div class="movie-card-hover-meta">
                                    <span class="movie-pill">{{ v.maturity }}</span>
                                    <span>{{ v.duration }}</span>
                                </div>
                            </div>
                        </div>
                    </a>
                    {% endfor %}
                </div>
                <button class="movie-rail-nav is-next" data-rail-nav="next" aria-label="Scroll right"><i data-feather="chevron-right"></i></button>
            </div>
        </section>

        <div class="glass-divider my-3"></div>

        {# ===== New Releases ===== #}
        <section class="movie-rail">
            <div class="movie-rail-header">
                <h3 class="movie-rail-title">New Releases</h3>
                <a href="movie-streaming-browse.html?filter=new" class="movie-rail-link"><span>Explore All</span><i data-feather="chevron-right" class="le-icon-14"></i></a>
            </div>
            <div class="movie-rail-viewport">
                <button class="movie-rail-nav is-prev" data-rail-nav="prev" aria-label="Scroll left"><i data-feather="chevron-left"></i></button>
                <div class="movie-rail-track">
                    {% for v in newReleases %}{{ movieCard(v) }}{% endfor %}
                </div>
                <button class="movie-rail-nav is-next" data-rail-nav="next" aria-label="Scroll right"><i data-feather="chevron-right"></i></button>
            </div>
        </section>

        <div class="glass-divider my-3"></div>

        {# ===== Cineflux Originals ===== #}
        <section class="movie-rail">
            <div class="movie-rail-header">
                <h3 class="movie-rail-title">Cineflux Originals</h3>
                <a href="movie-streaming-browse.html?filter=originals" class="movie-rail-link"><span>Explore All</span><i data-feather="chevron-right" class="le-icon-14"></i></a>
            </div>
            <div class="movie-rail-viewport">
                <button class="movie-rail-nav is-prev" data-rail-nav="prev" aria-label="Scroll left"><i data-feather="chevron-left"></i></button>
                <div class="movie-rail-track">
                    {% for v in originals %}{{ movieCard(v) }}{% endfor %}
                </div>
                <button class="movie-rail-nav is-next" data-rail-nav="next" aria-label="Scroll right"><i data-feather="chevron-right"></i></button>
            </div>
        </section>

        <div class="glass-divider my-3"></div>

        {# ===== Documentaries ===== #}
        <section class="movie-rail">
            <div class="movie-rail-header">
                <h3 class="movie-rail-title">Critically Acclaimed Documentaries</h3>
                <a href="movie-streaming-browse.html?filter=documentary" class="movie-rail-link"><span>Explore All</span><i data-feather="chevron-right" class="le-icon-14"></i></a>
            </div>
            <div class="movie-rail-viewport">
                <button class="movie-rail-nav is-prev" data-rail-nav="prev" aria-label="Scroll left"><i data-feather="chevron-left"></i></button>
