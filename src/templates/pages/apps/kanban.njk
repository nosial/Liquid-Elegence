                <div class="modal-header">
                    <div>
                        <h5 class="modal-title fw-bold" id="modalCardTitle"></h5>
                        <div class="modal-detail-labels d-flex gap-2 mt-2" id="modalCardLabels"></div>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="row">
                        <div class="col-md-8">
                            <div class="kanban-detail-section">
                                <div class="kanban-detail-label">Description</div>
                                <textarea class="glass-input w-100 le-textarea" id="modalCardDesc" rows="3"></textarea>
                            </div>
                            <div class="kanban-detail-section">
                                <div class="kanban-detail-label">Checklist</div>
                                <div class="kanban-progress-bar-wrap mb-2 le-h-6">
                                    <div class="kanban-progress-bar-fill" id="checklistProgress" style="width:33%;"></div>
                                </div>
                                <div id="modalChecklist">
                                    <div class="kanban-checklist-item">
                                        <input type="checkbox" id="check1" checked>
                                        <label for="check1">Research and define requirements</label>
                                    </div>
                                    <div class="kanban-checklist-item">
                                        <input type="checkbox" id="check2">
                                        <label for="check2">Create implementation plan</label>
                                    </div>
                                    <div class="kanban-checklist-item">
                                        <input type="checkbox" id="check3">
                                        <label for="check3">Submit for code review</label>
                                    </div>
                                </div>
                            </div>
                            <div class="kanban-detail-section">
                                <div class="kanban-detail-label">Comments</div>
                                <div id="modalComments">
                                    <div class="kanban-comment">
                                        <div class="kanban-comment-avatar le-bg-gradient-primary">SC</div>
                                        <div class="kanban-comment-body">
                                            <span class="comment-author">Sarah Chen</span>
                                            <span class="comment-time">2 hours ago</span>
                                            <p class="comment-text">I've started working on the initial implementation. Will push a draft PR by end of day.</p>
                                        </div>
                                    </div>
                                    <div class="kanban-comment">
                                        <div class="kanban-comment-avatar le-bg-gradient-success">MR</div>
                                        <div class="kanban-comment-body">
                                            <span class="comment-author">Mike Ross</span>
                                            <span class="comment-time">5 hours ago</span>
                                            <p class="comment-text">Make sure to check the edge cases we discussed in standup. I'll review once the PR is up.</p>
                                        </div>
                                    </div>
                                </div>
                                <div class="d-flex gap-2 mt-3">
                                    <div class="kanban-comment-avatar le-avatar-32 le-avatar-gradient">JD</div>
                                    <input type="text" class="glass-input flex-grow-1 le-glass-form-input" placeholder="Write a comment...">
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="kanban-detail-section">
                                <div class="kanban-detail-label">Assignees</div>
                                <div class="d-flex gap-2 flex-wrap" id="modalAssignees"></div>
                            </div>
                            <div class="kanban-detail-section">
                                <div class="kanban-detail-label">Due Date</div>
                                <div id="modalDueDate" class="le-fs-body fw-semibold"></div>
                            </div>
                            <div class="kanban-detail-section">
                                <div class="kanban-detail-label">Priority</div>
                                <div id="modalPriority" class="le-fs-body fw-semibold"></div>
                            </div>
                            <div class="kanban-detail-section">
                                <div class="kanban-detail-label">Column</div>
                                <div id="modalColumn" class="le-fs-body fw-semibold"></div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-sm le-btn-danger-ghost" data-bs-dismiss="modal">Delete Card</button>
                    <button type="button" class="btn btn-sm le-btn-primary-solid" data-bs-dismiss="modal">Save Changes</button>
                </div>
            </div>
        </div>
    </div>

{% endblock %}

{% block scripts %}
<script src="{{ asset_root or root }}js/apps/kanban.js"></script>
{% endblock %}
