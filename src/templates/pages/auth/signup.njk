{% set root = "../../" %}
{% extends "layouts/auth.njk" %}

{% block body_attrs %} class="auth-page page-signup"{% endblock %}

{% block auth_content %}
<div class="auth-container">
        <div class="auth-card">
            <div class="auth-brand">
                <span class="auth-brand-icon">◆</span>
                <span class="auth-brand-text">Liquid Elegance</span>
            </div>

            <h2 class="auth-title">Create Account</h2>
            <p class="auth-subtitle">Start your free 14-day trial</p>

            <form class="auth-form" id="signupForm" novalidate>
                <div class="auth-input-group">
                    <i data-feather="user" class="input-icon"></i>
                    <input type="text" class="form-control" id="fullName" placeholder="Full Name" required>
                    <div class="invalid-feedback">Please enter your full name.</div>
                </div>

                <div class="auth-input-group">
                    <i data-feather="mail" class="input-icon"></i>
                    <input type="email" class="form-control" id="email" placeholder="Email address" required>
                    <div class="invalid-feedback">Please enter a valid email address.</div>
                </div>

                <div class="auth-input-group">
                    <i data-feather="lock" class="input-icon"></i>
                    <input type="password" class="form-control pe-5" id="password" placeholder="Password" required>
                    <button type="button" class="toggle-password" data-target="password" aria-label="Toggle password visibility">
                        <i data-feather="eye" width="18" height="18"></i>
                    </button>
                    <div class="invalid-feedback">Please enter a password.</div>
                </div>

                <div class="auth-input-group">
                    <i data-feather="lock" class="input-icon"></i>
                    <input type="password" class="form-control" id="confirmPassword" placeholder="Confirm Password" required>
                    <div class="invalid-feedback">Passwords do not match.</div>
                </div>

                <div>
                    <div class="password-strength-bar">
                        <div class="bar-fill" id="strengthBar"></div>
                    </div>
                    <div class="password-strength-label" id="strengthLabel"></div>

                    <ul class="password-requirements" id="reqList">
                        <li data-req="length"><span class="req-icon">✓</span> 8+ characters</li>
                        <li data-req="upper"><span class="req-icon">✓</span> Uppercase</li>
                        <li data-req="lower"><span class="req-icon">✓</span> Lowercase</li>
                        <li data-req="number"><span class="req-icon">✓</span> Number</li>
                        <li data-req="special"><span class="req-icon">✓</span> Special char</li>
                    </ul>
                </div>

                <div class="auth-checkbox">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="agreeTerms" required>
                        <label class="form-check-label" for="agreeTerms">
                            I agree to the <a href="javascript:void(0)">Terms of Service</a> and <a href="javascript:void(0)">Privacy Policy</a>
                        </label>
                    </div>
                    <div class="invalid-feedback d-none" id="termsError">You must agree to the terms.</div>
                </div>

                <button type="submit" class="btn btn-primary w-100">Create Account</button>
            </form>

            <div class="auth-divider">or sign up with</div>

            <div class="auth-social">
                <a href="javascript:void(0)" class="btn btn-glass">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
                    Google
                </a>
                <a href="javascript:void(0)" class="btn btn-glass">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
                    GitHub
                </a>
                <a href="javascript:void(0)" class="btn btn-glass">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                    Twitter
                </a>
            </div>

            <div class="auth-footer">
                Already have an account? <a href="signin.html">Sign In</a>
            </div>
        </div>
    </div>
{% endblock %}

{% block scripts %}
<script>
        document.addEventListener('DOMContentLoaded', function() {
            if (typeof feather !== 'undefined') feather.replace();

            var passwordInput = document.getElementById('password');
            var confirmInput = document.getElementById('confirmPassword');
            var strengthBar = document.getElementById('strengthBar');
            var strengthLabel = document.getElementById('strengthLabel');
            var reqItems = document.querySelectorAll('#reqList li');

            var requirements = {
                length: function(v) { return v.length >= 8; },
                upper: function(v) { return /[A-Z]/.test(v); },
                lower: function(v) { return /[a-z]/.test(v); },
                number: function(v) { return /[0-9]/.test(v); },
                special: function(v) { return /[^A-Za-z0-9]/.test(v); }
            };

            function checkStrength(value) {
                var met = 0;
                reqItems.forEach(function(li) {
                    var req = li.dataset.req;
                    if (requirements[req] && requirements[req](value)) {
                        li.classList.add('met');
                        met++;
                    } else {
                        li.classList.remove('met');
                    }
                });

                var pct = (met / 5) * 100;
                strengthBar.style.width = pct + '%';

                if (met <= 1) {
                    strengthBar.style.background = 'var(--le-danger)';
                    strengthLabel.textContent = value.length ? 'Weak' : '';
                } else if (met <= 3) {
                    strengthBar.style.background = 'var(--le-warning)';
                    strengthLabel.textContent = 'Fair';
                } else if (met === 4) {
                    strengthBar.style.background = '#f59e0b';
                    strengthLabel.textContent = 'Good';
                } else {
                    strengthBar.style.background = 'var(--le-success)';
                    strengthLabel.textContent = 'Strong';
                }
            }

            passwordInput.addEventListener('input', function() {
                checkStrength(this.value);
                this.classList.remove('is-invalid');
            });

            // Password toggle
            document.querySelectorAll('.toggle-password').forEach(function(btn) {
                btn.addEventListener('click', function() {
                    var target = document.getElementById(this.dataset.target);
                    if (target.type === 'password') {
                        target.type = 'text';
                        this.innerHTML = '<i data-feather="eye-off" width="18" height="18"></i>';
                    } else {
                        target.type = 'password';
                        this.innerHTML = '<i data-feather="eye" width="18" height="18"></i>';
                    }
                    if (typeof feather !== 'undefined') feather.replace();
                });
            });

            // Form validation
            document.getElementById('signupForm').addEventListener('submit', function(e) {
                e.preventDefault();
                var valid = true;
                var name = document.getElementById('fullName');
                var email = document.getElementById('email');
                var terms = document.getElementById('agreeTerms');
                var termsError = document.getElementById('termsError');

                [name, email, passwordInput, confirmInput].forEach(function(el) { el.classList.remove('is-invalid'); });
                termsError.style.display = 'none';

                if (!name.value.trim()) { name.classList.add('is-invalid'); valid = false; }

                var emailPattern = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
                if (!emailPattern.test(email.value.trim())) { email.classList.add('is-invalid'); valid = false; }

                if (!passwordInput.value || passwordInput.value.length < 8) { passwordInput.classList.add('is-invalid'); valid = false; }

                if (confirmInput.value !== passwordInput.value || !confirmInput.value) { confirmInput.classList.add('is-invalid'); valid = false; }

                if (!terms.checked) { termsError.style.display = 'block'; valid = false; }

                if (valid) {
                    var btn = this.querySelector('.btn-primary');
                    btn.textContent = 'Creating account...';
                    btn.disabled = true;
                    setTimeout(function() { btn.textContent = 'Create Account'; btn.disabled = false; }, 2000);
                }
            });

            document.querySelectorAll('.form-control').forEach(function(input) {
                input.addEventListener('input', function() { this.classList.remove('is-invalid'); });
            });
        });
</script>
{% endblock %}
