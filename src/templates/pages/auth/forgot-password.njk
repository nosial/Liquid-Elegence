{% set root = "../../" %}
{% extends "layouts/auth.njk" %}


{% block auth_content %}
<div class="auth-container">
        <div class="auth-card">
            <div class="auth-brand">
                <span class="auth-brand-icon">◆</span>
                <span class="auth-brand-text">Liquid Elegance</span>
            </div>

            <div class="auth-icon-circle">
                <i data-feather="key" width="32" height="32"></i>
            </div>

            <h2 class="auth-title">Forgot Your Password?</h2>
            <p class="auth-subtitle">No worries! Enter your email address and we'll send you a link to reset your password.</p>

            <form class="auth-form" id="forgotForm" novalidate>
                <div class="auth-input-group">
                    <i data-feather="mail" class="input-icon"></i>
                    <input type="email" class="form-control" id="email" placeholder="Email address" required>
                    <div class="invalid-feedback">Please enter a valid email address.</div>
                </div>

                <button type="submit" class="btn btn-primary w-100" id="submitBtn">Send Reset Link</button>
            </form>

            <div class="auth-success-msg" id="successMsg">
                <i data-feather="check-circle" width="20" height="20" class="mb-2"></i>
                <div><strong>Check your email!</strong></div>
                <div id="successText">We've sent a password reset link to your email.</div>
            </div>

            <a href="signin.html" class="auth-back-link">
                <i data-feather="arrow-left" width="16" height="16"></i>
                Back to Sign In
            </a>
        </div>
    </div>
{% endblock %}

{% block scripts %}
<script>
        document.addEventListener('DOMContentLoaded', function() {
            if (typeof feather !== 'undefined') feather.replace();

            var form = document.getElementById('forgotForm');
            var emailInput = document.getElementById('email');
            var successMsg = document.getElementById('successMsg');
            var successText = document.getElementById('successText');
            var submitBtn = document.getElementById('submitBtn');

            form.addEventListener('submit', function(e) {
                e.preventDefault();
                emailInput.classList.remove('is-invalid');

                var emailPattern = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
                if (!emailPattern.test(emailInput.value.trim())) {
                    emailInput.classList.add('is-invalid');
                    return;
                }

                submitBtn.textContent = 'Sending...';
                submitBtn.disabled = true;

                setTimeout(function() {
                    form.style.display = 'none';
                    successText.textContent = "We've sent a password reset link to " + emailInput.value.trim();
                    successMsg.classList.add('show');
                    if (typeof feather !== 'undefined') feather.replace();
                }, 1500);
            });

            emailInput.addEventListener('input', function() {
                this.classList.remove('is-invalid');
            });
        });
</script>
{% endblock %}
