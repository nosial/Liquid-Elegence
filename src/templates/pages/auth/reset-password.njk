{% set root = "../../" %}
{% extends "layouts/auth.njk" %}


{% block auth_content %}
<div class="auth-container">
        <div class="auth-card">
            <div class="auth-brand">
                <span class="auth-brand-icon">◆</span>
                <span class="auth-brand-text">Liquid Elegance</span>
            </div>

            <div class="auth-icon-circle">
                <i data-feather="lock" width="32" height="32"></i>
            </div>

            <h2 class="auth-title">Reset Your Password</h2>
            <p class="auth-subtitle">Enter your new password below</p>

            <form class="auth-form" id="resetForm" novalidate>
                <div class="auth-input-group">
                    <i data-feather="lock" class="input-icon"></i>
                    <input type="password" class="form-control pe-5" id="newPassword" placeholder="New Password" required>
                    <button type="button" class="toggle-password" data-target="newPassword" aria-label="Toggle password visibility">
                        <i data-feather="eye" width="18" height="18"></i>
                    </button>
                    <div class="invalid-feedback">Please enter a new password.</div>
                </div>

                <div class="auth-input-group">
                    <i data-feather="lock" class="input-icon"></i>
                    <input type="password" class="form-control pe-5" id="confirmPassword" placeholder="Confirm Password" required>
                    <button type="button" class="toggle-password" data-target="confirmPassword" aria-label="Toggle password visibility">
                        <i data-feather="eye" width="18" height="18"></i>
                    </button>
                    <div class="invalid-feedback">Passwords do not match.</div>
                </div>

                <div>
                    <div class="password-strength-bar">
                        <div class="bar-fill" id="strengthBar"></div>
                    </div>
                    <div class="password-strength-label" id="strengthLabel"></div>

                    <ul class="password-requirements" id="reqList">
                        <li data-req="length"><span class="req-icon">✓</span> 8+ characters</li>
                        <li data-req="upper"><span class="req-icon">✓</span> Uppercase</li>
                        <li data-req="lower"><span class="req-icon">✓</span> Lowercase</li>
                        <li data-req="number"><span class="req-icon">✓</span> Number</li>
                        <li data-req="special"><span class="req-icon">✓</span> Special char</li>
                    </ul>
                </div>

                <button type="submit" class="btn btn-primary w-100" id="resetBtn">Reset Password</button>
            </form>

            <div class="auth-success-msg" id="successMsg">
                <i data-feather="check-circle" width="20" height="20" class="mb-2"></i>
                <div><strong>Password successfully reset!</strong></div>
                <div>Redirecting to sign in...</div>
            </div>

            <a href="signin.html" class="auth-back-link">
                <i data-feather="arrow-left" width="16" height="16"></i>
                Back to Sign In
            </a>
        </div>
    </div>
{% endblock %}

{% block scripts %}
<script>
        document.addEventListener('DOMContentLoaded', function() {
            if (typeof feather !== 'undefined') feather.replace();

            var passwordInput = document.getElementById('newPassword');
            var confirmInput = document.getElementById('confirmPassword');
            var strengthBar = document.getElementById('strengthBar');
            var strengthLabel = document.getElementById('strengthLabel');
            var reqItems = document.querySelectorAll('#reqList li');

            var requirements = {
                length: function(v) { return v.length >= 8; },
                upper: function(v) { return /[A-Z]/.test(v); },
                lower: function(v) { return /[a-z]/.test(v); },
                number: function(v) { return /[0-9]/.test(v); },
                special: function(v) { return /[^A-Za-z0-9]/.test(v); }
            };

            function checkStrength(value) {
                var met = 0;
                reqItems.forEach(function(li) {
                    var req = li.dataset.req;
                    if (requirements[req] && requirements[req](value)) {
                        li.classList.add('met');
                        met++;
                    } else {
                        li.classList.remove('met');
                    }
                });
                var pct = (met / 5) * 100;
                strengthBar.style.width = pct + '%';
                if (met <= 1) { strengthBar.style.background = 'var(--le-danger)'; strengthLabel.textContent = value.length ? 'Weak' : ''; }
                else if (met <= 3) { strengthBar.style.background = 'var(--le-warning)'; strengthLabel.textContent = 'Fair'; }
                else if (met === 4) { strengthBar.style.background = '#f59e0b'; strengthLabel.textContent = 'Good'; }
                else { strengthBar.style.background = 'var(--le-success)'; strengthLabel.textContent = 'Strong'; }
            }

            passwordInput.addEventListener('input', function() {
                checkStrength(this.value);
                this.classList.remove('is-invalid');
            });

            // Password toggles
            document.querySelectorAll('.toggle-password').forEach(function(btn) {
                btn.addEventListener('click', function() {
                    var target = document.getElementById(this.dataset.target);
                    if (target.type === 'password') {
                        target.type = 'text';
                        this.innerHTML = '<i data-feather="eye-off" width="18" height="18"></i>';
                    } else {
                        target.type = 'password';
                        this.innerHTML = '<i data-feather="eye" width="18" height="18"></i>';
                    }
                    if (typeof feather !== 'undefined') feather.replace();
                });
            });

            // Form submission
            document.getElementById('resetForm').addEventListener('submit', function(e) {
                e.preventDefault();
                var valid = true;
                passwordInput.classList.remove('is-invalid');
                confirmInput.classList.remove('is-invalid');

                if (!passwordInput.value || passwordInput.value.length < 8) {
                    passwordInput.classList.add('is-invalid');
                    valid = false;
                }
                if (confirmInput.value !== passwordInput.value || !confirmInput.value) {
                    confirmInput.classList.add('is-invalid');
                    valid = false;
                }

                if (valid) {
                    var btn = document.getElementById('resetBtn');
                    btn.textContent = 'Resetting...';
                    btn.disabled = true;
                    setTimeout(function() {
                        document.getElementById('resetForm').style.display = 'none';
                        document.getElementById('successMsg').classList.add('show');
                        if (typeof feather !== 'undefined') feather.replace();
                        setTimeout(function() {
                            window.location.href = 'signin.html';
                        }, 3000);
                    }, 1500);
                }
            });

            document.querySelectorAll('.form-control').forEach(function(input) {
                input.addEventListener('input', function() { this.classList.remove('is-invalid'); });
            });
        });
</script>
{% endblock %}
